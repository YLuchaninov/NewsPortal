---
import { DEFAULT_PAGE, DEFAULT_PAGE_SIZE } from "@newsportal/contracts";
import type { ContentItemPreview, WebContentListSort } from "@newsportal/contracts";
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { PaginationNav } from "@newsportal/ui";
import { buildLiveRevision } from "../lib/live-updates";
import Shell from "../layouts/Shell.astro";
import { ContentItemCard } from "../components/ContentItemCard";
import { LiveSurfaceSummary } from "../components/LiveSurfaceSummary";
import { getPool, queryOne } from "../lib/server/db";
import { resolveWebSession } from "../lib/server/auth";
import { readFlash } from "../lib/server/browser-flow";
import { getUserContentStateMap } from "../lib/server/user-content-state";

export const prerender = false;
const WEB_CONTENT_SORT_OPTIONS: Array<{ value: WebContentListSort; label: string }> = [
  { value: "latest", label: "Newest first" },
  { value: "oldest", label: "Oldest first" },
  { value: "title_asc", label: "Title A-Z" },
  { value: "title_desc", label: "Title Z-A" },
];

function isWebContentListSort(value: string | null): value is WebContentListSort {
  return WEB_CONTENT_SORT_OPTIONS.some((option) => option.value === value);
}

const session = await resolveWebSession(Astro.request);

if (!session) {
  return Astro.redirect("/");
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({
  baseUrl: readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4321/" }).apiBaseUrl,
  fetchImpl: fetch,
});

const pageBaseUrl = new URL(Astro.url);
if (!pageBaseUrl.pathname.endsWith("/")) pageBaseUrl.pathname += "/";
function resolvePageAppPath(t: string) {
  return new URL(t.replace(/^\/+/, ""), pageBaseUrl).pathname;
}

const bffPaths = {
  authBootstrap: resolvePageAppPath("../bff/auth/bootstrap"),
  authLogout: resolvePageAppPath("../bff/auth/logout"),
  liveUpdates: resolvePageAppPath("../bff/live-updates"),
  preferences: resolvePageAppPath("../bff/preferences"),
  reactions: resolvePageAppPath("../bff/reactions"),
  contentState: resolvePageAppPath("../bff/content-state"),
};

const requestedPage = Number.parseInt(Astro.url.searchParams.get("page") ?? String(DEFAULT_PAGE), 10);
const page = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : DEFAULT_PAGE;
const requestedQuery = Astro.url.searchParams.get("q") ?? "";
const searchQuery = requestedQuery.trim();
const requestedSort = Astro.url.searchParams.get("sort");
const selectedSort: WebContentListSort = isWebContentListSort(requestedSort)
  ? requestedSort
  : "latest";
const hasActiveFilters = searchQuery.length > 0 || selectedSort !== "latest";
const [matches, profile] = await Promise.all([
  sdk.listMatchesPage<ContentItemPreview>(session.userId, {
    page,
    pageSize: DEFAULT_PAGE_SIZE,
    sort: selectedSort,
    q: searchQuery || undefined,
  }),
  queryOne<Record<string, unknown>>(`select theme_preference from user_profiles where user_id = $1`, [session.userId]),
]);
const userStateMap = await getUserContentStateMap(getPool(), session.userId, matches.items);
const matchesRevision = buildLiveRevision([
  matches.total,
  matches.items[0]?.content_item_id,
  matches.items[0]?.published_at ?? matches.items[0]?.ingested_at,
]);

const themePreference = String(profile?.theme_preference ?? "system");
const themeClass = themePreference === "dark" ? "dark" : "";
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;
const clearFiltersHref = Astro.url.pathname;

function resolvePageHref(nextPage: number): string {
  const target = new URL(Astro.url);
  if (nextPage <= DEFAULT_PAGE) {
    target.searchParams.delete("page");
  } else {
    target.searchParams.set("page", String(nextPage));
  }
  return `${target.pathname}${target.search}`;
}

function readMatchNote(match: ContentItemPreview): string | null {
  const interestDescription = String(match.matched_interest_description ?? "").trim();
  const rawScore = Number(match.interest_match_score ?? NaN);
  const scoreLabel = Number.isFinite(rawScore) ? `score ${rawScore.toFixed(2)}` : "";

  if (!interestDescription && !scoreLabel) {
    return null;
  }

  if (!interestDescription) {
    return scoreLabel;
  }

  if (!scoreLabel) {
    return `Matched via "${interestDescription}"`;
  }

  return `Matched via "${interestDescription}" - ${scoreLabel}`;
}
---

<Shell
  title="My Matches — NewsPortal"
  session={session}
  themeClass={themeClass}
  currentTheme={themePreference}
  flash={flash}
  activeNav="matches"
  bffLiveUpdatesPath={bffPaths.liveUpdates}
  bffPreferencesPath={bffPaths.preferences}
  bffLogoutPath={bffPaths.authLogout}
  bffBootstrapPath={bffPaths.authBootstrap}
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">My Matches</h1>
    <p class="text-muted-foreground mt-1">
      Content from the system-selected collection that also matched your interests
    </p>
    <LiveSurfaceSummary
      surface="matches"
      initialCount={matches.total}
      initialRevision={matchesRevision}
      page={matches.page}
      totalPages={matches.totalPages}
      singularLabel="matched item"
      pluralLabel="matched items"
      suffix=" total"
      refreshHref={currentPath}
      client:load
    />
  </div>

  <form method="get" action={Astro.url.pathname} class="mb-8 rounded-xl border border-border bg-card p-4 shadow-sm">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end">
      <div class="flex-1">
        <label for="matches-search" class="mb-1 block text-sm font-medium text-foreground">Search</label>
        <input
          id="matches-search"
          type="search"
          name="q"
          value={searchQuery}
          placeholder="Search title or text"
          class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring"
        />
      </div>
      <div class="w-full lg:w-56">
        <label for="matches-sort" class="mb-1 block text-sm font-medium text-foreground">Sort</label>
        <select
          id="matches-sort"
          name="sort"
          class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring"
        >
          {WEB_CONTENT_SORT_OPTIONS.map((option) => (
            <option value={option.value} selected={option.value === selectedSort}>{option.label}</option>
          ))}
        </select>
      </div>
      <div class="flex gap-2 lg:pb-0">
        <button
          type="submit"
          class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          Apply
        </button>
        <a
          href={clearFiltersHref}
          class="inline-flex h-10 items-center justify-center rounded-md border border-input px-4 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
        >
          Clear filters
        </a>
      </div>
    </div>
  </form>

  {matches.total === 0 ? (
    <div class="flex flex-col items-center justify-center py-24 text-center">
      <div class="h-16 w-16 rounded-full bg-muted flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </div>
      <p class="font-semibold text-lg">{hasActiveFilters ? "No filtered matches found" : "No personal matches yet"}</p>
      <p class="text-muted-foreground text-sm mt-1 max-w-md">
        {hasActiveFilters
          ? "Try a different search or sort option, or clear the current filters to see all of your matches."
          : "This page only fills with content that passed the global system-selected collection and also matched your interests. Create or update an interest, then give the background sync a moment to replay existing selected content."}
      </p>
      {!hasActiveFilters && (
        <a href="/interests" class="mt-4 inline-flex h-9 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
          Manage Interests
        </a>
      )}
    </div>
  ) : (
    <>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {matches.items.map((contentItem) => (
          <ContentItemCard
            contentItem={contentItem}
            isLoggedIn={!!session}
            reactionsPath={bffPaths.reactions}
            contentStatePath={bffPaths.contentState}
            contextBadgeLabel="my-match"
            contextNote={readMatchNote(contentItem)}
            initialUserState={userStateMap.get(String(contentItem.content_item_id))}
            client:visible
          />
        ))}
      </div>
      {(matches.hasPrev || matches.hasNext) && (
        <PaginationNav
          className="mt-8"
          page={matches.page}
          totalPages={matches.totalPages}
          hasPrev={matches.hasPrev}
          hasNext={matches.hasNext}
          prevHref={resolvePageHref(matches.page - 1)}
          nextHref={resolvePageHref(matches.page + 1)}
        />
      )}
    </>
  )}
</Shell>
