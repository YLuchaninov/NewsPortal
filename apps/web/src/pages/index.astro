---
import { DEFAULT_BRAND_CONFIG, readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { APP_SHELL_STYLES } from "@newsportal/ui";

import { queryOne, queryRows } from "../lib/server/db";
import { resolveWebSession } from "../lib/server/auth";
import { readFlash } from "../lib/server/browser-flow";

export const prerender = false;
const session = await resolveWebSession(Astro.request);
const flash = readFlash(Astro.url);
const runtimeConfig = readRuntimeConfig(process.env, {
  defaultAppBaseUrl: "http://127.0.0.1:4321/"
});
const sdk = createNewsPortalSdk({
  baseUrl: runtimeConfig.apiBaseUrl,
  fetchImpl: fetch
});
const pageBaseUrl = new URL(Astro.url);
if (!pageBaseUrl.pathname.endsWith("/")) {
  pageBaseUrl.pathname = `${pageBaseUrl.pathname}/`;
}

function resolvePageAppPath(target: string): string {
  const resolved = new URL(String(target).replace(/^\/+/, ""), pageBaseUrl);
  return `${resolved.pathname}${resolved.search}${resolved.hash}`;
}

const bffPaths = {
  authBootstrap: resolvePageAppPath("bff/auth/bootstrap"),
  authLogout: resolvePageAppPath("bff/auth/logout"),
  feedback: resolvePageAppPath("bff/feedback"),
  interests: resolvePageAppPath("bff/interests"),
  interest: (interestId: string) => resolvePageAppPath(`bff/interests/${interestId}`),
  notificationChannels: resolvePageAppPath("bff/notification-channels"),
  preferences: resolvePageAppPath("bff/preferences"),
  reactions: resolvePageAppPath("bff/reactions")
};

type ViewRow = Record<string, unknown>;

const articles = await sdk.listArticles<Array<ViewRow>>();
const interests = session ? await sdk.listInterests<Array<ViewRow>>(session.userId) : [];
const notifications = session
  ? await sdk.listNotifications<Array<ViewRow>>(session.userId)
  : [];
const [profile, configuredChannels] = session
  ? await Promise.all([
      queryOne<ViewRow>(
        `
          select theme_preference, notification_preferences
          from user_profiles
          where user_id = $1
        `,
        [session.userId]
      ),
      queryRows<ViewRow>(
        `
          select
            unc.*,
            last_delivery.status as last_status,
            last_delivery.sent_at as last_sent_at,
            last_delivery.delivery_payload_json as last_delivery_payload_json
          from user_notification_channels unc
          left join lateral (
            select
              status,
              sent_at,
              delivery_payload_json
            from notification_log nl
            where nl.user_id = unc.user_id
              and nl.channel_type = unc.channel_type
            order by nl.created_at desc
            limit 1
          ) last_delivery on true
          where unc.user_id = $1
          order by unc.channel_type, unc.created_at desc
        `,
        [session.userId]
      )
    ])
  : [null, []];

function asRecord(value: unknown): Record<string, unknown> {
  return value != null && typeof value === "object" && !Array.isArray(value)
    ? (value as Record<string, unknown>)
    : {};
}

function asStringList(value: unknown): string[] {
  return Array.isArray(value)
    ? value.map((entry) => String(entry ?? "").trim()).filter(Boolean)
    : [];
}

function asCsv(value: unknown): string {
  return asStringList(value).join(", ");
}

function asLines(value: unknown): string {
  return asStringList(value).join("\n");
}

function formatTimestamp(value: unknown): string {
  if (!value) {
    return "never";
  }

  const parsed = new Date(String(value));
  return Number.isNaN(parsed.getTime()) ? String(value) : parsed.toLocaleString("en-US");
}

const notificationPreferences = asRecord(profile?.notification_preferences);
const themePreference = String(profile?.theme_preference ?? "system");
const preferenceState = {
  webPush: notificationPreferences.web_push !== false,
  telegram: notificationPreferences.telegram !== false,
  weeklyEmailDigest: notificationPreferences.weekly_email_digest !== false
};
const flashTone = flash?.status === "error" ? "var(--np-danger)" : "var(--np-success)";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{DEFAULT_BRAND_CONFIG.productName} Web MVP</title>
    <style is:global set:html={APP_SHELL_STYLES}></style>
  </head>
  <body>
    <main>
      <div class="np-shell">
        {flash ? (
          <div
            class="np-card"
            role={flash.status === "error" ? "alert" : "status"}
            aria-live="polite"
            style={`border-left: 4px solid ${flashTone}; margin-bottom: 16px;`}
          >
            <strong>{flash.status === "error" ? "Action failed" : "Action complete"}</strong>
            <p style="margin-bottom: 0;">{flash.message}</p>
          </div>
        ) : null}
        <section id="auth" class="np-card" style={`background:${DEFAULT_BRAND_CONFIG.backgroundGradient}; scroll-margin-top: 24px;`}>
          <p class="np-subtle">User-facing local MVP</p>
          <h1 class="np-heading">{DEFAULT_BRAND_CONFIG.productName}</h1>
          <p>{DEFAULT_BRAND_CONFIG.tagline}</p>
          {
            session ? (
              <div>
                <span class="np-pill">userId: {session.userId}</span>
                <span class="np-pill">provider: {session.identity.provider}</span>
                <span class="np-pill">anonymous: {String(session.identity.isAnonymous)}</span>
                <form method="post" action={bffPaths.authLogout} style="margin-top: 16px;">
                  <button type="submit" class="np-button secondary">Sign Out</button>
                </form>
              </div>
            ) : (
              <div class="np-grid two" style="align-items: start;">
                <div>
                  <p class="np-subtle">
                    Anonymous Firebase bootstrap is required before interests, reactions, and
                    notification channels become writable.
                  </p>
                  <button id="bootstrap-session" class="np-button" type="button">
                    Start Anonymous Session
                  </button>
                </div>
                <div class="np-card">
                  <strong>Local MVP behavior</strong>
                  <p class="np-subtle">
                    The page stays server-rendered, while session bootstrap happens via the BFF.
                  </p>
                </div>
              </div>
            )
          }
        </section>

        <section class="np-grid two">
          <article id="interests" class="np-card" style="scroll-margin-top: 24px;">
            <h2>Interests</h2>
            {
              session ? (
                <>
                  <form method="post" action={bffPaths.interests}>
                    <label>
                      Description
                      <textarea name="description" rows="3" placeholder="AI policy updates in the EU"></textarea>
                    </label>
                    <label>
                      Positive prototypes
                      <textarea name="positive_texts" rows="4" placeholder="EU AI Act&#10;Brussels regulation"></textarea>
                    </label>
                    <label>
                      Negative prototypes
                      <textarea name="negative_texts" rows="3" placeholder="sports&#10;celebrity gossip"></textarea>
                    </label>
                    <label>
                      Places
                      <input name="places" placeholder="Brussels, Warsaw" />
                    </label>
                    <label>
                      Languages
                      <input name="languages_allowed" value="en" />
                    </label>
                    <label>
                      Must-have terms
                      <input name="must_have_terms" placeholder="policy, regulation" />
                    </label>
                    <label>
                      Must-not-have terms
                      <input name="must_not_have_terms" placeholder="sports, celebrity" />
                    </label>
                    <label>
                      Required short tokens
                      <input name="short_tokens_required" placeholder="EU, AI" />
                    </label>
                    <label>
                      Forbidden short tokens
                      <input name="short_tokens_forbidden" placeholder="NBA, NFL" />
                    </label>
                    <label>
                      Priority
                      <input name="priority" type="number" value="1" min="0.1" max="1" step="0.1" />
                    </label>
                    <input type="submit" value="Create Interest" />
                  </form>
                  <div style="margin-top: 20px;">
                    {interests.length === 0 ? (
                      <p class="np-subtle">No interests yet.</p>
                    ) : (
                      interests.map((interest) => (
                        <article class="np-card" style="margin-top: 12px;">
                          <strong>{String(interest.description ?? "Untitled interest")}</strong>
                          <div class="np-subtle">
                            status: {String(interest.compile_status ?? "pending")} | version:{" "}
                            {String(interest.version ?? "-")} | enabled: {String(interest.enabled === true)}
                          </div>
                          <div class="np-subtle">
                            compiled at: {formatTimestamp(interest.compiled_at)} | compile error:{" "}
                            {String(interest.error_text ?? "none")}
                          </div>
                          <details style="margin-top: 12px;">
                            <summary>Edit / clone / delete</summary>
                            <form
                              method="post"
                              action={bffPaths.interest(String(interest.interest_id))}
                              style="margin-top: 12px;"
                            >
                              <input type="hidden" name="_action" value="update" />
                              <label>
                                Description
                                <textarea name="description" rows="2">{String(interest.description ?? "")}</textarea>
                              </label>
                              <label>
                                Positive prototypes
                                <textarea name="positive_texts" rows="4">{asLines(interest.positive_texts)}</textarea>
                              </label>
                              <label>
                                Negative prototypes
                                <textarea name="negative_texts" rows="3">{asLines(interest.negative_texts)}</textarea>
                              </label>
                              <label>
                                Places
                                <input name="places" value={asCsv(interest.places)} />
                              </label>
                              <label>
                                Languages
                                <input name="languages_allowed" value={asCsv(interest.languages_allowed)} />
                              </label>
                              <label>
                                Must-have terms
                                <input name="must_have_terms" value={asCsv(interest.must_have_terms)} />
                              </label>
                              <label>
                                Must-not-have terms
                                <input name="must_not_have_terms" value={asCsv(interest.must_not_have_terms)} />
                              </label>
                              <label>
                                Required short tokens
                                <input name="short_tokens_required" value={asCsv(interest.short_tokens_required)} />
                              </label>
                              <label>
                                Forbidden short tokens
                                <input name="short_tokens_forbidden" value={asCsv(interest.short_tokens_forbidden)} />
                              </label>
                              <label>
                                Priority
                                <input
                                  name="priority"
                                  type="number"
                                  min="0.1"
                                  max="1"
                                  step="0.1"
                                  value={String(interest.priority ?? 1)}
                                />
                              </label>
                              <label>
                                Enabled
                                <select name="enabled">
                                  <option value="true" selected={interest.enabled === true}>true</option>
                                  <option value="false" selected={interest.enabled !== true}>false</option>
                                </select>
                              </label>
                              <button type="submit" class="np-button secondary">Save Interest</button>
                            </form>
                            <div class="np-grid two" style="margin-top: 12px;">
                              <form method="post" action={bffPaths.interest(String(interest.interest_id))}>
                                <input type="hidden" name="_action" value="clone" />
                                <input
                                  type="hidden"
                                  name="description"
                                  value={`Copy of ${String(interest.description ?? "interest")}`}
                                />
                                <button type="submit" class="np-button secondary">Clone</button>
                              </form>
                              <form method="post" action={bffPaths.interest(String(interest.interest_id))}>
                                <input type="hidden" name="_action" value="delete" />
                                <button type="submit" class="np-button secondary">Delete</button>
                              </form>
                            </div>
                          </details>
                        </article>
                      ))
                    )}
                  </div>
                </>
              ) : (
                <p class="np-subtle">Bootstrap a session first.</p>
              )
            }
          </article>

          <article id="preferences" class="np-card" style="scroll-margin-top: 24px;">
            <h2>Preferences & Channels</h2>
            {
              session ? (
                <>
                  <form method="post" action={bffPaths.preferences}>
                    <label>
                      Theme preference
                      <select name="themePreference">
                        <option value="system" selected={themePreference === "system"}>System</option>
                        <option value="light" selected={themePreference === "light"}>Light</option>
                        <option value="dark" selected={themePreference === "dark"}>Dark</option>
                      </select>
                    </label>
                    <label>
                      Web push enabled
                      <select name="webPushEnabled">
                        <option value="true" selected={preferenceState.webPush}>true</option>
                        <option value="false" selected={!preferenceState.webPush}>false</option>
                      </select>
                    </label>
                    <label>
                      Telegram enabled
                      <select name="telegramEnabled">
                        <option value="true" selected={preferenceState.telegram}>true</option>
                        <option value="false" selected={!preferenceState.telegram}>false</option>
                      </select>
                    </label>
                    <label>
                      Weekly email digest enabled
                      <select name="weeklyEmailDigestEnabled">
                        <option value="true" selected={preferenceState.weeklyEmailDigest}>true</option>
                        <option value="false" selected={!preferenceState.weeklyEmailDigest}>false</option>
                      </select>
                    </label>
                    <input type="submit" value="Save Preferences" />
                  </form>

                  <div class="np-grid two" style="margin-top: 18px;">
                    <div class="np-card">
                      <strong>Web Push</strong>
                      <p class="np-subtle">
                        {runtimeConfig.webPushVapidPublicKey
                          ? "Register the browser subscription for manual push testing."
                          : "WEB_PUSH_VAPID_PUBLIC_KEY is not configured for the web app."}
                      </p>
                      <button
                        id="connect-web-push"
                        class="np-button secondary"
                        type="button"
                        disabled={!runtimeConfig.webPushVapidPublicKey}
                        data-vapid-key={runtimeConfig.webPushVapidPublicKey}
                      >
                        Connect Web Push
                      </button>
                      <p id="web-push-status" class="np-subtle" style="margin-top: 12px;"></p>
                    </div>

                    <div>
                      <form method="post" action={bffPaths.notificationChannels} style="margin-top: 0;">
                        <input type="hidden" name="channelType" value="telegram" />
                        <label>
                          Telegram chat ID
                          <input name="chatId" placeholder="123456789" />
                        </label>
                        <input type="submit" value="Connect Telegram" />
                      </form>
                      <form method="post" action={bffPaths.notificationChannels}>
                        <input type="hidden" name="channelType" value="email_digest" />
                        <label>
                          Digest email
                          <input
                            name="email"
                            value={session.identity.email ?? ""}
                            placeholder="user@example.com"
                          />
                        </label>
                        <input type="submit" value="Connect Email Digest" />
                      </form>
                    </div>
                  </div>

                  <div style="margin-top: 18px;">
                    {configuredChannels.length === 0 ? (
                      <p class="np-subtle">No notification channels configured yet.</p>
                    ) : (
                      <table class="np-table">
                        <thead>
                          <tr>
                            <th>Channel</th>
                            <th>Verified</th>
                            <th>Last Delivery</th>
                            <th>Detail</th>
                          </tr>
                        </thead>
                        <tbody>
                          {configuredChannels.map((channel) => {
                            const configJson = asRecord(channel.config_json);
                            const deliveryPayload = asRecord(channel.last_delivery_payload_json);
                            return (
                              <tr>
                                <td>
                                  <div>{String(channel.channel_type ?? "-")}</div>
                                  <div class="np-subtle">
                                    {String(configJson.email ?? configJson.chat_id ?? "browser subscription")}
                                  </div>
                                </td>
                                <td>{formatTimestamp(channel.verified_at)}</td>
                                <td>
                                  <div>{String(channel.last_status ?? "never")}</div>
                                  <div class="np-subtle">{formatTimestamp(channel.last_sent_at)}</div>
                                </td>
                                <td>{String(deliveryPayload.detail ?? "-")}</td>
                              </tr>
                            );
                          })}
                        </tbody>
                      </table>
                    )}
                  </div>
                </>
              ) : (
                <p class="np-subtle">Session required.</p>
              )
            }
          </article>
        </section>

        <section id="feed" class="np-card" style="scroll-margin-top: 24px;">
          <h2>Matched News Feed</h2>
          <div class="np-grid two">
            {articles.map((article) => (
              <article class="np-card">
                <div>
                  <span class="np-pill">{String(article.lang ?? "n/a")}</span>
                  <span class="np-pill">{String(article.processing_state ?? "raw")}</span>
                  <span class="np-pill">{String(article.visibility_state ?? "visible")}</span>
                </div>
                <h3>{String(article.title ?? "Untitled article")}</h3>
                <p class="np-subtle">{String(article.lead ?? "")}</p>
                <p class="np-subtle">
                  likes: {String(article.like_count ?? 0)} | dislikes: {String(article.dislike_count ?? 0)}
                </p>
                {session ? (
                  <div class="np-grid two">
                    <form method="post" action={bffPaths.reactions}>
                      <input type="hidden" name="docId" value={String(article.doc_id)} />
                      <input type="hidden" name="reactionType" value="like" />
                      <input type="submit" value="Like" />
                    </form>
                    <form method="post" action={bffPaths.reactions}>
                      <input type="hidden" name="docId" value={String(article.doc_id)} />
                      <input type="hidden" name="reactionType" value="dislike" />
                      <input type="submit" value="Dislike" />
                    </form>
                  </div>
                ) : null}
                <a href={`${runtimeConfig.publicApiBaseUrl}/articles/${String(article.doc_id)}`} target="_blank">
                  Open raw article payload
                </a>
              </article>
            ))}
          </div>
        </section>

        <section id="notifications" class="np-card" style="scroll-margin-top: 24px;">
          <h2>Notification History</h2>
          {session ? (
            notifications.length === 0 ? (
              <p class="np-subtle">No notifications yet.</p>
            ) : (
              <table class="np-table">
                <thead>
                  <tr>
                    <th>Article</th>
                    <th>Channel</th>
                    <th>Status</th>
                    <th>Decision</th>
                    <th>Feedback</th>
                  </tr>
                </thead>
                <tbody>
                  {notifications.map((notification) => (
                    <tr>
                      <td>{String(notification.article_title ?? notification.doc_id)}</td>
                      <td>{String(notification.channel_type ?? "-")}</td>
                      <td>{String(notification.status ?? "-")}</td>
                      <td>{String(notification.decision_reason ?? "-")}</td>
                      <td>
                        <div class="np-grid two">
                          <form method="post" action={bffPaths.feedback}>
                            <input type="hidden" name="notificationId" value={String(notification.notification_id)} />
                            <input type="hidden" name="docId" value={String(notification.doc_id)} />
                            <input type="hidden" name="interestId" value={String(notification.interest_id ?? "")} />
                            <input type="hidden" name="feedbackValue" value="helpful" />
                            <button type="submit" class="np-button secondary">Helpful</button>
                          </form>
                          <form method="post" action={bffPaths.feedback}>
                            <input type="hidden" name="notificationId" value={String(notification.notification_id)} />
                            <input type="hidden" name="docId" value={String(notification.doc_id)} />
                            <input type="hidden" name="interestId" value={String(notification.interest_id ?? "")} />
                            <input type="hidden" name="feedbackValue" value="not_helpful" />
                            <button type="submit" class="np-button secondary">Not Helpful</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )
          ) : (
            <p class="np-subtle">Sign in anonymously to see notification history.</p>
          )}
        </section>

        <section class="np-card">
          <h2>Explainability</h2>
          <p class="np-subtle">
            Open the API explain payload for any article and inspect criterion scores, interest scores,
            LLM review logs, and notification records in one place.
          </p>
          <div>
            {articles.slice(0, 5).map((article) => (
              <a class="np-pill" href={`${runtimeConfig.publicApiBaseUrl}/articles/${String(article.doc_id)}/explain`} target="_blank">
                explain {String(article.doc_id).slice(0, 8)}
              </a>
            ))}
          </div>
        </section>
      </div>
    </main>

    <script
      is:inline
      define:vars={{
        authBootstrapPath: bffPaths.authBootstrap,
        notificationChannelsPath: bffPaths.notificationChannels,
        webPushVapidPublicKey: runtimeConfig.webPushVapidPublicKey
      }}
    >
      const bootstrapButton = document.getElementById("bootstrap-session");
      if (bootstrapButton) {
        bootstrapButton.addEventListener("click", async () => {
          const response = await fetch(authBootstrapPath, {
            method: "POST"
          });
          if (response.ok) {
            window.location.reload();
          }
        });
      }

      function urlBase64ToUint8Array(value) {
        const padding = "=".repeat((4 - (value.length % 4 || 4)) % 4);
        const base64 = (value + padding).replaceAll("-", "+").replaceAll("_", "/");
        const raw = window.atob(base64);
        return Uint8Array.from(raw, (character) => character.charCodeAt(0));
      }

      const webPushButton = document.getElementById("connect-web-push");
      const webPushStatus = document.getElementById("web-push-status");
      if (webPushButton && webPushStatus) {
        webPushButton.addEventListener("click", async () => {
          if (!webPushVapidPublicKey) {
            webPushStatus.textContent = "WEB_PUSH_VAPID_PUBLIC_KEY is missing.";
            return;
          }

          if (!("serviceWorker" in navigator) || !("PushManager" in window)) {
            webPushStatus.textContent = "This browser does not support Web Push.";
            return;
          }

          try {
            const permission = await Notification.requestPermission();
            if (permission !== "granted") {
              webPushStatus.textContent = "Notification permission was not granted.";
              return;
            }

            const registration = await navigator.serviceWorker.register("/sw.js");
            let subscription = await registration.pushManager.getSubscription();
            if (!subscription) {
              subscription = await registration.pushManager.subscribe({
                userVisibleOnly: true,
                applicationServerKey: urlBase64ToUint8Array(webPushVapidPublicKey)
              });
            }

            const body = new URLSearchParams({
              channelType: "web_push",
              subscription: JSON.stringify(subscription.toJSON())
            });
            const response = await fetch(notificationChannelsPath, {
              method: "POST",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded"
              },
              body
            });

            if (!response.ok) {
              const payload = await response.json().catch(() => ({}));
              throw new Error(payload.error || `HTTP ${response.status}`);
            }

            webPushStatus.textContent = "Web push subscription connected.";
            window.location.reload();
          } catch (error) {
            webPushStatus.textContent =
              error instanceof Error ? error.message : "Failed to register web push.";
          }
        });
      }
    </script>
  </body>
</html>
