---
import { DEFAULT_BRAND_CONFIG, readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import Shell from "../layouts/Shell.astro";
import { ArticleCard } from "../components/ArticleCard";
import { queryOne } from "../lib/server/db";
import { resolveWebSession } from "../lib/server/auth";
import { readFlash } from "../lib/server/browser-flow";

export const prerender = false;
const session = await resolveWebSession(Astro.request);
const flash = readFlash(Astro.url);
const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4321/" });
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });

const pageBaseUrl = new URL(Astro.url);
if (!pageBaseUrl.pathname.endsWith("/")) pageBaseUrl.pathname += "/";
function resolvePageAppPath(t: string) {
  return new URL(t.replace(/^\/+/, ""), pageBaseUrl).pathname;
}

const bffPaths = {
  authBootstrap: resolvePageAppPath("bff/auth/bootstrap"),
  authLogout: resolvePageAppPath("bff/auth/logout"),
  preferences: resolvePageAppPath("bff/preferences"),
  reactions: resolvePageAppPath("bff/reactions"),
};

type ViewRow = Record<string, unknown>;
const articles = await sdk.listArticles<ViewRow[]>();
const profile = session ? await queryOne<ViewRow>(`select theme_preference from user_profiles where user_id = $1`, [session.userId]) : null;
const themePreference = String(profile?.theme_preference ?? "system");
const themeClass = themePreference === "dark" ? "dark" : "";
---

<Shell
  title={`${DEFAULT_BRAND_CONFIG.productName} — Feed`}
  session={session}
  themeClass={themeClass}
  currentTheme={themePreference}
  flash={flash}
  activeNav="feed"
  bffPreferencesPath={bffPaths.preferences}
  bffLogoutPath={bffPaths.authLogout}
  bffBootstrapPath={bffPaths.authBootstrap}
>
  <!-- Page header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">{DEFAULT_BRAND_CONFIG.productName}</h1>
    <p class="text-muted-foreground mt-1">{DEFAULT_BRAND_CONFIG.tagline}</p>
  </div>

  <!-- Articles grid -->
  {(articles as ViewRow[]).length === 0 ? (
    <div class="flex flex-col items-center justify-center py-24 text-center">
      <div class="h-16 w-16 rounded-full bg-muted flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground">
          <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/>
        </svg>
      </div>
      <p class="font-semibold text-lg">No articles yet</p>
      <p class="text-muted-foreground text-sm mt-1">Articles will appear here once the fetchers run</p>
    </div>
  ) : (
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {(articles as ViewRow[]).map((article) => (
        <ArticleCard
          article={article as any}
          isLoggedIn={!!session}
          reactionsPath={bffPaths.reactions}
          publicApiBaseUrl={runtimeConfig.publicApiBaseUrl}
          client:visible
        />
      ))}
    </div>
  )}
</Shell>
