---
import { readRuntimeConfig } from "@newsportal/config";
import Shell from "../layouts/Shell.astro";
import { LiveSettingsSection } from "../components/LiveSettingsSection";
import { getPool, queryOne, queryRows } from "../lib/server/db";
import { resolveWebSession } from "../lib/server/auth";
import { readFlash } from "../lib/server/browser-flow";
import { loadDigestSettings } from "../lib/server/digest-settings";

export const prerender = false;
const session = await resolveWebSession(Astro.request);

if (!session) {
  return Astro.redirect("/");
}

const flash = readFlash(Astro.url);
const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4321/" });

const pageBaseUrl = new URL(Astro.url);
if (!pageBaseUrl.pathname.endsWith("/")) pageBaseUrl.pathname += "/";
function resolvePageAppPath(t: string) {
  return new URL(t.replace(/^\/+/, ""), pageBaseUrl).pathname;
}

const bffPaths = {
  authBootstrap: resolvePageAppPath("../bff/auth/bootstrap"),
  authLogout: resolvePageAppPath("../bff/auth/logout"),
  liveUpdates: resolvePageAppPath("../bff/live-updates"),
  preferences: resolvePageAppPath("../bff/preferences"),
  notificationChannels: resolvePageAppPath("../bff/notification-channels"),
  digestSettings: resolvePageAppPath("../bff/digest-settings"),
};

type ViewRow = Record<string, unknown>;
const requestedPage = Number.parseInt(Astro.url.searchParams.get("page") ?? "1", 10);
const page = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;
const [profile, configuredChannels, digestSettings] = await Promise.all([
  queryOne<ViewRow>(`select theme_preference, notification_preferences from user_profiles where user_id = $1`, [session.userId]),
  queryRows<ViewRow>(`
    select unc.*, last_d.status as last_status, last_d.sent_at as last_sent_at
    from user_notification_channels unc
    left join lateral (
      select delivery.status, delivery.sent_at
      from (
        select nl.status, nl.sent_at, nl.created_at
        from notification_log nl
        where unc.channel_type <> 'email_digest'
          and nl.user_id = unc.user_id
          and nl.channel_type = unc.channel_type
        union all
        select ddl.status, ddl.sent_at, ddl.requested_at as created_at
        from digest_delivery_log ddl
        where unc.channel_type = 'email_digest'
          and ddl.user_id = unc.user_id
      ) delivery
      order by delivery.sent_at desc nulls last, delivery.created_at desc
      limit 1
    ) last_d on true
    where unc.user_id = $1
    order by unc.channel_type, unc.created_at desc
  `, [session.userId]),
  loadDigestSettings(getPool(), session.userId),
]);

const themePreference = String(profile?.theme_preference ?? "system");
const themeClass = themePreference === "dark" ? "dark" : "";
const notificationPreferences = (profile?.notification_preferences as Record<string, unknown>) ?? {};
const prefState = {
  webPush: notificationPreferences.web_push !== false,
  telegram: notificationPreferences.telegram !== false,
};
const webPushKey = runtimeConfig.webPushVapidPublicKey;
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;
---

<Shell
  title="Settings — NewsPortal"
  session={session}
  themeClass={themeClass}
  currentTheme={themePreference}
  flash={flash}
  activeNav="settings"
  bffLiveUpdatesPath={bffPaths.liveUpdates}
  bffPreferencesPath={bffPaths.preferences}
  bffLogoutPath={bffPaths.authLogout}
  bffBootstrapPath={bffPaths.authBootstrap}
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">Settings</h1>
    <p class="text-muted-foreground mt-1">Manage your preferences and notification channels</p>
  </div>

  <LiveSettingsSection
    initialThemePreference={themePreference}
    initialNotificationPreferences={prefState}
    initialChannels={configuredChannels as any[]}
    initialPage={page}
    pageSize={20}
    currentPath={currentPath}
    notificationChannelsPath={bffPaths.notificationChannels}
    preferencesPath={bffPaths.preferences}
    digestSettingsPath={bffPaths.digestSettings}
    initialDigestSettings={digestSettings}
    sessionEmail={session.identity.email ?? ""}
    vapidKey={webPushKey}
    client:load
  />
</Shell>
