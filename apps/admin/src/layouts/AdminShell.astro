---
import "../styles/globals.css";
import { DEFAULT_BRAND_CONFIG } from "@newsportal/config";
import { AdminLiveUpdateCoordinator } from "../components/AdminLiveUpdateCoordinator";
import { AdminFlashToast } from "../components/AdminFlashToast";
import AdminDesktopSidebarNav from "../components/AdminDesktopSidebarNav";
import { AdminThemeToggle } from "../components/AdminThemeToggle";
import { ADMIN_SIDEBAR_STORAGE_KEY } from "../components/admin-layout";
import { ADMIN_THEME_STORAGE_KEY } from "../components/admin-theme";
import { ADMIN_NAV_SECTIONS, findAdminNavSection } from "../lib/admin-ia";
import { resolveAdminAppPath } from "../lib/server/browser-flow";
import type { AdminLiveUpdateSurface } from "../lib/live-updates";

export interface Props {
  title?: string;
  session?: { userId: string; roles: string[] } | null;
  flash?: { status: "success" | "error"; message: string } | null;
  activeNav?: string;
  liveUpdatesEndpoint?: string | null;
  liveUpdatesSurface?: AdminLiveUpdateSurface | null;
}

const {
  title = `${DEFAULT_BRAND_CONFIG.productName} Admin`,
  session,
  flash,
  activeNav,
  liveUpdatesEndpoint = null,
  liveUpdatesSurface = null,
} = Astro.props;

const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
const activeSection = findAdminNavSection(activeNav ?? null);

// Lucide-like SVG icons as inline strings
const icons: Record<string, string> = {
  grid: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>`,
  newspaper: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>`,
  layers: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>`,
  rss: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>`,
  compass: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
  "file-text": `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>`,
  bookmark: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>`,
  users: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  workflow: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><path d="M9 6h4a2 2 0 0 1 2 2v7"/><path d="M15 18h-4a2 2 0 0 1-2-2V9"/></svg>`,
  "refresh-cw": `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>`,
  activity: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/></svg>`,
  database: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`,
  "help-circle": `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>`,
};
const desktopNavSections = ADMIN_NAV_SECTIONS.map((group) => ({
  label: group.label,
  isActive: activeSection?.label === group.label,
  items: group.items.map(({ href, label, icon, key }) => ({
    href: appPath(href),
    label,
    key,
    iconSvg: icons[icon],
    isActive: activeNav === key,
  })),
}));
---

<style is:global>
  .admin-table th,
  .admin-table td {
    vertical-align: top;
  }

  .admin-table-cell-stack {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.5rem;
  }

  .admin-table-meta {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.25rem;
  }

  .admin-table-chip-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .admin-table-actions-col {
    width: 12rem;
  }

  .admin-table-actions {
    display: flex;
    min-width: 8.75rem;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    html[data-admin-sidebar="compact"] [data-admin-sidebar] {
      width: 4.75rem;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-brand-text],
    html[data-admin-sidebar="compact"] [data-admin-sidebar-section-label],
    html[data-admin-sidebar="compact"] [data-admin-sidebar-link-label],
    html[data-admin-sidebar="compact"] [data-admin-sidebar-user-meta],
    html[data-admin-sidebar="compact"] [data-admin-sidebar-signout-label] {
      display: none;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-nav] {
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-link] {
      justify-content: center;
      padding-left: 0;
      padding-right: 0;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-user-card] {
      justify-content: center;
      padding-left: 0.25rem;
      padding-right: 0.25rem;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-signout] {
      justify-content: center;
      padding-left: 0.25rem;
      padding-right: 0.25rem;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-footer] {
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-expanded-footer] {
      display: none;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-compact-footer] {
      display: flex;
    }

    html[data-admin-sidebar="compact"] [data-admin-sidebar-active-section="true"] [data-admin-sidebar-section-marker] {
      opacity: 1;
    }
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script
      is:inline
      define:vars={{
        adminThemeStorageKey: ADMIN_THEME_STORAGE_KEY,
        adminSidebarStorageKey: ADMIN_SIDEBAR_STORAGE_KEY,
      }}
    >
      (() => {
        const root = document.documentElement;
        const themeStorageKey = adminThemeStorageKey;
        const sidebarStorageKey = adminSidebarStorageKey;
        const isThemeMode = (value) =>
          value === "light" || value === "dark" || value === "system";
        const isSidebarMode = (value) => value === "expanded" || value === "compact";
        const preference = (() => {
          try {
            const stored = window.localStorage.getItem(themeStorageKey);
            return isThemeMode(stored) ? stored : "system";
          } catch {
            return "system";
          }
        })();
        const sidebarMode = (() => {
          try {
            const stored = window.localStorage.getItem(sidebarStorageKey);
            return isSidebarMode(stored) ? stored : "expanded";
          } catch {
            return "expanded";
          }
        })();
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const effectiveTheme =
          preference === "dark" ? "dark" : preference === "light" ? "light" : prefersDark ? "dark" : "light";
        root.dataset.themePreference = preference;
        root.dataset.theme = effectiveTheme;
        root.dataset.adminSidebar = sidebarMode;
        root.classList.toggle("dark", effectiveTheme === "dark");
        root.style.colorScheme = effectiveTheme;
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="relative isolate min-h-screen overflow-hidden">
      <div class="admin-shell-backdrop pointer-events-none absolute inset-0"></div>
      <div class="admin-shell-grid pointer-events-none absolute inset-0 opacity-40 dark:opacity-30"></div>
      <div class="relative z-10 flex h-screen overflow-hidden">

      <!-- Sidebar -->
      <aside
        id="sidebar"
        data-admin-sidebar
        class="hidden md:flex flex-col w-56 shrink-0 border-r border-border bg-card/88 backdrop-blur overflow-y-auto transition-[width] duration-200"
      >
        <!-- Logo -->
        <div class="flex h-14 items-center gap-2.5 px-4 border-b border-border shrink-0">
          <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-primary text-primary-foreground text-sm font-bold">N</span>
          <div data-admin-sidebar-brand-text>
            <p class="text-sm font-semibold leading-none">{DEFAULT_BRAND_CONFIG.productName}</p>
            <p class="text-[10px] text-muted-foreground">Admin Console</p>
          </div>
        </div>

        <AdminDesktopSidebarNav
          sections={desktopNavSections}
          session={session ? { userId: session.userId, roles: session.roles } : null}
          logoutAction={appPath("/bff/auth/logout")}
          client:load
        />
      </aside>

      <!-- Main content -->
      <div class="flex flex-col flex-1 overflow-hidden">
        <!-- Top bar -->
        <header class="flex h-14 shrink-0 items-center gap-3 border-b border-border bg-card/88 px-4 backdrop-blur md:px-6">
          <!-- Mobile menu button -->
          <button
            type="button"
            id="mobile-sidebar-btn"
            class="md:hidden inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground hover:bg-accent transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          </button>

          <div class="flex min-w-0 flex-1 flex-col gap-0.5">
            {activeSection ? (
              <p class="truncate text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">{activeSection.label}</p>
            ) : null}
            <div class="min-w-0">
              <slot name="header-title" />
            </div>
          </div>

          <!-- Header actions -->
          <div class="flex items-center gap-2">
            <button
              type="button"
              id="admin-sidebar-toggle"
              class="hidden md:inline-flex h-9 items-center justify-center rounded-md border border-input px-3 text-sm font-medium transition-colors hover:bg-accent"
              aria-label="Toggle compact sidebar"
              title="Toggle compact sidebar"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                <path d="M9 4v16"></path>
              </svg>
              <span class="ml-2 hidden lg:inline" id="admin-sidebar-toggle-label">Compact nav</span>
            </button>
            <AdminThemeToggle client:load />
            <slot name="header-actions" />
          </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 overflow-y-auto">
          <AdminFlashToast flash={flash} client:load />
          {session && liveUpdatesEndpoint && liveUpdatesSurface && (
            <AdminLiveUpdateCoordinator
              endpoint={liveUpdatesEndpoint}
              activeSurface={liveUpdatesSurface}
              client:load
            />
          )}
          <div class="p-4 md:p-6">
            <slot />
          </div>
        </main>
      </div>
    </div>

    <!-- Mobile sidebar overlay -->
    <div id="mobile-sidebar-overlay" class="hidden fixed inset-0 z-50 bg-black/50 md:hidden">
      <aside class="flex flex-col w-64 h-full bg-card/92 border-r border-border backdrop-blur overflow-y-auto">
        <div class="flex h-14 items-center justify-between gap-2.5 px-4 border-b border-border shrink-0">
          <div class="flex items-center gap-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-primary text-primary-foreground text-sm font-bold">N</span>
            <p class="text-sm font-semibold">{DEFAULT_BRAND_CONFIG.productName} Admin</p>
          </div>
          <button type="button" id="close-mobile-sidebar" class="text-muted-foreground hover:text-foreground">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <nav class="flex-1 px-2 py-3 space-y-4">
          {ADMIN_NAV_SECTIONS.map((group) => (
            <div>
              <p class="px-2 mb-1 text-[10px] font-semibold uppercase tracking-widest text-muted-foreground">{group.label}</p>
              {group.items.map(({ href, label, icon, key }) => (
                <a href={appPath(href)} class={`flex items-center gap-2.5 rounded-md px-2 py-2 text-sm font-medium transition-colors ${
                  activeNav === key ? "bg-primary/15 text-primary" : "text-muted-foreground hover:text-foreground hover:bg-accent"
                }`}>
                  <span class="shrink-0" set:html={icons[icon]} />
                  {label}
                </a>
              ))}
            </div>
          ))}
        </nav>
      </aside>
      </div>
    </div>

    <script>
      const btn = document.getElementById("mobile-sidebar-btn");
      const overlay = document.getElementById("mobile-sidebar-overlay");
      const closeBtn = document.getElementById("close-mobile-sidebar");
      const sidebarToggle = document.getElementById("admin-sidebar-toggle");
      const sidebarToggleLabel = document.getElementById("admin-sidebar-toggle-label");
      const sidebarStorageKey = "newsportal-admin-sidebar";
      const root = document.documentElement;

      const applySidebarMode = (mode: "expanded" | "compact") => {
        root.dataset.adminSidebar = mode;
        sidebarToggle?.setAttribute("aria-pressed", String(mode === "compact"));
        sidebarToggle?.setAttribute(
          "aria-label",
          mode === "compact" ? "Expand sidebar" : "Compact sidebar"
        );
        sidebarToggle?.setAttribute(
          "title",
          mode === "compact" ? "Expand sidebar" : "Compact sidebar"
        );
        if (sidebarToggleLabel) {
          sidebarToggleLabel.textContent =
            mode === "compact" ? "Expand nav" : "Compact nav";
        }
      };

      applySidebarMode(root.dataset.adminSidebar === "compact" ? "compact" : "expanded");

      sidebarToggle?.addEventListener("click", () => {
        const nextMode = root.dataset.adminSidebar === "compact" ? "expanded" : "compact";
        applySidebarMode(nextMode);
        try {
          window.localStorage.setItem(sidebarStorageKey, nextMode);
        } catch {
          return;
        }
      });

      btn?.addEventListener("click", () => overlay?.classList.remove("hidden"));
      closeBtn?.addEventListener("click", () => overlay?.classList.add("hidden"));
      overlay?.addEventListener("click", (e) => {
        if (e.target === overlay) overlay.classList.add("hidden");
      });
    </script>
  </body>
</html>
