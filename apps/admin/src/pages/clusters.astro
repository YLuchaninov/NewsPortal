---
import { DEFAULT_PAGE } from "@newsportal/contracts";
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { PaginationNav } from "@newsportal/ui";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../lib/server/browser-flow";

export const prerender = false;
const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });
const pagePaths = { dashboard: appPath("/") };
const CLUSTERS_PAGE_SIZE = 12;
type R = Record<string, unknown>;
const requestedPage = Number.parseInt(Astro.url.searchParams.get("page") ?? String(DEFAULT_PAGE), 10);
const page = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : DEFAULT_PAGE;
const clusters = await sdk.listClustersPage<R>({ page, pageSize: CLUSTERS_PAGE_SIZE });
const selectedClusterId = String(Astro.url.searchParams.get("selected") ?? "").trim();
const selectedCluster =
  clusters.items.find((cluster) => String(cluster.cluster_id ?? "") === selectedClusterId) ??
  clusters.items[0] ??
  null;

function resolvePageHref(nextPage: number): string {
  const target = new URL(Astro.url);
  target.searchParams.delete("selected");
  if (nextPage <= DEFAULT_PAGE) {
    target.searchParams.delete("page");
  } else {
    target.searchParams.set("page", String(nextPage));
  }
  return `${target.pathname}${target.search}`;
}

function resolvePreviewHref(clusterId: string): string {
  const target = new URL(Astro.url);
  target.searchParams.set("selected", clusterId);
  return `${target.pathname}${target.search}`;
}

function formatTimestamp(value: unknown): string {
  if (!value) {
    return "—";
  }
  const date = new Date(String(value));
  if (Number.isNaN(date.getTime())) {
    return String(value);
  }
  return date.toLocaleString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit",
  });
}

function asStringList(value: unknown): string[] {
  return Array.isArray(value)
    ? (value as unknown[]).map((entry) => String(entry ?? "").trim()).filter(Boolean)
    : [];
}
---

<AdminShell title="Clusters — Admin" session={session} flash={flash} activeNav="clusters">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={pagePaths.dashboard} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">Clusters</span>
    </nav>
  </Fragment>

  <div class="space-y-5">
    <section class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Operations</p>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight">Event Clusters</h1>
      <p class="mt-2 text-sm leading-6 text-muted-foreground">
        Review cluster density, geography, and verification posture from one table, then inspect one cluster at a time in the side preview before deciding to open deeper article detail.
      </p>
      <p class="mt-3 text-sm text-muted-foreground">
        {clusters.total} cluster{clusters.total !== 1 ? "s" : ""} total
        {clusters.total > 0 && ` — page ${clusters.page} of ${Math.max(clusters.totalPages, 1)}`}
      </p>
    </section>

    <div class="grid gap-4 xl:grid-cols-[minmax(0,1.45fr)_minmax(20rem,0.85fr)]">
      <section class="overflow-hidden rounded-xl border border-border bg-card">
        {clusters.total === 0 ? (
          <div class="flex flex-col items-center justify-center py-16 text-center">
            <p class="font-medium text-sm">No clusters yet</p>
            <p class="text-xs text-muted-foreground mt-1">Clusters appear automatically as articles are processed.</p>
          </div>
        ) : clusters.items.length === 0 ? (
          <div class="flex flex-col items-center justify-center py-16 text-center">
            <p class="font-medium text-sm">No clusters on this page</p>
            <p class="text-xs text-muted-foreground mt-1">Try another page to return to cluster rows.</p>
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full min-w-[760px] text-sm">
              <thead>
                <tr class="border-b border-border">
                  <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Cluster</th>
                  <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Coverage</th>
                  <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Signals</th>
                  <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Open</th>
                </tr>
              </thead>
              <tbody>
                {clusters.items.map((cluster) => {
                  const clusterId = String(cluster.cluster_id ?? "");
                  const topPlaces = asStringList(cluster.top_places);
                  const isSelected = selectedCluster
                    ? String(selectedCluster.cluster_id ?? "") === clusterId
                    : false;
                  return (
                    <tr class:list={[
                      "border-b border-border last:border-0 transition-colors",
                      isSelected ? "bg-primary/5" : "hover:bg-muted/30",
                    ]}>
                      <td class="px-4 py-3">
                        <a
                          href={resolvePreviewHref(clusterId)}
                          class:list={[
                            "font-medium text-sm transition-colors",
                            isSelected ? "text-primary" : "hover:text-primary",
                          ]}
                        >
                          {String(cluster.primary_title ?? cluster.cluster_id ?? "Unnamed cluster")}
                        </a>
                        <p class="mt-1 text-[11px] text-muted-foreground">cluster:{clusterId ? clusterId.slice(0, 8) : "—"}</p>
                      </td>
                      <td class="px-4 py-3 text-xs text-muted-foreground">
                        <p>{String(cluster.article_count ?? 0)} article{Number(cluster.article_count ?? 0) === 1 ? "" : "s"}</p>
                        <p class="mt-1">Updated {formatTimestamp(cluster.updated_at ?? cluster.created_at)}</p>
                      </td>
                      <td class="px-4 py-3 text-xs text-muted-foreground">
                        {topPlaces.length > 0 ? (
                          <div class="flex flex-wrap gap-1.5">
                            {topPlaces.slice(0, 3).map((place) => (
                              <span class="inline-flex items-center rounded-full bg-sky-100 px-2 py-0.5 font-medium text-sky-800 dark:bg-sky-900/30 dark:text-sky-300">
                                {place}
                              </span>
                            ))}
                          </div>
                        ) : (
                          <span>No top places yet</span>
                        )}
                      </td>
                      <td class="px-4 py-3">
                        <a
                          href={resolvePreviewHref(clusterId)}
                          class="inline-flex h-8 items-center justify-center rounded-md border border-input px-3 text-xs font-medium transition-colors hover:bg-accent"
                        >
                          Preview
                        </a>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </section>

      <aside class="rounded-xl border border-border bg-card p-5 shadow-sm xl:sticky xl:top-6 xl:self-start">
        {selectedCluster ? (
          (() => {
            const topPlaces = asStringList(selectedCluster.top_places);
            return (
              <div class="space-y-5">
                <div>
                  <p class="text-xs font-medium uppercase tracking-[0.16em] text-primary/80">Preview</p>
                  <h2 class="mt-2 text-lg font-semibold leading-tight">
                    {String(selectedCluster.primary_title ?? selectedCluster.cluster_id ?? "Unnamed cluster")}
                  </h2>
                  <p class="mt-2 text-sm text-muted-foreground">
                    Clusters group multiple article observations into one event-level operator surface so moderation and notification reasoning do not fragment across duplicates.
                  </p>
                </div>

                <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                  <div class="rounded-2xl border border-border bg-background p-4">
                    <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Volume</p>
                    <p class="mt-2 text-sm font-semibold">
                      {String(selectedCluster.article_count ?? 0)} article{Number(selectedCluster.article_count ?? 0) === 1 ? "" : "s"}
                    </p>
                    <p class="mt-1 text-xs text-muted-foreground">cluster:{String(selectedCluster.cluster_id ?? "").slice(0, 8) || "—"}</p>
                  </div>
                  <div class="rounded-2xl border border-border bg-background p-4">
                    <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Timestamps</p>
                    <p class="mt-2 text-sm font-semibold">Updated {formatTimestamp(selectedCluster.updated_at ?? selectedCluster.created_at)}</p>
                    <p class="mt-1 text-xs text-muted-foreground">Created {formatTimestamp(selectedCluster.created_at)}</p>
                  </div>
                </div>

                <div class="rounded-2xl border border-border bg-background p-4">
                  <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Top places</p>
                  {topPlaces.length > 0 ? (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {topPlaces.map((place) => (
                        <span class="inline-flex items-center rounded-full bg-sky-100 px-2.5 py-1 text-xs font-medium text-sky-800 dark:bg-sky-900/30 dark:text-sky-300">
                          {place}
                        </span>
                      ))}
                    </div>
                  ) : (
                    <p class="mt-2 text-sm text-muted-foreground">This cluster has not accumulated clear geography hints yet.</p>
                  )}
                </div>

                <div class="rounded-2xl border border-border bg-background p-4">
                  <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Why clusters matter</p>
                  <p class="mt-2 text-sm font-semibold text-foreground">What are event clusters?</p>
                  <p class="mt-2 text-sm text-foreground">
                    One cluster represents one event-level storyline. Operators can use it to reason about duplicate suppression, verification spread, and follow-up density instead of reviewing each observation in isolation.
                  </p>
                </div>
              </div>
            );
          })()
        ) : (
          <div class="py-8 text-center">
            <p class="text-sm font-medium">No cluster selected</p>
            <p class="mt-2 text-sm text-muted-foreground">Pick a cluster row to inspect its event-level summary.</p>
          </div>
        )}
      </aside>
    </div>
    {(clusters.hasPrev || clusters.hasNext) && (
      <PaginationNav
        page={clusters.page}
        totalPages={clusters.totalPages}
        hasPrev={clusters.hasPrev}
        hasNext={clusters.hasNext}
        prevHref={resolvePageHref(clusters.page - 1)}
        nextHref={resolvePageHref(clusters.page + 1)}
      />
    )}
  </div>
</AdminShell>
