---
import { resolveAdminAppPath } from "../../../lib/server/browser-flow";

export const prerender = false;

const missionId = String(Astro.params.missionId ?? "").trim();
const target = resolveAdminAppPath(
  Astro.request,
  `/discovery?tab=portfolio&portfolioMissionId=${encodeURIComponent(missionId)}`
);
return Astro.redirect(target);
---
