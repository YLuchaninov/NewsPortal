---
import { DEFAULT_PAGE } from "@newsportal/contracts";
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { PaginationNav } from "@newsportal/ui";
import { AdminConfirmAction } from "../../components/AdminConfirmAction";
import AdminShell from "../../layouts/AdminShell.astro";
import { resolveAdminSession } from "../../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../../lib/server/browser-flow";

export const prerender = false;

const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });
const TEMPLATE_PAGE_SIZE = 8;
type R = Record<string, unknown>;

function parsePage(paramName: string): number {
  const requestedPage = Number.parseInt(Astro.url.searchParams.get(paramName) ?? String(DEFAULT_PAGE), 10);
  return Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : DEFAULT_PAGE;
}

const page = parsePage("page");
const templates = await sdk.listSystemInterestsPage<R>({ page, pageSize: TEMPLATE_PAGE_SIZE });
const currentListPath = `${Astro.url.pathname}${Astro.url.search}`;
const activeCount = templates.items.filter((item) => item.is_active === true).length;

function resolveListHref(nextPage: number): string {
  const target = new URL(Astro.url);
  if (nextPage <= DEFAULT_PAGE) {
    target.searchParams.delete("page");
  } else {
    target.searchParams.set("page", String(nextPage));
  }
  return `${target.pathname}${target.search}`;
}

function asPolicyRecord(value: unknown): Record<string, unknown> {
  return value && typeof value === "object" && !Array.isArray(value)
    ? (value as Record<string, unknown>)
    : {};
}

function resolveLlmReviewMode(
  profileFamily: unknown,
  selectionProfilePolicy: Record<string, unknown>
): string {
  const configured = String(selectionProfilePolicy.llmReviewMode ?? "").trim();
  if (configured) {
    return configured === "optional_high_value_only"
      && String(profileFamily ?? "") === "compatibility_interest_template"
      ? "always"
      : configured;
  }
  return String(profileFamily ?? "") === "compatibility_interest_template"
    ? "always"
    : "optional_high_value_only";
}
---

<AdminShell title="System Interests — Admin" session={session} flash={flash} activeNav="interest-templates">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={appPath("/")} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">System Interests</span>
    </nav>
  </Fragment>

  <Fragment slot="header-actions">
    <a href={appPath("/user-interests")} class="inline-flex h-9 items-center justify-center rounded-md border border-input px-3 text-sm font-medium transition-colors hover:bg-accent">
      User interests
    </a>
    <a href={appPath("/templates/llm")} class="inline-flex h-9 items-center justify-center rounded-md border border-input px-3 text-sm font-medium transition-colors hover:bg-accent">
      LLM templates
    </a>
    <a href={appPath("/templates/interests/new")} class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
      New system interest
    </a>
  </Fragment>

  <div class="space-y-6">
    <div class="flex flex-col gap-4 rounded-[1.75rem] border border-border bg-card p-6 shadow-sm lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Global selection</p>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">System interests</h1>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">
          These system interests define the reusable prototypes, hard constraints, time windows, and content-kind gates that shape the global system-selected collection. Active entries sync their matching constraints into the live criterion set used by fresh ingest and historical reindex, while allowed content kinds remain template-owned gates for which resource kinds may appear in the collection.
          Editing one specific user's real `user_interests` happens on the separate <a href={appPath("/user-interests")} class="text-primary hover:underline">User Interests</a> page.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Total</p>
          <p class="mt-1 text-2xl font-semibold">{templates.total}</p>
        </div>
        <div class="rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Active</p>
          <p class="mt-1 text-2xl font-semibold text-emerald-500">{activeCount}</p>
        </div>
        <div class="rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Page</p>
          <p class="mt-1 text-2xl font-semibold">{templates.page}</p>
        </div>
      </div>
    </div>

    <section class="overflow-hidden rounded-2xl border border-border bg-card shadow-sm">
      <div class="border-b border-border px-5 py-4">
        <h2 class="text-base font-semibold">System interest catalog</h2>
        <p class="mt-1 text-sm text-muted-foreground">
          {templates.total} system interest{templates.total !== 1 ? "s" : ""} total
          {templates.total > 0 && ` — page ${templates.page} of ${Math.max(templates.totalPages, 1)}`}
        </p>
      </div>

      {templates.total === 0 ? (
        <div class="px-6 py-14 text-center">
          <p class="text-base font-medium">No system interests yet</p>
          <p class="mt-2 text-sm text-muted-foreground">Create the first system interest so the platform can start selecting content globally.</p>
          <a href={appPath("/templates/interests/new")} class="mt-5 inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
            Create system interest
          </a>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full min-w-[920px] text-sm">
            <thead>
              <tr class="border-b border-border bg-muted/30">
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">System interest</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Coverage</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Content kinds</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Priority</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Status</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Actions</th>
              </tr>
            </thead>
            <tbody>
              {templates.items.length === 0 ? (
                <tr>
                  <td colspan="6" class="px-5 py-10 text-center text-sm text-muted-foreground">No system interests on this page</td>
                </tr>
              ) : templates.items.map((template) => {
                const interestTemplateId = String(template.interest_template_id ?? "");
                const isActive = template.is_active === true;
                const positiveCount = Array.isArray(template.positive_texts) ? (template.positive_texts as unknown[]).length : 0;
                const negativeCount = Array.isArray(template.negative_texts) ? (template.negative_texts as unknown[]).length : 0;
                const allowedKinds = Array.isArray(template.allowed_content_kinds)
                  ? (template.allowed_content_kinds as unknown[]).map((entry) => String(entry ?? "")).filter(Boolean)
                  : [];
                const selectionProfilePolicy = asPolicyRecord(template.selection_profile_policy_json);
                const profileFamily = String(template.selection_profile_family ?? "");
                const unresolvedDecision = String(selectionProfilePolicy.unresolvedDecision ?? "hold");
                const llmReviewMode = resolveLlmReviewMode(profileFamily, selectionProfilePolicy);
                const profileStatus = String(template.selection_profile_status ?? (isActive ? "active" : "archived"));
                return (
                  <tr class="border-b border-border last:border-b-0">
                    <td class="px-5 py-4 align-top">
                      <p class="text-sm font-semibold">{String(template.name ?? "Unnamed system interest")}</p>
                      <p class="mt-1 max-w-lg line-clamp-2 text-sm text-muted-foreground">{String(template.description ?? "No description yet.")}</p>
                    </td>
                    <td class="px-5 py-4 align-top">
                      <div class="flex flex-wrap gap-2">
                        <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-medium text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300">
                          {positiveCount} positive
                        </span>
                        <span class="inline-flex items-center rounded-full bg-rose-100 px-2.5 py-1 text-[11px] font-medium text-rose-800 dark:bg-rose-900/30 dark:text-rose-300">
                          {negativeCount} negative
                        </span>
                      </div>
                    </td>
                    <td class="px-5 py-4 align-top">
                      <div class="flex max-w-xs flex-wrap gap-2">
                        {(allowedKinds.length > 0 ? allowedKinds : ["editorial", "listing", "entity", "document", "data_file", "api_payload"]).map((kind) => (
                          <span class="inline-flex items-center rounded-full bg-sky-100 px-2.5 py-1 text-[11px] font-medium text-sky-800 dark:bg-sky-900/30 dark:text-sky-300">
                            {kind}
                          </span>
                        ))}
                      </div>
                    </td>
                    <td class="px-5 py-4 align-top text-sm text-muted-foreground">
                      <p>{String(template.priority ?? 1)}</p>
                      <p class="mt-1 text-xs">
                        {String(selectionProfilePolicy.strictness ?? "balanced")} · {unresolvedDecision}
                      </p>
                    </td>
                    <td class="px-5 py-4 align-top">
                      <div class="flex flex-wrap gap-2">
                        <span class:list={[
                          "inline-flex items-center rounded-full px-2.5 py-1 text-[11px] font-medium",
                          isActive
                            ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300"
                            : "bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-200",
                        ]}>
                          {isActive ? "Active" : "Archived"}
                        </span>
                        <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-1 text-[11px] font-medium text-amber-800 dark:bg-amber-900/30 dark:text-amber-300">
                          unresolved:{unresolvedDecision}
                        </span>
                      </div>
                      <p class="mt-2 text-xs text-muted-foreground">
                        {profileStatus} · llm:{llmReviewMode}
                      </p>
                    </td>
                    <td class="px-5 py-4 align-top">
                      <div class="flex flex-wrap gap-2">
                        <a href={appPath(`/templates/interests/${interestTemplateId}/edit`)} class="inline-flex h-8 items-center justify-center rounded-md border border-input px-3 text-xs font-medium transition-colors hover:bg-accent">
                          Edit
                        </a>
                        <AdminConfirmAction
                          action={appPath("/bff/admin/templates")}
                          title={isActive ? "Archive system interest" : "Reactivate system interest"}
                          description={isActive
                            ? "Archived system interests stay visible to operators but disappear from the active catalog until you reactivate them."
                            : "Reactivating this system interest makes it available again for operators and downstream content selection."}
                          triggerLabel={isActive ? "Archive" : "Activate"}
                          confirmLabel={isActive ? "Archive system interest" : "Activate system interest"}
                          fields={[
                            { name: "kind", value: "interest" },
                            { name: "intent", value: isActive ? "archive" : "activate" },
                            { name: "interestTemplateId", value: interestTemplateId },
                            { name: "redirectTo", value: currentListPath },
                          ]}
                          triggerClassName={isActive ? "border-amber-200 text-amber-700 hover:bg-amber-50 dark:border-amber-900/30 dark:text-amber-300 dark:hover:bg-amber-950/20" : "border-emerald-200 text-emerald-700 hover:bg-emerald-50 dark:border-emerald-900/30 dark:text-emerald-300 dark:hover:bg-emerald-950/20"}
                          confirmClassName={isActive ? "bg-amber-600 text-white hover:bg-amber-600/90" : "bg-emerald-600 text-white hover:bg-emerald-600/90"}
                          client:load
                        />
                        <AdminConfirmAction
                          action={appPath("/bff/admin/templates")}
                          title="Delete system interest"
                          description="Delete permanently only when this global selection rule should no longer exist in the admin library at all."
                          triggerLabel="Delete"
                          confirmLabel="Delete system interest"
                          fields={[
                            { name: "kind", value: "interest" },
                            { name: "intent", value: "delete" },
                            { name: "interestTemplateId", value: interestTemplateId },
                            { name: "redirectTo", value: currentListPath },
                          ]}
                          triggerClassName="border-rose-200 text-rose-700 hover:bg-rose-50 dark:border-rose-900/30 dark:text-rose-300 dark:hover:bg-rose-950/20"
                          client:load
                        />
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </section>

    {(templates.hasPrev || templates.hasNext) && (
      <PaginationNav
        page={templates.page}
        totalPages={templates.totalPages}
        hasPrev={templates.hasPrev}
        hasNext={templates.hasNext}
        prevHref={resolveListHref(templates.page - 1)}
        nextHref={resolveListHref(templates.page + 1)}
      />
    )}
  </div>
</AdminShell>
