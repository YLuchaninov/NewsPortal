---
import type { WebResourceDetail } from "@newsportal/contracts";
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import AdminShell from "../../layouts/AdminShell.astro";
import { resolveAdminSession } from "../../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../../lib/server/browser-flow";

export const prerender = false;

const runtimeConfig = readRuntimeConfig(process.env, {
  defaultAppBaseUrl: "http://127.0.0.1:4322/",
});
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });
const resourceId = String(Astro.params.resourceId ?? "").trim();

if (!resourceId) {
  return new Response("Web resource not found.", { status: 404 });
}

let resource: WebResourceDetail;
try {
  resource = await sdk.getWebResource<WebResourceDetail>(resourceId);
} catch {
  return new Response("Web resource not found.", { status: 404 });
}

function resolveSafeHref(rawValue: unknown): string | null {
  if (typeof rawValue !== "string" || !rawValue.trim()) {
    return null;
  }

  try {
    const normalized = new URL(rawValue);
    if (!["http:", "https:"].includes(normalized.protocol)) {
      return null;
    }
    return normalized.toString();
  } catch {
    return null;
  }
}

function sanitizeHtml(rawValue: unknown): string | null {
  if (typeof rawValue !== "string" || !rawValue.trim()) {
    return null;
  }

  return rawValue
    .replace(/<script[\s\S]*?<\/script>/gi, "")
    .replace(/<style[\s\S]*?<\/style>/gi, "")
    .replace(/\son[a-z]+\s*=\s*(["']).*?\1/gi, "")
    .replace(/\son[a-z]+\s*=\s*[^\s>]+/gi, "")
    .replace(/(href|src)\s*=\s*(["'])javascript:[\s\S]*?\2/gi, '$1="#"');
}

function formatTimestamp(rawValue: unknown): string {
  if (!rawValue) {
    return "—";
  }
  const date = new Date(String(rawValue));
  if (Number.isNaN(date.getTime())) {
    return String(rawValue);
  }
  return date.toLocaleString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit",
  });
}

function toArray<T>(rawValue: unknown): T[] {
  return Array.isArray(rawValue) ? (rawValue as T[]) : [];
}

function toRecord(rawValue: unknown): Record<string, unknown> {
  return rawValue && typeof rawValue === "object" && !Array.isArray(rawValue)
    ? (rawValue as Record<string, unknown>)
    : {};
}

function selectionBadgeClass(modeLike: unknown): string {
  switch (String(modeLike ?? "").trim()) {
    case "selected":
      return "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300";
    case "hold":
      return "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300";
    case "llm_review_pending":
      return "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300";
    case "rejected":
      return "bg-slate-100 text-slate-800 dark:bg-slate-900/30 dark:text-slate-300";
    case "gray_zone":
      return "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300";
    case "compatibility_only":
      return "bg-sky-100 text-sky-800 dark:bg-sky-900/30 dark:text-sky-300";
    default:
      return "bg-muted text-muted-foreground";
  }
}

const sourceHref = resolveSafeHref(resource.final_url ?? resource.url);
const projectedArticleHref = resource.projected_article_id
  ? appPath(`/articles/${encodeURIComponent(String(resource.projected_article_id))}`)
  : null;
const resourceHtml = sanitizeHtml(resource.body_html ?? null);
const documents = toArray<Record<string, unknown>>(resource.documents_json);
const mediaAssets = toArray<Record<string, unknown>>(resource.media_json);
const linksOut = toArray<Record<string, unknown>>(resource.links_out_json);
const childResources = toArray<Record<string, unknown>>(resource.child_resources_json);
const discoveryPayload = toRecord(toRecord(resource.raw_payload_json).discovery);
const discoverySignals = toRecord(discoveryPayload.rawSignals);
const browserAssisted = discoverySignals.browserAssisted === true;
const browserCaptureSource = String(discoverySignals.browserCaptureSource ?? "").trim() || "—";
const browserChallengeKind = String(discoverySignals.browserChallengeKind ?? "").trim() || "—";
const browserSeedUrl = String(discoverySignals.browserSeedUrl ?? "").trim() || "—";
const browserPageUrl = String(discoverySignals.browserPageUrl ?? "").trim() || "—";
const selectionGuidance = toRecord(resource.selection_guidance);
const selectionDiagnostics = toRecord(resource.selection_diagnostics);
const selectionMode = String(resource.selection_mode ?? "pending").trim() || "pending";
const selectionDecision = String(resource.selection_decision ?? "").trim();
const projectionState = String(resource.projection_state ?? "pending").trim() || "pending";
const projectionError = String(resource.projection_error ?? "").trim();
const selectionSummary =
  String(resource.selection_summary ?? "").trim() || "Selection not materialized yet.";
const selectionGuidanceTone = String(selectionGuidance.tone ?? "neutral").trim() || "neutral";
const selectionGuidanceSummary =
  String(selectionGuidance.summary ?? "").trim() || "Selection guidance is not available yet.";
---

<AdminShell title="Resource Detail — Admin" session={session} flash={flash} activeNav="resources">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={appPath("/")} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <a href={appPath("/resources")} class="hover:text-foreground">Resources</a>
      <span>/</span>
      <span class="text-foreground font-medium">Detail</span>
    </nav>
  </Fragment>

  <Fragment slot="header-actions">
    {projectedArticleHref && (
      <a
        href={projectedArticleHref}
        class="inline-flex h-9 items-center justify-center rounded-md border border-input px-3 text-sm font-medium transition-colors hover:bg-accent"
      >
        Open projected article
      </a>
    )}
    {sourceHref && (
      <a
        href={sourceHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        Open source
      </a>
    )}
  </Fragment>

  <div class="space-y-6">
    <div class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
      <div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
        <span class="inline-flex items-center rounded-full bg-secondary px-2.5 py-1 font-medium text-secondary-foreground">
          {String(resource.resource_kind ?? "unknown")}
        </span>
        <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 font-medium">
          {String(resource.extraction_state ?? "pending")}
        </span>
        <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 font-medium">
          {String(resource.discovery_source ?? "manual")}
        </span>
        <span class={`inline-flex items-center rounded-full px-2.5 py-1 font-medium ${selectionBadgeClass(projectionState)}`}>
          projection:{projectionState}
        </span>
        <span class={`inline-flex items-center rounded-full px-2.5 py-1 font-medium ${selectionBadgeClass(selectionMode)}`}>
          mode:{selectionMode}
        </span>
        {selectionDecision && (
          <span class={`inline-flex items-center rounded-full px-2.5 py-1 font-medium ${selectionBadgeClass(selectionDecision)}`}>
            decision:{selectionDecision}
          </span>
        )}
      </div>
      <h1 class="mt-4 text-2xl font-semibold tracking-tight">{String(resource.title ?? "Untitled resource")}</h1>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">{String(resource.summary ?? "No summary available.")}</p>
      <div
        class={`mt-4 rounded-2xl border px-4 py-3 text-sm ${
          selectionGuidanceTone === "positive"
            ? "border-emerald-200 bg-emerald-50 text-emerald-900 dark:border-emerald-900/40 dark:bg-emerald-950/20 dark:text-emerald-100"
            : selectionGuidanceTone === "warning"
              ? "border-amber-200 bg-amber-50 text-amber-900 dark:border-amber-900/40 dark:bg-amber-950/20 dark:text-amber-100"
              : "border-border bg-background text-foreground"
        }`}
      >
        <p class="font-medium">{selectionSummary}</p>
        <p class="mt-1 text-sm opacity-90">{selectionGuidanceSummary}</p>
      </div>
      <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-border bg-background p-4">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Channel</p>
          <p class="mt-2 font-medium">{String(resource.channel_name ?? "Unknown website channel")}</p>
          <p class="mt-1 text-sm text-muted-foreground">Resource id: {String(resource.resource_id)}</p>
        </div>
        <div class="rounded-2xl border border-border bg-background p-4">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Projection</p>
          <p class="mt-2 font-medium">
            {resource.projected_article_id ? "Projected into article" : "Diagnostics only"}
          </p>
          <p class="mt-1 text-sm text-muted-foreground">
            {resource.projected_article_title
              ? String(resource.projected_article_title)
              : projectionError || "Not projected to an article yet."}
          </p>
        </div>
        <div class="rounded-2xl border border-border bg-background p-4">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Timeline</p>
          <p class="mt-2 font-medium">{formatTimestamp(resource.discovered_at)}</p>
          <p class="mt-1 text-sm text-muted-foreground">Published: {formatTimestamp(resource.published_at)}</p>
        </div>
        <div class="rounded-2xl border border-border bg-background p-4">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Counts</p>
          <p class="mt-2 font-medium">Docs {String(resource.documents_count ?? 0)} · Media {String(resource.media_count ?? 0)}</p>
          <p class="mt-1 text-sm text-muted-foreground">Links {String(resource.links_out_count ?? 0)} · Children {String(resource.child_resources_count ?? 0)}</p>
        </div>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.35fr_0.65fr]">
      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <div class="mb-4">
          <h2 class="text-base font-semibold">Content preview</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            Persisted website resource body captured by the existing ingest and extraction path.
          </p>
        </div>
        {resourceHtml ? (
          <article
            class="prose prose-neutral max-w-none prose-headings:text-foreground prose-a:text-primary dark:prose-invert"
            set:html={resourceHtml}
          />
        ) : (
          <pre class="whitespace-pre-wrap text-sm leading-6 text-foreground">{String(resource.body ?? "No body available.")}</pre>
        )}
      </section>

      <div class="space-y-6">
        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <div class="mb-4">
            <h2 class="text-base font-semibold">Selection diagnostics</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Server-owned selection summary for this resource or its projected article.
            </p>
          </div>
          <dl class="grid gap-3 text-sm">
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Source</dt>
              <dd class="mt-1 text-foreground">{String(selectionDiagnostics.source ?? resource.selection_source ?? "pending")}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Reason</dt>
              <dd class="mt-1 text-foreground">{String(selectionDiagnostics.selectionReason ?? resource.selection_reason ?? "—")}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Downstream loss bucket</dt>
              <dd class="mt-1 text-foreground">
                {String(selectionDiagnostics.downstreamLossBucket ?? "—")} · stage: {String(selectionDiagnostics.selectionBlockerStage ?? "—")}
              </dd>
              <p class="mt-1 text-xs text-muted-foreground">
                {String(selectionDiagnostics.selectionBlockerReason ?? "No blocker reason available.")}
              </p>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Hold / review</dt>
              <dd class="mt-1 text-foreground">
                hold {String(selectionDiagnostics.holdCount ?? resource.selection_hold_count ?? 0)} · pending review {String(selectionDiagnostics.llmReviewPendingCount ?? resource.selection_llm_review_pending_count ?? 0)}
              </dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Filter rows</dt>
              <dd class="mt-1 text-foreground">
                matched {String(selectionDiagnostics.matchedRows ?? 0)} · no-match {String(selectionDiagnostics.noMatchRows ?? 0)} · gray-zone {String(selectionDiagnostics.grayZoneRows ?? 0)}
              </dd>
              <p class="mt-1 text-xs text-muted-foreground">
                {`semantic: ${JSON.stringify(selectionDiagnostics.semanticSignalSummary ?? {})}`}
              </p>
            </div>
          </dl>
        </section>

        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <div class="mb-4">
            <h2 class="text-base font-semibold">Resolved URLs</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Canonical source references kept on the resource row.
            </p>
          </div>
          <dl class="grid gap-3 text-sm">
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Original URL</dt>
              <dd class="mt-1 break-all text-foreground">{String(resource.url ?? "—")}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Final URL</dt>
              <dd class="mt-1 break-all text-foreground">{String(resource.final_url ?? "—")}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Normalized URL</dt>
              <dd class="mt-1 break-all text-foreground">{String(resource.normalized_url ?? "—")}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Updated</dt>
              <dd class="mt-1 text-foreground">{formatTimestamp(resource.updated_at)}</dd>
            </div>
          </dl>
        </section>

        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <div class="mb-4">
            <h2 class="text-base font-semibold">Discovery provenance</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Operator-facing trace of whether the resource came from cheap static discovery or the browser-assisted fallback.
            </p>
          </div>
          <dl class="grid gap-3 text-sm">
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Browser-assisted</dt>
              <dd class="mt-1 text-foreground">{browserAssisted ? "Yes" : "No"}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Capture source</dt>
              <dd class="mt-1 text-foreground">{browserCaptureSource}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Challenge kind</dt>
              <dd class="mt-1 text-foreground">{browserChallengeKind}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Seed URL</dt>
              <dd class="mt-1 break-all text-foreground">{browserSeedUrl}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Rendered page URL</dt>
              <dd class="mt-1 break-all text-foreground">{browserPageUrl}</dd>
            </div>
          </dl>
        </section>

        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <div class="mb-4">
            <h2 class="text-base font-semibold">Structured extraction</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Summary of typed resource outputs retained for operator inspection.
            </p>
          </div>
          <dl class="grid gap-3 text-sm">
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Documents</dt>
              <dd class="mt-1 text-foreground">{documents.length}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Media</dt>
              <dd class="mt-1 text-foreground">{mediaAssets.length}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Links out</dt>
              <dd class="mt-1 text-foreground">{linksOut.length}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Child resources</dt>
              <dd class="mt-1 text-foreground">{childResources.length}</dd>
            </div>
            <div>
              <dt class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Extraction error</dt>
              <dd class="mt-1 text-foreground">{String(resource.extraction_error ?? "—")}</dd>
            </div>
          </dl>
        </section>
      </div>
    </div>

    <details class="group rounded-2xl border border-border bg-card p-5 shadow-sm">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-semibold text-foreground [&::-webkit-details-marker]:hidden">
        <span>Raw resource payloads</span>
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-border bg-background text-muted-foreground transition group-open:rotate-180">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </span>
      </summary>
      <div class="mt-4 grid gap-4 xl:grid-cols-2">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground">Classification / attributes</p>
          <pre class="mt-2 overflow-x-auto rounded-2xl bg-background p-4 text-xs leading-6 text-foreground">{JSON.stringify({
            classification_json: resource.classification_json ?? {},
            attributes_json: resource.attributes_json ?? {},
          }, null, 2)}</pre>
        </div>
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground">Documents / media / links</p>
          <pre class="mt-2 overflow-x-auto rounded-2xl bg-background p-4 text-xs leading-6 text-foreground">{JSON.stringify({
            documents_json: resource.documents_json ?? [],
            media_json: resource.media_json ?? [],
            links_out_json: resource.links_out_json ?? [],
            child_resources_json: resource.child_resources_json ?? [],
          }, null, 2)}</pre>
        </div>
      </div>
      <div class="mt-4">
        <p class="text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground">Raw payload</p>
        <pre class="mt-2 overflow-x-auto rounded-2xl bg-background p-4 text-xs leading-6 text-foreground">{JSON.stringify(resource.raw_payload_json ?? {}, null, 2)}</pre>
      </div>
    </details>
  </div>
</AdminShell>
