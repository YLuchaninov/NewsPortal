---
import AdminShell from "../../layouts/AdminShell.astro";
import { BulkChannelImport } from "../../components/BulkChannelImport";
import { resolveAdminSession } from "../../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../../lib/server/browser-flow";

export const prerender = false;

const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const pagePath = `${Astro.url.pathname}${Astro.url.search}`;
const providerType =
  Astro.url.searchParams.get("providerType") === "website" ? "website" : "rss";
const providerLabel = providerType === "website" ? "website" : "RSS";
const title =
  providerType === "website"
    ? "Import website channels from JSON"
    : "Import RSS channels from JSON";
const description =
  providerType === "website"
    ? "Use the shared bulk screen when you want to onboard or update multiple website ingestion channels with consistent discovery defaults and one operator review step."
    : "Keep the list page focused on monitoring and use this screen when you need validation, examples, and batch creation in one place.";
const rssImportPath = appPath("/channels/import");
const websiteImportPath = appPath("/channels/import?providerType=website");
---

<AdminShell title="Bulk Import Channels — Admin" session={session} flash={flash} activeNav="channels">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={appPath("/")} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <a href={appPath("/channels")} class="hover:text-foreground">Channels</a>
      <span>/</span>
      <span class="text-foreground font-medium">Bulk import</span>
    </nav>
  </Fragment>

  <div class="space-y-6">
    <div class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Bulk onboarding</p>
      <div class="mt-3 flex flex-wrap gap-2">
        <a
          href={rssImportPath}
          class:list={[
            "inline-flex h-9 items-center justify-center rounded-full border px-4 text-sm font-medium transition-colors",
            providerType === "rss"
              ? "border-primary bg-primary text-primary-foreground"
              : "border-input hover:bg-accent"
          ]}
        >
          RSS import
        </a>
        <a
          href={websiteImportPath}
          class:list={[
            "inline-flex h-9 items-center justify-center rounded-full border px-4 text-sm font-medium transition-colors",
            providerType === "website"
              ? "border-primary bg-primary text-primary-foreground"
              : "border-input hover:bg-accent"
          ]}
        >
          Website import
        </a>
      </div>
      <h1 class="mt-4 text-2xl font-semibold tracking-tight">{title}</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">{description}</p>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
      <BulkChannelImport
        action={appPath("/bff/admin/channels/bulk")}
        preflightAction={appPath("/bff/admin/channels/bulk/preflight")}
        redirectTo={pagePath}
        providerType={providerType}
        client:load
      />

      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <h2 class="text-base font-semibold">Import checklist</h2>
        <div class="mt-4 space-y-4 text-sm text-muted-foreground">
          <div class="rounded-2xl border border-border bg-background p-4">
            <p class="font-medium text-foreground">Validate before importing</p>
            <p class="mt-2">Use the built-in server-backed preflight to catch missing names, invalid URLs, bad scheduling values, and unexpected overwrite targets before the batch is submitted.</p>
          </div>
          <div class="rounded-2xl border border-border bg-background p-4">
            <p class="font-medium text-foreground">Keep naming consistent</p>
            <p class="mt-2">Channel names show up in fetch-run logs and admin health tables, so use source names that operators can recognize quickly across {providerLabel} operations.</p>
          </div>
          <div class="rounded-2xl border border-border bg-background p-4">
            <p class="font-medium text-foreground">{providerType === "website" ? "Review discovery settings" : "Return to monitoring"}</p>
            <p class="mt-2">
              {providerType === "website"
                ? "For website batches, keep browser fallback disabled unless you already proved the site needs it, and review any fetchUrl-matched updates carefully before you confirm the overwrite."
                : "After a successful import, go back to the channels list to review health badges, schedule state, and first fetch outcomes."}
            </p>
          </div>
        </div>
        <div class="mt-5">
          <a href={appPath("/channels")} class="inline-flex h-10 items-center justify-center rounded-md border border-input px-4 text-sm font-medium transition-colors hover:bg-accent">
            Back to channels
          </a>
        </div>
      </section>
    </div>
  </div>
</AdminShell>
