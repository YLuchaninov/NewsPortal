---
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import AdminShell from "../../../layouts/AdminShell.astro";
import { AdminConfirmAction } from "../../../components/AdminConfirmAction";
import { ChannelEditorForm } from "../../../components/ChannelEditorForm";
import { resolveAdminSession } from "../../../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../../../lib/server/browser-flow";

export const prerender = false;

const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });
const channelId = String(Astro.params.channelId ?? "");
type R = Record<string, unknown>;
const channel = await sdk.getChannel<R>(channelId);

function asRecord(v: unknown): R { return v != null && typeof v === "object" && !Array.isArray(v) ? v as R : {}; }
function asInt(v: unknown, fallback: number) {
  const parsed = typeof v === "number" && Number.isFinite(v) ? v : Number.parseInt(String(v ?? ""), 10);
  return Number.isFinite(parsed) ? Number(parsed) : fallback;
}
function fmt(v: unknown) {
  if (!v) return "—";
  const d = new Date(String(v));
  return isNaN(d.getTime()) ? String(v) : d.toLocaleString("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" });
}

const configJson = asRecord(channel.config_json);
const articleCount = asInt(channel.article_count, 0);
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;
const deleteLabel = articleCount > 0 ? "Archive channel" : "Delete channel";
const deleteDescription = articleCount > 0
  ? `This channel is already linked to ${articleCount} historical article${articleCount === 1 ? "" : "s"}. Confirming this action will archive it instead of hard-deleting it.`
  : "This channel has no linked historical articles, so deleting it will permanently remove it and its runtime state.";
---

<AdminShell title="Edit Channel — Admin" session={session} flash={flash} activeNav="channels">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={appPath("/")} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <a href={appPath("/channels")} class="hover:text-foreground">Channels</a>
      <span>/</span>
      <span class="text-foreground font-medium">Edit</span>
    </nav>
  </Fragment>

  <div class="space-y-6">
    <div class="grid gap-4 xl:grid-cols-[1.2fr_0.8fr]">
      <div class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Edit channel</p>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">{String(channel.name ?? "RSS channel")}</h1>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">
          Use this screen for full feed edits. Quick pause and archive actions are still available, but the detailed schedule and fetch settings live here.
        </p>
      </div>

      <section class="grid gap-3 sm:grid-cols-3 xl:grid-cols-1">
        <div class="rounded-2xl border border-border bg-card p-4 shadow-sm">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Linked articles</p>
          <p class="mt-2 text-2xl font-semibold">{articleCount}</p>
          <p class="mt-2 text-sm text-muted-foreground">Historical articles determine whether delete becomes a safe archive.</p>
        </div>
        <div class="rounded-2xl border border-border bg-card p-4 shadow-sm">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Last success</p>
          <p class="mt-2 text-sm font-medium">{fmt(channel.last_success_at)}</p>
          <p class="mt-2 text-sm text-muted-foreground">Most recent successful fetch for this feed.</p>
        </div>
        <div class="rounded-2xl border border-border bg-card p-4 shadow-sm">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Next due</p>
          <p class="mt-2 text-sm font-medium">{fmt(channel.next_due_at)}</p>
          <p class="mt-2 text-sm text-muted-foreground">Live scheduler target after the last runtime update.</p>
        </div>
      </section>
    </div>

    <ChannelEditorForm
      action={appPath("/bff/admin/channels")}
      mode="edit"
      redirectTo={currentPath}
      cancelHref={appPath("/channels")}
      value={{
        channelId,
        name: String(channel.name ?? ""),
        fetchUrl: String(channel.fetch_url ?? ""),
        language: String(channel.language ?? "en"),
        isActive: channel.is_active === true,
        pollIntervalSeconds: asInt(channel.poll_interval_seconds, 300),
        adaptiveEnabled: channel.adaptive_enabled !== false,
        maxPollIntervalSeconds: asInt(channel.max_poll_interval_seconds, 4800),
        maxItemsPerPoll: asInt(configJson.maxItemsPerPoll, 20),
        requestTimeoutMs: asInt(configJson.requestTimeoutMs, 10000),
        userAgent: String(configJson.userAgent ?? "NewsPortalFetchers/0.1"),
        preferContentEncoded: configJson.preferContentEncoded !== false,
      }}
    />

    <section class="rounded-2xl border border-amber-200 bg-amber-50/50 p-5 shadow-sm dark:border-amber-900/40 dark:bg-amber-950/20">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <h2 class="text-base font-semibold text-foreground">Danger zone</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            {articleCount > 0
              ? "Because this feed already has historical articles, the destructive action archives it instead of deleting the record."
              : "This feed can be permanently deleted because it has no historical article links yet."}
          </p>
        </div>
        <AdminConfirmAction
          action={appPath("/bff/admin/channels")}
          title={deleteLabel}
          description={deleteDescription}
          triggerLabel={articleCount > 0 ? "Archive" : "Delete"}
          confirmLabel={articleCount > 0 ? "Archive channel" : "Delete channel"}
          fields={[
            { name: "intent", value: "delete" },
            { name: "channelId", value: channelId },
            { name: "redirectTo", value: appPath("/channels") },
          ]}
          triggerClassName={articleCount > 0 ? "border-amber-200 text-amber-700 hover:bg-amber-50 dark:border-amber-900/30 dark:text-amber-300 dark:hover:bg-amber-950/20" : "border-rose-200 text-rose-700 hover:bg-rose-50 dark:border-rose-900/30 dark:text-rose-300 dark:hover:bg-rose-950/20"}
          confirmClassName={articleCount > 0 ? "bg-amber-600 text-white hover:bg-amber-600/90" : ""}
          client:load
        />
      </div>
    </section>
  </div>
</AdminShell>
