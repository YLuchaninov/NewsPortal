---
import {
  DEFAULT_CHANNEL_ENRICHMENT_MIN_BODY_LENGTH,
  parseApiChannelConfig,
  parseEmailImapChannelConfig,
  parseRssChannelConfig,
  parseWebsiteChannelConfig,
  resolveRssChannelAdapterStrategy,
  resolveRssChannelMaxEntryAgeHours,
} from "@newsportal/contracts";
import AdminShell from "../../layouts/AdminShell.astro";
import { ChannelEditorForm } from "../../components/ChannelEditorForm";
import { resolveAdminSession } from "../../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../../lib/server/browser-flow";
import {
  resolveAdminChannelProviderType,
} from "../../lib/channel-providers";

export const prerender = false;

const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const editorPath = `${Astro.url.pathname}${Astro.url.search}`;
const rawProviderType = Astro.url.searchParams.get("providerType");
const providerType = rawProviderType
  ? resolveAdminChannelProviderType(rawProviderType)
  : null;
const defaultWebsiteConfig = parseWebsiteChannelConfig({});
const defaultRssConfig = parseRssChannelConfig({});
const defaultApiConfig = parseApiChannelConfig({});
const defaultEmailImapConfig = parseEmailImapChannelConfig({});
const title = providerType === "website"
  ? "Add website channel"
  : providerType === "api"
    ? "Add API channel"
    : providerType === "email_imap"
      ? "Add Email IMAP channel"
      : "Add source";
const description = providerType === "website"
  ? "Create one website ingestion channel at a time when you want a deliberate setup flow with safe discovery defaults."
  : providerType === "api"
    ? "Create one JSON API ingestion channel at a time when you want an explicit payload mapping and authenticated fetch support."
    : providerType === "email_imap"
      ? "Create one mailbox ingestion channel at a time when you want deliberate credential, mailbox, and sender-filter setup."
      : providerType === "rss"
        ? "Create one feed at a time when you want a deliberate setup flow. Bulk onboarding lives on a separate import screen."
        : "Choose the provider first, then continue in a dedicated setup workspace with safe defaults for that source type.";
---

<AdminShell title="New Channel — Admin" session={session} flash={flash} activeNav="channels">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={appPath("/")} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <a href={appPath("/channels")} class="hover:text-foreground">Channels</a>
      <span>/</span>
      <span class="text-foreground font-medium">New</span>
    </nav>
  </Fragment>

  <div class="space-y-6">
    <div class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Create</p>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight">{title}</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">{description}</p>
    </div>

    {providerType === null ? (
      <div class="grid gap-4 xl:grid-cols-[1.1fr_0.9fr]">
        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <h2 class="text-base font-semibold">Choose a source type</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            Start with the provider. Deep settings, auth, and advanced fetch controls stay on the next screen so this first step stays lightweight.
          </p>
          <div class="mt-4 rounded-2xl border border-border bg-background p-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="text-sm font-medium text-foreground">Quick RSS entry</p>
                <p class="mt-1 text-sm text-muted-foreground">
                  Paste one feed URL to jump straight into the existing create path. The full chooser stays below for provider-specific setup.
                </p>
              </div>
            </div>
            <form method="post" action={appPath("/bff/admin/channels")} class="mt-4 grid gap-3 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
              <input type="hidden" name="providerType" value="rss" />
              <input type="hidden" name="redirectTo" value={editorPath} />
              <label class="grid gap-1.5">
                <span class="text-sm font-medium">Feed URL</span>
                <input
                  type="url"
                  name="fetchUrl"
                  placeholder="https://example.com/feed.xml"
                  class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                />
              </label>
              <button
                type="submit"
                class="inline-flex h-10 items-center justify-center rounded-md border border-input px-4 text-sm font-medium transition-colors hover:bg-accent"
              >
                Create RSS source
              </button>
            </form>
          </div>
          <div class="mt-5 grid gap-3 md:grid-cols-2">
            {[
              {
                href: appPath("/channels/new?providerType=rss"),
                title: "RSS feed",
                body: "Fastest path for editorial feeds with polling, adapter, and enrichment defaults.",
              },
              {
                href: appPath("/channels/new?providerType=website"),
                title: "Website",
                body: "Generic website acquisition with discovery modes, crawl budgets, and optional browser fallback.",
              },
              {
                href: appPath("/channels/new?providerType=api"),
                title: "API",
                body: "JSON endpoint ingest with explicit field mapping and optional authorization header.",
              },
              {
                href: appPath("/channels/new?providerType=email_imap"),
                title: "Email IMAP",
                body: "Mailbox-backed ingest for press inboxes and structured sender-filter workflows.",
              },
            ].map((option) => (
              <a href={option.href} class="rounded-2xl border border-border bg-background p-4 transition-colors hover:bg-accent hover:border-primary/20">
                <p class="text-sm font-medium text-foreground">{option.title}</p>
                <p class="mt-2 text-sm text-muted-foreground">{option.body}</p>
                <p class="mt-4 text-sm font-medium text-primary">Continue →</p>
              </a>
            ))}
          </div>
        </section>

        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <h2 class="text-base font-semibold">Bulk onboarding stays separate</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            Use the dedicated import flow when you already have a prepared batch of source rows and want explicit row-level provider validation.
          </p>
          <div class="mt-4 rounded-2xl border border-border bg-background p-4">
            <p class="text-sm font-medium">When to choose each path</p>
            <div class="mt-3 space-y-3 text-sm text-muted-foreground">
              <p><span class="font-medium text-foreground">Add source:</span> deliberate setup, one provider at a time, easier to reason about defaults and risk.</p>
              <p><span class="font-medium text-foreground">Bulk import:</span> pre-prepared fleets, mixed providers, operational onboarding at scale.</p>
            </div>
            <a href={appPath("/channels/import")} class="mt-4 inline-flex h-10 items-center justify-center rounded-md border border-input px-4 text-sm font-medium transition-colors hover:bg-accent">
              Open bulk import
            </a>
          </div>
        </section>
      </div>
    ) : (
      <ChannelEditorForm
        action={appPath("/bff/admin/channels")}
        mode="create"
        redirectTo={editorPath}
        cancelHref={appPath("/channels/new")}
        value={providerType === "website"
          ? {
            providerType: "website",
            name: "",
            fetchUrl: "",
            language: "en",
            isActive: true,
            pollIntervalSeconds: 900,
            adaptiveEnabled: true,
            maxPollIntervalSeconds: 14400,
            requestTimeoutMs: defaultWebsiteConfig.requestTimeoutMs,
            userAgent: defaultWebsiteConfig.userAgent,
            maxResourcesPerPoll: defaultWebsiteConfig.maxResourcesPerPoll,
            totalPollTimeoutMs: defaultWebsiteConfig.totalPollTimeoutMs,
            crawlDelayMs: defaultWebsiteConfig.crawlDelayMs,
            sitemapDiscoveryEnabled: defaultWebsiteConfig.sitemapDiscoveryEnabled,
            feedDiscoveryEnabled: defaultWebsiteConfig.feedDiscoveryEnabled,
            collectionDiscoveryEnabled: defaultWebsiteConfig.collectionDiscoveryEnabled,
            downloadDiscoveryEnabled: defaultWebsiteConfig.downloadDiscoveryEnabled,
            browserFallbackEnabled: defaultWebsiteConfig.browserFallbackEnabled,
            collectionSeedUrlsText: "",
            allowedUrlPatternsText: "",
            blockedUrlPatternsText: "",
            hasAuthorizationHeader: false,
            }
          : providerType === "api"
            ? {
              providerType: "api",
              name: "",
              fetchUrl: "",
              language: "en",
              isActive: true,
              pollIntervalSeconds: 300,
              adaptiveEnabled: true,
              maxPollIntervalSeconds: 4800,
              maxItemsPerPoll: defaultApiConfig.maxItemsPerPoll,
              requestTimeoutMs: defaultApiConfig.requestTimeoutMs,
              userAgent: defaultApiConfig.userAgent,
              itemsPath: defaultApiConfig.itemsPath,
              titleField: defaultApiConfig.titleField,
              leadField: defaultApiConfig.leadField,
              bodyField: defaultApiConfig.bodyField,
              urlField: defaultApiConfig.urlField,
              publishedAtField: defaultApiConfig.publishedAtField,
              externalIdField: defaultApiConfig.externalIdField,
              languageField: defaultApiConfig.languageField,
              enrichmentEnabled: true,
              enrichmentMinBodyLength: DEFAULT_CHANNEL_ENRICHMENT_MIN_BODY_LENGTH,
              hasAuthorizationHeader: false,
            }
          : providerType === "email_imap"
            ? {
                providerType: "email_imap",
                name: "",
                fetchUrl: "",
                language: "en",
                isActive: true,
                pollIntervalSeconds: 300,
                adaptiveEnabled: true,
                maxPollIntervalSeconds: 4800,
                requestTimeoutMs: undefined,
                userAgent: undefined,
                maxItemsPerPoll: defaultEmailImapConfig.maxItemsPerPoll,
                enrichmentEnabled: true,
                enrichmentMinBodyLength: DEFAULT_CHANNEL_ENRICHMENT_MIN_BODY_LENGTH,
                host: defaultEmailImapConfig.host,
                port: defaultEmailImapConfig.port,
                secure: defaultEmailImapConfig.secure,
                username: defaultEmailImapConfig.username,
                mailbox: defaultEmailImapConfig.mailbox,
                searchFrom: defaultEmailImapConfig.searchFrom ?? "",
                hasPassword: false,
              }
            : {
                providerType: "rss",
                name: "",
                fetchUrl: "",
                language: "en",
                isActive: true,
                pollIntervalSeconds: 300,
                adaptiveEnabled: true,
                maxPollIntervalSeconds: 4800,
                maxItemsPerPoll: defaultRssConfig.maxItemsPerPoll,
                requestTimeoutMs: defaultRssConfig.requestTimeoutMs,
                userAgent: defaultRssConfig.userAgent,
                preferContentEncoded: defaultRssConfig.preferContentEncoded,
                adapterStrategy: defaultRssConfig.adapterStrategy,
                maxEntryAgeHours: defaultRssConfig.maxEntryAgeHours,
                resolvedAdapterStrategy: resolveRssChannelAdapterStrategy("", defaultRssConfig),
                resolvedMaxEntryAgeHours: resolveRssChannelMaxEntryAgeHours("", defaultRssConfig),
                enrichmentEnabled: true,
                enrichmentMinBodyLength: DEFAULT_CHANNEL_ENRICHMENT_MIN_BODY_LENGTH,
                hasAuthorizationHeader: false,
              }}
      />
    )}
  </div>
</AdminShell>
