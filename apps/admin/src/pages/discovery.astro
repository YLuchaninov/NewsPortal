                  <h3 class="text-sm font-semibold">{String(item.display_name ?? item.class_key ?? "Class")}</h3>
                  <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                    {String(item.class_key ?? "—")}
                  </span>
                  <span class="inline-flex items-center rounded-full border border-border bg-background px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
