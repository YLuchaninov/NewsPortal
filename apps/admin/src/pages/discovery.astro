---
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { PaginationNav } from "@newsportal/ui";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import {
  resolveDiscoveryChannelMetrics,
  resolveDiscoveryOperatorSummary,
  resolveDiscoveryRecallCandidateState,
  resolveDiscoverySourceQuality,
} from "../lib/server/operator-surfaces";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../lib/server/browser-flow";

export const prerender = false;

const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });
const bffPath = appPath("/bff/admin/discovery");
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;
const tab = Astro.url.searchParams.get("tab") ?? "dashboard";

type R = Record<string, unknown>;
type PagedR = {
  items: R[];
  page: number;
  pageSize: number;
  total: number;
  totalPages: number;
  hasNext: boolean;
  hasPrev: boolean;
};

function asRecord(value: unknown): R {
  return value != null && typeof value === "object" && !Array.isArray(value) ? (value as R) : {};
}

function asArray(value: unknown): R[] {
  return Array.isArray(value) ? value.map((entry) => asRecord(entry)) : [];
}

function asPaged(value: unknown): PagedR {
  const row = asRecord(value);
  return {
    items: asArray(row.items),
    page: asInt(row.page, 1),
    pageSize: asInt(row.pageSize, 20),
    total: asInt(row.total, 0),
    totalPages: asInt(row.totalPages, 1),
    hasNext: row.hasNext === true,
    hasPrev: row.hasPrev === true,
  };
}

function asInt(value: unknown, fallback = 0): number {
  const parsed =
    typeof value === "number" && Number.isFinite(value)
      ? value
      : Number.parseInt(String(value ?? ""), 10);
  return Number.isFinite(parsed) ? parsed : fallback;
}

function asFloat(value: unknown, fallback = 0): number {
  const parsed =
    typeof value === "number" && Number.isFinite(value)
      ? value
      : Number.parseFloat(String(value ?? ""));
  return Number.isFinite(parsed) ? parsed : fallback;
}

function asStringList(value: unknown): string[] {
  return Array.isArray(value) ? value.map((entry) => String(entry ?? "").trim()).filter(Boolean) : [];
}

async function getDiscoveryApiJson(
  path: string,
  query: Record<string, string | number | null | undefined> = {}
): Promise<unknown> {
  const target = new URL(path, runtimeConfig.apiBaseUrl);
  for (const [key, value] of Object.entries(query)) {
    if (value == null) continue;
    const normalized = String(value).trim();
    if (!normalized) continue;
    target.searchParams.set(key, normalized);
  }
  const response = await fetch(target, {
    headers: {
      accept: "application/json",
    },
  });
  if (!response.ok) {
    throw new Error(`Discovery API request failed: ${response.status}`);
  }
  return response.json();
}

function fmtDate(value: unknown): string {
  if (!value) return "—";
  const date = new Date(String(value));
  return Number.isNaN(date.getTime())
    ? String(value)
    : date.toLocaleString("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" });
}

function fmtMoney(cents: unknown): string {
  return `$${(asInt(cents, 0) / 100).toFixed(2)}`;
}

function fmtUsd(value: unknown): string {
  const amount = asFloat(value, 0);
  return `$${amount >= 1 ? amount.toFixed(2) : amount.toFixed(4)}`;
}

function fmtBudget(cents: unknown): string {
  const amount = asInt(cents, 0);
  return amount > 0 ? fmtMoney(amount) : "Unlimited";
}

function fmtPercent(value: unknown): string {
  return `${Math.round(asFloat(value, 0) * 100)}%`;
}

function metricSourceLabel(value: unknown): string {
  const normalized = String(value ?? "").trim();
  return normalized === "generic_channel_quality" ? "generic intake quality" : normalized || "generic intake quality";
}

function resolveTabHref(nextTab: string): string {
  const target = new URL(Astro.url);
  if (nextTab === "dashboard") {
    target.searchParams.delete("tab");
  } else {
    target.searchParams.set("tab", nextTab);
  }
  return `${target.pathname}${target.search}`;
}

function resolvePageHref(paramName: string, nextPage: number): string {
  const target = new URL(Astro.url);
  target.searchParams.set("tab", tab || "dashboard");
  if (nextPage <= 1) {
    target.searchParams.delete(paramName);
  } else {
    target.searchParams.set(paramName, String(nextPage));
  }
  return `${target.pathname}${target.search}`;
}

function resolveMissionScopedHref(missionId: string): string {
  const target = new URL(Astro.url);
  if (missionId) {
    target.searchParams.set("portfolioMissionId", missionId);
  } else {
    target.searchParams.delete("portfolioMissionId");
  }
  return `${target.pathname}${target.search}`;
}

const requestedMissionPage = Number.parseInt(Astro.url.searchParams.get("missionPage") ?? "1", 10);
const requestedClassPage = Number.parseInt(Astro.url.searchParams.get("classPage") ?? "1", 10);
const requestedCandidatePage = Number.parseInt(Astro.url.searchParams.get("candidatePage") ?? "1", 10);
const requestedHypothesisPage = Number.parseInt(Astro.url.searchParams.get("hypothesisPage") ?? "1", 10);
const requestedSourcePage = Number.parseInt(Astro.url.searchParams.get("sourcePage") ?? "1", 10);
const requestedFeedbackPage = Number.parseInt(Astro.url.searchParams.get("feedbackPage") ?? "1", 10);
const requestedRecallMissionPage = Number.parseInt(Astro.url.searchParams.get("recallMissionPage") ?? "1", 10);
const requestedRecallCandidatePage = Number.parseInt(Astro.url.searchParams.get("recallCandidatePage") ?? "1", 10);
const missionPage = Number.isFinite(requestedMissionPage) && requestedMissionPage > 0 ? requestedMissionPage : 1;
const classPage = Number.isFinite(requestedClassPage) && requestedClassPage > 0 ? requestedClassPage : 1;
const candidatePage = Number.isFinite(requestedCandidatePage) && requestedCandidatePage > 0 ? requestedCandidatePage : 1;
const hypothesisPage = Number.isFinite(requestedHypothesisPage) && requestedHypothesisPage > 0 ? requestedHypothesisPage : 1;
const sourcePage = Number.isFinite(requestedSourcePage) && requestedSourcePage > 0 ? requestedSourcePage : 1;
const feedbackPage = Number.isFinite(requestedFeedbackPage) && requestedFeedbackPage > 0 ? requestedFeedbackPage : 1;
const recallMissionPage =
  Number.isFinite(requestedRecallMissionPage) && requestedRecallMissionPage > 0
    ? requestedRecallMissionPage
    : 1;
const recallCandidatePage =
  Number.isFinite(requestedRecallCandidatePage) && requestedRecallCandidatePage > 0
    ? requestedRecallCandidatePage
    : 1;

const summary = asRecord(await sdk.getDiscoverySummary<R>());
const costs = asRecord(await sdk.getDiscoveryCostSummary<R>());
const missions = asPaged(await sdk.listDiscoveryMissions<R>({ page: missionPage, pageSize: 10 }));
const classes = asPaged(await sdk.listDiscoveryClasses<R>({ page: classPage, pageSize: 10 }));
const candidates = asPaged(await sdk.listDiscoveryCandidates<R>({ page: candidatePage, pageSize: 12 }));
const hypotheses = asPaged(await sdk.listDiscoveryHypotheses<R>({ page: hypothesisPage, pageSize: 12 }));
const sourceProfiles = asPaged(await sdk.listDiscoverySourceProfiles<R>({ page: sourcePage, pageSize: 12 }));
const feedback = asPaged(await sdk.listDiscoveryFeedback<R>({ page: feedbackPage, pageSize: 12 }));
const recallMissions = asPaged(
  await getDiscoveryApiJson("/maintenance/discovery/recall-missions", {
    page: recallMissionPage,
    pageSize: 8,
  }).catch(() => ({}))
);
const recallCandidates = asPaged(
  await getDiscoveryApiJson("/maintenance/discovery/recall-candidates", {
    page: recallCandidatePage,
    pageSize: 10,
  }).catch(() => ({}))
);

const missionItems = missions.items.map((item) => asRecord(item));
const classItems = classes.items.map((item) => asRecord(item));
const candidateItems = candidates.items.map((item) => asRecord(item));
const hypothesisItems = hypotheses.items.map((item) => asRecord(item));
const sourceProfileItems = sourceProfiles.items.map((item) => asRecord(item));
const feedbackItems = feedback.items.map((item) => asRecord(item));
const recallMissionItems = recallMissions.items.map((item) => asRecord(item));
const recallCandidateItems = recallCandidates.items.map((item) => asRecord(item));
const operatorSummary = resolveDiscoveryOperatorSummary(summary);
const selectedMissionIdRaw = String(Astro.url.searchParams.get("portfolioMissionId") ?? "").trim();
const selectedMissionId =
  missionItems.find((item) => String(item.mission_id ?? "") === selectedMissionIdRaw) != null
    ? selectedMissionIdRaw
    : String(missionItems[0]?.mission_id ?? "");
const portfolioResult = selectedMissionId
  ? asRecord(await sdk.getDiscoveryMissionPortfolio<R>(selectedMissionId).catch(() => ({})))
  : {};
const portfolioSnapshot = asRecord(portfolioResult.snapshot);
const sourceScores = selectedMissionId
  ? asPaged(
      await sdk.listDiscoverySourceInterestScores<R>({
        missionId: selectedMissionId,
        page: 1,
        pageSize: 20,
      })
    )
  : asPaged({});
const sourceScoreItems = sourceScores.items.map((item) => asRecord(item));
const sourceScoreByProfileId = new Map<string, R>(
  sourceScoreItems
    .map((item) => [String(item.source_profile_id ?? ""), item] as const)
    .filter(([key]) => key.length > 0)
);
const rankedSources = asArray(portfolioSnapshot.ranked_sources);
const portfolioGaps = asArray(portfolioSnapshot.gaps_json);
const portfolioSummary = asRecord(portfolioSnapshot.summary_json);
const costItems = asArray(costs.items);

const tabs = [
  { key: "dashboard", label: "Dashboard" },
  { key: "missions", label: "Missions" },
  { key: "recall", label: "Recall" },
  { key: "classes", label: "Classes" },
  { key: "candidates", label: "Candidates" },
  { key: "hypotheses", label: "Hypotheses" },
  { key: "sources", label: "Sources" },
  { key: "portfolio", label: "Portfolio" },
  { key: "feedback", label: "Feedback" },
];

const pagePaths = {
  dashboard: appPath("/"),
};
const monthlyBudgetCents = asInt(
  summary.monthlyBudgetCents ?? costs.monthlyBudgetCents ?? runtimeConfig.discoveryMonthlyBudgetCents,
  0
);
const remainingMonthlyBudgetCents = asInt(
  summary.remainingMonthlyBudgetCents ?? costs.remainingMonthlyBudgetCents,
  0
);
const monthToDateCostUsd = asFloat(summary.monthToDateCostUsd ?? costs.monthToDateCostUsd, 0);
const totalCostUsd = asFloat(costs.totalCostUsd ?? summary.total_cost_usd, 0);
const monthlyQuotaReached = summary.monthlyQuotaReached === true || costs.monthlyQuotaReached === true;
const activeSearchProvider = String(summary.searchProvider ?? runtimeConfig.discoverySearchProvider);
const activeLlmModel = String(summary.llmModel ?? runtimeConfig.discoveryLlmModel);
---

<AdminShell title="Discovery — Admin" session={session} flash={flash} activeNav="discovery">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={pagePaths.dashboard} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">Discovery</span>
    </nav>
  </Fragment>

  <Fragment slot="header-actions">
    <a href={appPath("/channels")} class="inline-flex h-9 items-center justify-center rounded-md border border-input px-3 text-sm font-medium transition-colors hover:bg-accent">
      View channels
    </a>
  </Fragment>

  <div class="space-y-6">
    <div class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Adaptive Discovery Agent</p>
          <h1 class="mt-2 text-2xl font-semibold tracking-tight">Dual-path discovery control plane</h1>
          <p class="mt-2 text-sm leading-6 text-muted-foreground">
            Discovery now ships two bounded upstream lanes. Graph-first missions still own mission planning, hypothesis classes, and portfolio fit, while independent recall owns neutral acquisition backlog, generic source quality, and bounded promotion into normal channels. Downstream zero-shot filtering stays a separate consumer of the discovered corpus.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Enabled</p>
            <p class={`mt-1 text-2xl font-semibold ${summary.enabled ? "text-emerald-500" : "text-slate-500"}`}>
              {summary.enabled ? "Yes" : "No"}
            </p>
          </div>
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Graph missions</p>
            <p class="mt-1 text-2xl font-semibold">{String(operatorSummary.graphMissionCount)}</p>
          </div>
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Recall missions</p>
            <p class="mt-1 text-2xl font-semibold">{String(operatorSummary.recallMissionCount)}</p>
          </div>
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">This month</p>
            <p class="mt-1 text-2xl font-semibold">{fmtUsd(monthToDateCostUsd)}</p>
          </div>
        </div>
      </div>

      <div class="mt-5 flex flex-wrap gap-2">
        {tabs.map((item) => (
          <a
            href={resolveTabHref(item.key)}
            class:list={[
              "inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium transition-colors",
              tab === item.key || (tab === "dashboard" && item.key === "dashboard")
                ? "bg-primary text-primary-foreground"
                : "bg-muted text-muted-foreground hover:bg-accent hover:text-foreground",
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      {monthlyQuotaReached && (
        <div class="mt-4 rounded-2xl border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-950">
          Monthly discovery quota is exhausted for the current UTC month. Planning and mission runs will remain blocked until the quota resets or `DISCOVERY_MONTHLY_BUDGET_CENTS` is increased.
        </div>
      )}

      <div class="mt-4 grid gap-3 sm:grid-cols-4">
        <div class="rounded-2xl border border-border bg-background p-4">
          <p class="text-sm font-medium">Search provider</p>
          <p class="mt-1 text-sm text-muted-foreground">{activeSearchProvider}</p>
        </div>
        <div class="rounded-2xl border border-border bg-background p-4">
          <p class="text-sm font-medium">Discovery LLM</p>
          <p class="mt-1 text-sm text-muted-foreground break-all">{activeLlmModel}</p>
        </div>
        <div class="rounded-2xl border border-border bg-background p-4">
          <p class="text-sm font-medium">Monthly quota</p>
          <p class="mt-1 text-sm text-muted-foreground">
            {fmtBudget(monthlyBudgetCents)}
            {monthlyBudgetCents > 0 ? ` · ${fmtMoney(remainingMonthlyBudgetCents)} left` : ""}
          </p>
        </div>
        <div class="rounded-2xl border border-border bg-background p-4">
          <p class="text-sm font-medium">Default cron</p>
          <p class="mt-1 text-sm text-muted-foreground font-mono">{String(summary.defaultCron ?? runtimeConfig.discoveryCron)}</p>
        </div>
      </div>

      <div class="mt-4 rounded-2xl border border-sky-200 bg-sky-50/60 px-4 py-3 text-sm text-sky-950 dark:border-sky-900/40 dark:bg-sky-950/20 dark:text-sky-100">
        <strong>Operator note:</strong> keep these meanings separate. <em>Mission fit</em> stays graph-scoped and portfolio-specific, <em>generic source quality</em> comes from additive recall/source snapshots, <em>neutral recall backlog</em> tracks acquisition without `interest_graph`, and <em>promotion state</em> shows which recall candidates have already become normal `source_channels`. None of these signals should be interpreted as downstream selected-content yield.
      </div>
    </div>

    {(tab === "dashboard" || !tab) && (
      <div class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
        <div class="space-y-4">
          <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
            <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
              <div>
                <h2 class="text-base font-semibold">Discovery operator model</h2>
                <p class="mt-1 text-sm text-muted-foreground">
                  The shipped runtime is now dual-path: graph-first compatibility planning plus independent recall acquisition and promotion.
                </p>
              </div>
              <span class="inline-flex w-fit items-center rounded-full border border-border bg-background px-3 py-1 text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground">
                {operatorSummary.operatingModel === "dual_path" ? "dual path" : "graph first only"}
              </span>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Graph missions</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.graphMissionCount)}</p>
                <p class="mt-1 text-xs text-muted-foreground">
                  {String(operatorSummary.activeGraphMissionCount)} active · {String(operatorSummary.compiledGraphCount)} compiled
                </p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Mission backlog</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.pendingHypothesisCount)}</p>
                <p class="mt-1 text-xs text-muted-foreground">
                  pending hypotheses · {String(operatorSummary.graphCandidateCount)} graph candidates
                </p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Mission fit state</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.sourceInterestScoreCount)}</p>
                <p class="mt-1 text-xs text-muted-foreground">
                  mission source scores · {String(operatorSummary.portfolioSnapshotCount)} portfolio snapshots
                </p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Recall missions</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.recallMissionCount)}</p>
                <p class="mt-1 text-xs text-muted-foreground">
                  {String(operatorSummary.activeRecallMissionCount)} active neutral missions
                </p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Recall backlog</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.recallCandidateCount)}</p>
                <p class="mt-1 text-xs text-muted-foreground">
                  {String(operatorSummary.pendingRecallCandidateCount)} pending · {String(operatorSummary.duplicateRecallCandidateCount)} linked duplicates
                </p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Generic quality</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.sourceQualitySnapshotCount)}</p>
                <p class="mt-1 text-xs text-muted-foreground">
                  snapshots across {String(operatorSummary.sourceProfileCount)} source profiles
                </p>
              </div>
            </div>
            <div class="mt-4 grid gap-3 lg:grid-cols-2">
              <div class="rounded-2xl border border-emerald-300/60 bg-emerald-50/60 p-4 text-sm text-emerald-950 dark:border-emerald-900/50 dark:bg-emerald-950/20 dark:text-emerald-100">
                <p class="font-medium">Independent recall lane</p>
                <p class="mt-1 leading-6">
                  Recall runs can search and probe `rss` / `website` candidates without `interest_graph`, persist generic source-quality snapshots, and now promote shortlisted candidates into `source_channels`.
                </p>
              </div>
              <div class="rounded-2xl border border-amber-300/60 bg-amber-50/60 p-4 text-sm text-amber-950 dark:border-amber-900/50 dark:bg-amber-950/20 dark:text-amber-100">
                <p class="font-medium">Graph-first compatibility lane</p>
                <p class="mt-1 leading-6">
                  Mission graphs, class registry planning, hypothesis execution, feedback, and portfolio assembly remain live compatibility flows. They are no longer the only owner of source onboarding.
                </p>
              </div>
            </div>
          </section>

          <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
            <h2 class="text-base font-semibold">Recall promotion snapshot</h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-3">
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Promoted recall candidates</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.promotedRecallCandidateCount)}</p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Linked duplicates</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.duplicateRecallCandidateCount)}</p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-medium">Review queue</p>
                <p class="mt-2 text-3xl font-semibold">{String(operatorSummary.pendingRecallCandidateCount)}</p>
              </div>
            </div>
          </section>
        </div>

        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <h2 class="text-base font-semibold">Cost ledger</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            {fmtUsd(totalCostUsd)} total, {fmtUsd(costs.last24hCostUsd)} in the last 24h, {fmtUsd(costs.monthToDateCostUsd)} this UTC month.
          </p>
          <div class="mt-4 space-y-2">
            {costItems.length === 0 ? (
              <p class="rounded-2xl border border-dashed border-border bg-background px-4 py-5 text-sm text-muted-foreground">
                No discovery cost rows yet.
              </p>
            ) : costItems.map((item) => (
              <div class="rounded-2xl border border-border bg-background px-4 py-3">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-sm font-medium">{String(item.provider ?? "unknown")} / {String(item.operation ?? "operation")}</p>
                    <p class="text-xs text-muted-foreground">
                      {String(item.row_count ?? 0)} entries · {fmtUsd(item.month_to_date_cost_usd)} this month
                    </p>
                  </div>
                  <p class="text-sm font-semibold">{fmtUsd(item.total_cost_usd)}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      </div>
    )}

    {tab === "missions" && (
      <div class="grid gap-4 xl:grid-cols-[0.8fr_1.2fr]">
        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <h2 class="text-base font-semibold">Create mission</h2>
          <form method="post" action={bffPath} class="mt-4 grid gap-3">
            <input type="hidden" name="intent" value="create_mission" />
            <input type="hidden" name="redirectTo" value={currentPath} />
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Title</span>
              <input name="title" required class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Description</span>
