                    confirmLabel={isClassArchived ? "Reactivate class" : "Archive class"}
                    fields={[
                      { name: "intent", value: isClassArchived ? "activate_class" : "archive_class" },
                      { name: "classKey", value: classKey },
                      { name: "redirectTo", value: currentPath },
                    ]}
                    triggerClassName={isClassArchived ? "border-emerald-200 text-emerald-700 hover:bg-emerald-50 dark:border-emerald-900/30 dark:text-emerald-300 dark:hover:bg-emerald-950/20" : "border-amber-200 text-amber-700 hover:bg-amber-50 dark:border-amber-900/30 dark:text-amber-300 dark:hover:bg-amber-950/20"}
                    confirmClassName={isClassArchived ? "bg-emerald-600 text-white hover:bg-emerald-600/90" : "bg-amber-600 text-white hover:bg-amber-600/90"}
