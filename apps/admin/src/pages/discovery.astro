              {sourceProfileItems.length === 0 ? (
                <p class="px-5 py-8 text-sm text-muted-foreground">No source profiles yet. Discovery will add them after source evaluation runs.</p>
              ) : sourceProfileItems.map((profile) => {
                const profileId = String(profile.source_profile_id ?? "");
                const isSelected = profileId === selectedSourceProfileId;
                return (
                  <article class:list={["px-5 py-4 transition-colors", isSelected && "bg-muted/20"]}>
                    <div class="flex flex-col gap-3 xl:flex-row xl:items-start xl:justify-between">
                      <div class="space-y-1.5">
                        <div class="flex flex-wrap items-center gap-2">
                          <a
                            href={resolveSelectionHref("sources", { selectedSourceProfileId: profileId })}
                            data-admin-pane-open-link="discovery-sources"
                            class="text-sm font-semibold hover:text-primary"
                          >
                            {String(profile.canonical_domain ?? "Unknown domain")}
                          </a>
                          <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                            {String(profile.source_type ?? "unknown")}
                          </span>
                        </div>
                        <p class="text-sm text-muted-foreground">
                          Org {String(profile.org_name ?? "—")} · Country {String(profile.country ?? "—")} · Languages {asStringList(profile.languages).join(", ") || "—"}
                        </p>
                        <p class="text-xs text-muted-foreground">
                          Trust {fmtPercent(profile.trust_score)} · Accountability {fmtPercent(profile.author_accountability)} · Technical quality {fmtPercent(profile.technical_quality)}
                        </p>
                      </div>
                      <a
                        href={resolveSelectionHref("sources", { selectedSourceProfileId: profileId })}
                        data-admin-pane-open-link="discovery-sources"
                        class:list={[
                          "inline-flex h-9 items-center justify-center rounded-md border px-3 text-sm font-medium transition-colors",
                          isSelected
                            ? "border-primary/40 bg-primary/10 text-primary"
                            : "border-input hover:bg-accent",
                        ]}
                      >
                        Inspect
                      </a>
                    </div>
                  </article>
                );
              })}
            </div>
            {(sourceProfiles.hasPrev || sourceProfiles.hasNext) && (
              <PaginationNav
                className="rounded-none border-x-0 border-b-0"
                page={sourceProfiles.page}
                totalPages={sourceProfiles.totalPages}
                hasPrev={sourceProfiles.hasPrev}
                hasNext={sourceProfiles.hasNext}
                prevHref={resolvePageHref("sourcePage", sourceProfiles.page - 1)}
                nextHref={resolvePageHref("sourcePage", sourceProfiles.page + 1)}
              />
            )}
          </section>
        </Fragment>

        <Fragment slot="pane">
          {selectedSourceProfile ? (() => {
            const profile = selectedSourceProfile;
            const score = sourceScoreByProfileId.get(String(profile.source_profile_id ?? ""));
            const channelMetrics = resolveDiscoveryChannelMetrics(score);
            const sourceQuality = resolveDiscoverySourceQuality(profile);
            return (
              <div class="space-y-5">
                <div class="space-y-3">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 text-[11px] font-medium text-muted-foreground">
                      {String(profile.source_type ?? "unknown")}
                    </span>
                    <span class="inline-flex items-center rounded-full border border-border bg-background px-2.5 py-1 text-[11px] font-medium text-muted-foreground">
                      {String(profile.country ?? "Unknown country")}
                    </span>
                  </div>
                  <div>
                    <h2 class="text-2xl font-semibold tracking-tight">{String(profile.canonical_domain ?? "Unknown domain")}</h2>
                    <p class="mt-2 text-sm leading-6 text-muted-foreground">
                      Org {String(profile.org_name ?? "—")} · Languages {asStringList(profile.languages).join(", ") || "—"}
                    </p>
                  </div>
                </div>

                <div class="grid gap-3 md:grid-cols-2">
                  <div class="rounded-2xl border border-border bg-background px-4 py-4 text-sm text-muted-foreground">
                    <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-muted-foreground">Generic source quality</p>
                    <div class="mt-3 space-y-1.5">
                      <div>Recall score {sourceQuality.recallScore == null ? "—" : fmtPercent(sourceQuality.recallScore)}</div>
                      <div>Metric source {metricSourceLabel(sourceQuality.metricSource)}</div>
                      <div>Yield {fmtPercent(sourceQuality.yieldScore ?? 0)} · Lead {fmtPercent(sourceQuality.leadTimeScore ?? 0)} · Dupes {fmtPercent(sourceQuality.duplicationScore ?? 0)}</div>
                      <div>Snapshot {sourceQuality.snapshotReason ?? "—"} · {fmtDate(sourceQuality.scoredAt)}</div>
                    </div>
                  </div>
                  <div class="rounded-2xl border border-border bg-background px-4 py-4 text-sm text-muted-foreground">
                    <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-muted-foreground">Mission fit</p>
                    {score ? (
                      <div class="mt-3 space-y-1.5">
                        <div>Contextual fit {fmtPercent(score.contextual_score)}</div>
                        <div>Channel quality {metricSourceLabel(channelMetrics.metricSource)}</div>
                        <div>Yield {fmtPercent(channelMetrics.yieldScore ?? 0)} · Lead {fmtPercent(channelMetrics.leadTimeScore ?? 0)} · Dupes {fmtPercent(channelMetrics.duplicationScore ?? 0)}</div>
                        <div>Unique articles {String(channelMetrics.uniqueArticlesPeriod ?? 0)} / {String(channelMetrics.totalArticlesPeriod ?? 0)}</div>
                        <div>Roles {asStringList(score.role_labels).join(", ") || "—"}</div>
                      </div>
                    ) : (
                      <div class="mt-3">No mission-scoped source score for the current portfolio mission.</div>
                    )}
                  </div>
                </div>

                <div class="rounded-2xl border border-border bg-background px-4 py-4 text-sm text-muted-foreground">
                  <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-muted-foreground">Operator context</p>
                  <div class="mt-3 space-y-1.5">
                    <div>Trust {fmtPercent(profile.trust_score)} · Accountability {fmtPercent(profile.author_accountability)} · Technical quality {fmtPercent(profile.technical_quality)}</div>
                    <div>Context mission {selectedMissionId || "No active portfolio mission"}</div>
                    {selectedMissionId ? (
                      <div>
                        <a href={resolveMissionScopedHref(selectedMissionId)} class="text-primary hover:underline">
                          Open current mission portfolio
                        </a>
                      </div>
                    ) : null}
                  </div>
                </div>
              </div>
            );
          })() : (
            <div class="rounded-2xl border border-dashed border-border bg-background px-4 py-10 text-sm text-muted-foreground">
              Select a source profile to compare generic quality against the current mission-fit context.
            </div>
          )}
        </Fragment>
      </AdminWorkspacePane>
    )}

    {tab === "portfolio" && (
      <div class="grid gap-4 xl:grid-cols-[0.85fr_1.15fr]">
        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <h2 class="text-base font-semibold">Portfolio controls</h2>
          <div class="mt-4 space-y-3">
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Selected mission</span>
              <div class="rounded-md border border-input bg-background px-3 py-2 text-sm">
                {selectedMissionId || "No mission selected"}
              </div>
            </label>
            <form method="post" action={bffPath} class="grid gap-3">
              <input type="hidden" name="intent" value="re_evaluate" />
              <input type="hidden" name="missionId" value={selectedMissionId} />
              <input type="hidden" name="redirectTo" value={currentPath} />
              <button type="submit" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
                Re-evaluate mission
              </button>
            </form>
            <div class="rounded-2xl border border-border bg-background p-4 text-sm text-muted-foreground">
              <p>Snapshot reason: {String(portfolioSnapshot.snapshot_reason ?? "—")}</p>
              <p class="mt-1">Created: {fmtDate(portfolioSnapshot.created_at)}</p>
              <p class="mt-1">Selected sources: {String(portfolioSummary.selected_count ?? 0)}</p>
              <p class="mt-1">Gap count: {String(portfolioSummary.gap_count ?? 0)}</p>
            </div>
            <div class="space-y-2">
              {missionItems.map((mission) => (
                <a href={resolveMissionScopedHref(String(mission.mission_id ?? ""))} class="flex items-center justify-between rounded-xl border border-border bg-background px-3 py-2 text-sm transition-colors hover:bg-accent">
                  <span>{String(mission.title ?? mission.mission_id ?? "Mission")}</span>
                  <span class="text-xs text-muted-foreground">{String(mission.interest_graph_status ?? "pending")}</span>
                </a>
              ))}
            </div>
          </div>
        </section>

        <section class="rounded-2xl border border-border bg-card shadow-sm overflow-hidden">
          <div class="border-b border-border px-5 py-4">
            <h2 class="text-base font-semibold">Ranked sources</h2>
            <p class="mt-1 text-sm text-muted-foreground">{rankedSources.length} ranked source{rankedSources.length === 1 ? "" : "s"} in latest snapshot</p>
          </div>
          <div class="divide-y divide-border">
            {rankedSources.length === 0 ? (
              <p class="px-5 py-8 text-sm text-muted-foreground">No portfolio snapshot yet. Run or refresh the selected mission first.</p>
            ) : rankedSources.map((item) => {
              const channelMetrics = resolveDiscoveryChannelMetrics(item);

              return (
                <div class="px-5 py-4">
                  <div class="flex flex-col gap-2 xl:flex-row xl:items-start xl:justify-between">
                    <div class="space-y-1">
                      <h3 class="text-sm font-semibold">{String(item.canonical_domain ?? item.url ?? "Source")}</h3>
                      <a href={String(item.url ?? "#")} target="_blank" class="text-sm text-primary hover:underline break-all">
                        {String(item.url ?? "—")}
                      </a>
                      <p class="text-xs text-muted-foreground">Roles: {asStringList(item.role_labels).join(", ") || "—"}</p>
                    </div>
                    <div class="rounded-2xl border border-border bg-background px-3 py-2 text-xs text-muted-foreground">
                      <div>Mission fit {fmtPercent(item.contextual_score)}</div>
                      <div class="mt-1">Trust {fmtPercent(item.trust_score)}</div>
                      <div class="mt-1">Yield {fmtPercent(channelMetrics.yieldScore ?? 0)} · Lead {fmtPercent(channelMetrics.leadTimeScore ?? 0)} · Dupes {fmtPercent(channelMetrics.duplicationScore ?? 0)}</div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
          <div class="border-t border-border px-5 py-4">
            <h3 class="text-sm font-semibold">Coverage gaps</h3>
            <div class="mt-3 space-y-2">
              {portfolioGaps.length === 0 ? (
                <p class="text-sm text-muted-foreground">No open portfolio gaps.</p>
              ) : portfolioGaps.map((gap) => (
                <div class="rounded-2xl border border-border bg-background px-4 py-3 text-sm">
                  <p class="font-medium">{String(gap.kind ?? "gap")}</p>
                  <p class="mt-1 text-muted-foreground">{String(gap.message ?? gap.query_hint ?? "No details")}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      </div>
    )}

    {tab === "feedback" && (
      <div class="grid gap-4 xl:grid-cols-[0.75fr_1.25fr]">
        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <h2 class="text-base font-semibold">Submit feedback</h2>
          <form method="post" action={bffPath} class="mt-4 grid gap-3">
            <input type="hidden" name="intent" value="submit_feedback" />
            <input type="hidden" name="redirectTo" value={currentPath} />
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Mission ID</span>
              <input name="missionId" value={selectedMissionId} class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Candidate ID</span>
              <input name="candidateId" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Source profile ID</span>
              <input name="sourceProfileId" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <div class="grid gap-3 sm:grid-cols-2">
              <label class="grid gap-1.5">
                <span class="text-xs font-medium">Feedback type</span>
                <select name="feedbackType" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">
                  {["valuable_source", "early_signal", "keep", "too_noisy", "duplicate_source", "reject"].map((option) => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
              </label>
              <label class="grid gap-1.5">
                <span class="text-xs font-medium">Feedback value</span>
                <input name="feedbackValue" placeholder="optional value" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
              </label>
            </div>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Notes</span>
              <textarea name="notes" rows="4" class="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring"></textarea>
            </label>
            <button type="submit" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
              Record feedback
            </button>
          </form>
        </section>

        <section class="rounded-2xl border border-border bg-card shadow-sm overflow-hidden">
          <div class="border-b border-border px-5 py-4">
            <h2 class="text-base font-semibold">Feedback events</h2>
            <p class="mt-1 text-sm text-muted-foreground">{feedback.total} event{feedback.total === 1 ? "" : "s"} total</p>
          </div>
          <div class="divide-y divide-border">
            {feedbackItems.length === 0 ? (
              <p class="px-5 py-8 text-sm text-muted-foreground">No feedback events yet. Review feedback appears here after operator decisions.</p>
            ) : feedbackItems.map((item) => (
              <div class="px-5 py-4">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="text-sm font-semibold">{String(item.feedback_type ?? "feedback")}</h3>
                  <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                    {String(item.feedback_value ?? "no value")}
                  </span>
                </div>
                <p class="mt-1 text-sm text-muted-foreground">{String(item.notes ?? "No notes")}</p>
                <p class="mt-1 text-xs text-muted-foreground">
                  Mission {String(item.mission_id ?? "—")} · Candidate {String(item.candidate_id ?? "—")} · Profile {String(item.source_profile_id ?? "—")} · {fmtDate(item.created_at)}
                </p>
              </div>
            ))}
          </div>
          {(feedback.hasPrev || feedback.hasNext) && (
            <PaginationNav
              className="rounded-none border-x-0 border-b-0"
              page={feedback.page}
              totalPages={feedback.totalPages}
              hasPrev={feedback.hasPrev}
              hasNext={feedback.hasNext}
              prevHref={resolvePageHref("feedbackPage", feedback.page - 1)}
              nextHref={resolvePageHref("feedbackPage", feedback.page + 1)}
            />
          )}
        </section>
      </div>
    )}
  </div>
</AdminShell>
