                  </div>
                )}
              </div>
            );
          })() : (
            <div class="rounded-2xl border border-dashed border-border bg-background px-4 py-10 text-sm text-muted-foreground">
              Select a candidate to review explainability and moderation actions in one side pane.
            </div>
