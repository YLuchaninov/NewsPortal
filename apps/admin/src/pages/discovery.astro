                  <div class="grid gap-1">
                    <span class="text-[11px] font-medium uppercase tracking-[0.14em] text-muted-foreground">Update</span>
                    <button type="submit" class="inline-flex h-9 items-center justify-center rounded-md border border-input px-3 text-sm font-medium transition-colors hover:bg-accent">
                      Save class
                    </button>
                  </div>
                </form>
              </div>
            ))}
          </div>
          {(classes.hasPrev || classes.hasNext) && (
            <PaginationNav
              className="rounded-none border-x-0 border-b-0"
              page={classes.page}
              totalPages={classes.totalPages}
              hasPrev={classes.hasPrev}
              hasNext={classes.hasNext}
              prevHref={resolvePageHref("classPage", classes.page - 1)}
              nextHref={resolvePageHref("classPage", classes.page + 1)}
            />
          )}
        </section>
      </div>
    )}

    {tab === "candidates" && (
      <section class="rounded-2xl border border-border bg-card shadow-sm overflow-hidden">
        <div class="border-b border-border px-5 py-4">
          <h2 class="text-base font-semibold">Candidates</h2>
          <p class="mt-1 text-sm text-muted-foreground">{candidates.total} candidate{candidates.total === 1 ? "" : "s"} total</p>
        </div>
        <div class="divide-y divide-border">
          {candidateItems.length === 0 ? (
            <p class="px-5 py-8 text-sm text-muted-foreground">No discovery candidates yet.</p>
          ) : candidateItems.map((candidate) => (
            <div class="px-5 py-4">
              <div class="flex flex-col gap-2 xl:flex-row xl:items-start xl:justify-between">
                <div class="space-y-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="text-sm font-semibold">{String(candidate.title ?? candidate.url ?? "Candidate")}</h3>
                    <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                      {String(candidate.status ?? "pending")}
                    </span>
                    <span class="inline-flex items-center rounded-full bg-background px-2 py-0.5 text-[11px] font-medium text-muted-foreground border border-border">
                      {String(candidate.provider_type ?? "rss")}
                    </span>
                  </div>
                  <a href={String(candidate.url ?? "#")} target="_blank" class="text-sm text-primary hover:underline break-all">
                    {String(candidate.url ?? "—")}
                  </a>
                  <p class="text-sm text-muted-foreground">{String(candidate.description ?? "No reasoning recorded")}</p>
                  <p class="text-xs text-muted-foreground">
                    Mission: {String(candidate.mission_title ?? "—")} · Class: {String(candidate.class_key ?? "—")} · Tactic: {String(candidate.tactic_key ?? "—")} · Score: {asFloat(candidate.relevance_score, 0).toFixed(2)}
                  </p>
                </div>
                {String(candidate.status ?? "pending") === "pending" ? (
                  <div class="grid gap-2 sm:grid-cols-2">
                    <form method="post" action={bffPath} class="flex gap-2">
                      <input type="hidden" name="intent" value="review_candidate" />
                      <input type="hidden" name="candidateId" value={String(candidate.candidate_id ?? "")} />
                      <input type="hidden" name="status" value="approved" />
                      <input type="hidden" name="redirectTo" value={currentPath} />
                      <button type="submit" class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
                        Approve
                      </button>
                    </form>
                    <form method="post" action={bffPath} class="grid gap-2">
                      <input type="hidden" name="intent" value="review_candidate" />
                      <input type="hidden" name="candidateId" value={String(candidate.candidate_id ?? "")} />
                      <input type="hidden" name="status" value="rejected" />
                      <input type="hidden" name="redirectTo" value={currentPath} />
                      <input name="rejectionReason" placeholder="reason" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
                      <button type="submit" class="inline-flex h-9 items-center justify-center rounded-md border border-input px-3 text-sm font-medium transition-colors hover:bg-accent">
                        Reject
                      </button>
                    </form>
                  </div>
                ) : (
                  <div class="rounded-2xl border border-border bg-background px-3 py-2 text-xs text-muted-foreground">
                    Reviewed {fmtDate(candidate.reviewed_at)} by {String(candidate.reviewed_by ?? "system")}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
        {(candidates.hasPrev || candidates.hasNext) && (
          <PaginationNav
            className="rounded-none border-x-0 border-b-0"
            page={candidates.page}
            totalPages={candidates.totalPages}
            hasPrev={candidates.hasPrev}
            hasNext={candidates.hasNext}
            prevHref={resolvePageHref("candidatePage", candidates.page - 1)}
            nextHref={resolvePageHref("candidatePage", candidates.page + 1)}
          />
        )}
      </section>
    )}

    {tab === "hypotheses" && (
      <section class="rounded-2xl border border-border bg-card shadow-sm overflow-hidden">
        <div class="border-b border-border px-5 py-4">
          <h2 class="text-base font-semibold">Hypotheses</h2>
          <p class="mt-1 text-sm text-muted-foreground">{hypotheses.total} hypothesis{hypotheses.total === 1 ? "" : "es"} total</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full min-w-[1120px] text-sm">
            <thead>
              <tr class="border-b border-border bg-muted/30">
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Mission</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Class</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Query</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Expected value</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Results</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Cost</th>
              </tr>
            </thead>
            <tbody>
              {hypothesisItems.length === 0 ? (
                <tr>
                  <td colspan="6" class="px-5 py-10 text-center text-sm text-muted-foreground">No discovery hypotheses yet.</td>
                </tr>
              ) : hypothesisItems.map((hypothesis) => (
                <tr class="border-b border-border last:border-b-0">
                  <td class="px-5 py-4 align-top">
                    <div class="font-medium">{String(hypothesis.mission_title ?? "—")}</div>
                    <div class="mt-1 text-xs text-muted-foreground">{String(hypothesis.status ?? "pending")}</div>
                  </td>
                  <td class="px-5 py-4 align-top">
                    <div>{String(hypothesis.class_key ?? "—")}</div>
                    <div class="mt-1 text-xs text-muted-foreground">{String(hypothesis.tactic_key ?? "default")}</div>
                  </td>
                  <td class="px-5 py-4 align-top text-muted-foreground">{String(hypothesis.search_query ?? "—")}</td>
                  <td class="px-5 py-4 align-top text-muted-foreground">{String(hypothesis.expected_value ?? "—")}</td>
                  <td class="px-5 py-4 align-top">
                    <div>{String(hypothesis.sources_found ?? 0)} found</div>
                    <div class="mt-1 text-xs text-muted-foreground">
                      {String(hypothesis.sources_approved ?? 0)} approved · {asFloat(hypothesis.effectiveness, 0).toFixed(2)} effectiveness
                    </div>
                  </td>
                  <td class="px-5 py-4 align-top">
                    <div>{fmtUsd(hypothesis.execution_cost_usd)}</div>
                    <div class="mt-1 text-xs text-muted-foreground">{fmtMoney(hypothesis.execution_cost_cents ?? 0)}</div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {(hypotheses.hasPrev || hypotheses.hasNext) && (
          <PaginationNav
            className="rounded-none border-x-0 border-b-0"
            page={hypotheses.page}
            totalPages={hypotheses.totalPages}
            hasPrev={hypotheses.hasPrev}
            hasNext={hypotheses.hasNext}
            prevHref={resolvePageHref("hypothesisPage", hypotheses.page - 1)}
            nextHref={resolvePageHref("hypothesisPage", hypotheses.page + 1)}
          />
        )}
      </section>
    )}

    {tab === "sources" && (
      <section class="rounded-2xl border border-border bg-card shadow-sm overflow-hidden">
        <div class="border-b border-border px-5 py-4">
          <h2 class="text-base font-semibold">Source profiles</h2>
          <p class="mt-1 text-sm text-muted-foreground">{sourceProfiles.total} profile{sourceProfiles.total === 1 ? "" : "s"} total</p>
        </div>
        <div class="divide-y divide-border">
          {sourceProfileItems.length === 0 ? (
            <p class="px-5 py-8 text-sm text-muted-foreground">No source profiles yet.</p>
          ) : sourceProfileItems.map((profile) => {
            const score = sourceScoreByProfileId.get(String(profile.source_profile_id ?? ""));
            const channelMetrics = resolveDiscoveryChannelMetrics(score);
            const sourceQuality = resolveDiscoverySourceQuality(profile);
            return (
              <div class="px-5 py-4">
                <div class="flex flex-col gap-2 xl:flex-row xl:items-start xl:justify-between">
                  <div class="space-y-1">
                    <div class="flex flex-wrap items-center gap-2">
                      <h3 class="text-sm font-semibold">{String(profile.canonical_domain ?? "Unknown domain")}</h3>
                      <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                        {String(profile.source_type ?? "unknown")}
                      </span>
                    </div>
                    <p class="text-sm text-muted-foreground">
                      Org: {String(profile.org_name ?? "—")} · Country: {String(profile.country ?? "—")} · Languages: {asStringList(profile.languages).join(", ") || "—"}
                    </p>
                    <p class="text-xs text-muted-foreground">
                      Trust {fmtPercent(profile.trust_score)} · Accountability {fmtPercent(profile.author_accountability)} · Technical quality {fmtPercent(profile.technical_quality)}
                    </p>
                  </div>
                  <div class="grid gap-3 md:grid-cols-2">
                    <div class="rounded-2xl border border-border bg-background px-3 py-3 text-xs text-muted-foreground">
                      <div class="font-medium text-foreground">Generic source quality</div>
                      <div class="mt-1">Recall score {sourceQuality.recallScore == null ? "—" : fmtPercent(sourceQuality.recallScore)}</div>
                      <div class="mt-1">Metric source {metricSourceLabel(sourceQuality.metricSource)}</div>
                      <div class="mt-1">Yield {fmtPercent(sourceQuality.yieldScore ?? 0)} · Lead {fmtPercent(sourceQuality.leadTimeScore ?? 0)} · Dupes {fmtPercent(sourceQuality.duplicationScore ?? 0)}</div>
                      <div class="mt-1">Snapshot {sourceQuality.snapshotReason ?? "—"} · {fmtDate(sourceQuality.scoredAt)}</div>
                    </div>
                    <div class="rounded-2xl border border-border bg-background px-3 py-3 text-xs text-muted-foreground">
                      <div class="font-medium text-foreground">Mission fit</div>
                      {score ? (
                        <>
                          <div class="mt-1">Contextual fit {fmtPercent(score.contextual_score)}</div>
                          <div class="mt-1">Channel quality {metricSourceLabel(channelMetrics.metricSource)}</div>
                          <div class="mt-1">Yield {fmtPercent(channelMetrics.yieldScore ?? 0)} · Lead {fmtPercent(channelMetrics.leadTimeScore ?? 0)} · Dupes {fmtPercent(channelMetrics.duplicationScore ?? 0)}</div>
                          <div class="mt-1">Unique articles {String(channelMetrics.uniqueArticlesPeriod ?? 0)} / {String(channelMetrics.totalArticlesPeriod ?? 0)}</div>
                          <div class="mt-1">Roles: {asStringList(score.role_labels).join(", ") || "—"}</div>
                        </>
                      ) : (
                        <div class="mt-1">No mission-scoped source score for the current portfolio mission.</div>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
        {(sourceProfiles.hasPrev || sourceProfiles.hasNext) && (
          <PaginationNav
            className="rounded-none border-x-0 border-b-0"
            page={sourceProfiles.page}
            totalPages={sourceProfiles.totalPages}
            hasPrev={sourceProfiles.hasPrev}
            hasNext={sourceProfiles.hasNext}
            prevHref={resolvePageHref("sourcePage", sourceProfiles.page - 1)}
            nextHref={resolvePageHref("sourcePage", sourceProfiles.page + 1)}
          />
        )}
      </section>
    )}

    {tab === "portfolio" && (
      <div class="grid gap-4 xl:grid-cols-[0.85fr_1.15fr]">
        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <h2 class="text-base font-semibold">Portfolio controls</h2>
          <div class="mt-4 space-y-3">
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Selected mission</span>
              <div class="rounded-md border border-input bg-background px-3 py-2 text-sm">
                {selectedMissionId || "No mission selected"}
              </div>
            </label>
            <form method="post" action={bffPath} class="grid gap-3">
              <input type="hidden" name="intent" value="re_evaluate" />
              <input type="hidden" name="missionId" value={selectedMissionId} />
              <input type="hidden" name="redirectTo" value={currentPath} />
              <button type="submit" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
                Re-evaluate mission
              </button>
            </form>
            <div class="rounded-2xl border border-border bg-background p-4 text-sm text-muted-foreground">
              <p>Snapshot reason: {String(portfolioSnapshot.snapshot_reason ?? "—")}</p>
              <p class="mt-1">Created: {fmtDate(portfolioSnapshot.created_at)}</p>
              <p class="mt-1">Selected sources: {String(portfolioSummary.selected_count ?? 0)}</p>
              <p class="mt-1">Gap count: {String(portfolioSummary.gap_count ?? 0)}</p>
            </div>
            <div class="space-y-2">
              {missionItems.map((mission) => (
                <a href={resolveMissionScopedHref(String(mission.mission_id ?? ""))} class="flex items-center justify-between rounded-xl border border-border bg-background px-3 py-2 text-sm transition-colors hover:bg-accent">
                  <span>{String(mission.title ?? mission.mission_id ?? "Mission")}</span>
                  <span class="text-xs text-muted-foreground">{String(mission.interest_graph_status ?? "pending")}</span>
                </a>
              ))}
            </div>
          </div>
        </section>

        <section class="rounded-2xl border border-border bg-card shadow-sm overflow-hidden">
          <div class="border-b border-border px-5 py-4">
            <h2 class="text-base font-semibold">Ranked sources</h2>
            <p class="mt-1 text-sm text-muted-foreground">{rankedSources.length} ranked source{rankedSources.length === 1 ? "" : "s"} in latest snapshot</p>
          </div>
          <div class="divide-y divide-border">
            {rankedSources.length === 0 ? (
              <p class="px-5 py-8 text-sm text-muted-foreground">No portfolio snapshot yet for the selected mission.</p>
            ) : rankedSources.map((item) => {
              const channelMetrics = resolveDiscoveryChannelMetrics(item);

              return (
                <div class="px-5 py-4">
                  <div class="flex flex-col gap-2 xl:flex-row xl:items-start xl:justify-between">
                    <div class="space-y-1">
                      <h3 class="text-sm font-semibold">{String(item.canonical_domain ?? item.url ?? "Source")}</h3>
                      <a href={String(item.url ?? "#")} target="_blank" class="text-sm text-primary hover:underline break-all">
                        {String(item.url ?? "—")}
                      </a>
                      <p class="text-xs text-muted-foreground">Roles: {asStringList(item.role_labels).join(", ") || "—"}</p>
                    </div>
                    <div class="rounded-2xl border border-border bg-background px-3 py-2 text-xs text-muted-foreground">
                      <div>Mission fit {fmtPercent(item.contextual_score)}</div>
                      <div class="mt-1">Trust {fmtPercent(item.trust_score)}</div>
                      <div class="mt-1">Yield {fmtPercent(channelMetrics.yieldScore ?? 0)} · Lead {fmtPercent(channelMetrics.leadTimeScore ?? 0)} · Dupes {fmtPercent(channelMetrics.duplicationScore ?? 0)}</div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
          <div class="border-t border-border px-5 py-4">
            <h3 class="text-sm font-semibold">Coverage gaps</h3>
            <div class="mt-3 space-y-2">
              {portfolioGaps.length === 0 ? (
                <p class="text-sm text-muted-foreground">No open portfolio gaps.</p>
              ) : portfolioGaps.map((gap) => (
                <div class="rounded-2xl border border-border bg-background px-4 py-3 text-sm">
                  <p class="font-medium">{String(gap.kind ?? "gap")}</p>
                  <p class="mt-1 text-muted-foreground">{String(gap.message ?? gap.query_hint ?? "No details")}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      </div>
    )}

    {tab === "feedback" && (
      <div class="grid gap-4 xl:grid-cols-[0.75fr_1.25fr]">
        <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <h2 class="text-base font-semibold">Submit feedback</h2>
          <form method="post" action={bffPath} class="mt-4 grid gap-3">
            <input type="hidden" name="intent" value="submit_feedback" />
            <input type="hidden" name="redirectTo" value={currentPath} />
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Mission ID</span>
              <input name="missionId" value={selectedMissionId} class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Candidate ID</span>
              <input name="candidateId" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Source profile ID</span>
              <input name="sourceProfileId" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <div class="grid gap-3 sm:grid-cols-2">
              <label class="grid gap-1.5">
                <span class="text-xs font-medium">Feedback type</span>
                <select name="feedbackType" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">
                  {["valuable_source", "early_signal", "keep", "too_noisy", "duplicate_source", "reject"].map((option) => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
              </label>
              <label class="grid gap-1.5">
                <span class="text-xs font-medium">Feedback value</span>
                <input name="feedbackValue" placeholder="optional value" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
              </label>
            </div>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Notes</span>
              <textarea name="notes" rows="4" class="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring"></textarea>
            </label>
            <button type="submit" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
              Record feedback
            </button>
          </form>
        </section>

        <section class="rounded-2xl border border-border bg-card shadow-sm overflow-hidden">
          <div class="border-b border-border px-5 py-4">
            <h2 class="text-base font-semibold">Feedback events</h2>
            <p class="mt-1 text-sm text-muted-foreground">{feedback.total} event{feedback.total === 1 ? "" : "s"} total</p>
          </div>
          <div class="divide-y divide-border">
            {feedbackItems.length === 0 ? (
              <p class="px-5 py-8 text-sm text-muted-foreground">No feedback events yet.</p>
            ) : feedbackItems.map((item) => (
              <div class="px-5 py-4">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="text-sm font-semibold">{String(item.feedback_type ?? "feedback")}</h3>
                  <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                    {String(item.feedback_value ?? "no value")}
                  </span>
                </div>
                <p class="mt-1 text-sm text-muted-foreground">{String(item.notes ?? "No notes")}</p>
                <p class="mt-1 text-xs text-muted-foreground">
                  Mission {String(item.mission_id ?? "—")} · Candidate {String(item.candidate_id ?? "—")} · Profile {String(item.source_profile_id ?? "—")} · {fmtDate(item.created_at)}
                </p>
              </div>
            ))}
          </div>
          {(feedback.hasPrev || feedback.hasNext) && (
            <PaginationNav
              className="rounded-none border-x-0 border-b-0"
              page={feedback.page}
              totalPages={feedback.totalPages}
              hasPrev={feedback.hasPrev}
              hasNext={feedback.hasNext}
              prevHref={resolvePageHref("feedbackPage", feedback.page - 1)}
              nextHref={resolvePageHref("feedbackPage", feedback.page + 1)}
            />
          )}
        </section>
      </div>
    )}
  </div>
</AdminShell>
