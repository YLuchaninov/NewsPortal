                    <p class="mt-3 text-sm leading-6 text-muted-foreground">{String(candidate.description ?? "No reasoning recorded")}</p>
                  </div>
                  <div class="rounded-2xl border border-border bg-background px-4 py-3 text-sm text-muted-foreground">
                    Mission {String(candidate.mission_title ?? "—")} · Class {String(candidate.class_key ?? "—")} · Tactic {String(candidate.tactic_key ?? "—")}<br />
                    Relevance score {asFloat(candidate.relevance_score, 0).toFixed(2)} · Profile {explainability.profileName ?? "—"} · Version {String(explainability.profileVersion ?? "—")}
                  </div>
                </div>

                <div class="rounded-2xl border border-border bg-background px-4 py-4 text-sm text-muted-foreground">
                  <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-muted-foreground">Explainability</p>
                  <div class="mt-3 space-y-1.5">
                    <div>Threshold {explainability.threshold == null ? "—" : explainability.threshold.toFixed(2)} · Score {explainability.score == null ? "—" : explainability.score.toFixed(2)}</div>
                    <div>Fit {explainability.fitScore == null ? "—" : explainability.fitScore.toFixed(2)} · Quality prior {explainability.qualityPrior == null ? "—" : explainability.qualityPrior.toFixed(2)} · Final review {explainability.finalReviewScore == null ? "—" : explainability.finalReviewScore.toFixed(2)}</div>
                    <div>Policy verdict {explainability.policyVerdict ?? "—"} · Onboarding {explainability.onboardingVerdict ?? "—"} · Provider {explainability.provider ?? "—"}</div>
