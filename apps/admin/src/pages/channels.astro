---
import {
  CHANNEL_SCHEDULE_PRESETS,
  DEFAULT_PAGE,
  DEFAULT_PAGE_SIZE,
  parseApiChannelConfig,
  parseEmailImapChannelConfig,
  parseRssChannelConfig,
  parseWebsiteChannelConfig,
  resolveRssChannelAdapterStrategy,
  resolveRssChannelMaxEntryAgeHours,
} from "@newsportal/contracts";
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { PaginationNav } from "@newsportal/ui";
import { AdminConfirmAction } from "../components/AdminConfirmAction";
import { AdminConfirmSubmitButton } from "../components/AdminConfirmSubmitButton";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../lib/server/browser-flow";
import {
  formatAdminChannelProviderLabel,
  isAdminChannelProviderType,
} from "../lib/channel-providers";

export const prerender = false;

const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });

const bffPaths = {
  channels: appPath("/bff/admin/channels"),
  channelsSchedule: appPath("/bff/admin/channels/schedule"),
};

const pagePaths = {
  dashboard: appPath("/"),
  help: appPath("/help"),
  resources: appPath("/resources"),
  newSource: appPath("/channels/new"),
  importChannels: appPath("/channels/import"),
};

type R = Record<string, unknown>;
function asRecord(v: unknown): R {
  return v != null && typeof v === "object" && !Array.isArray(v) ? (v as R) : {};
}
function asInt(v: unknown, f: number) {
  const p = typeof v === "number" && Number.isInteger(v) ? v : parseInt(String(v ?? ""), 10);
  return Number.isInteger(p) && p >= 0 ? p : f;
}
function asBoolString(v: boolean) {
  return v ? "true" : "false";
}
function resolveListedProviderType(value: unknown): string {
  const normalized = String(value ?? "").trim();
  return normalized || "unknown";
}
function formatListedProviderLabel(providerType: string): string {
  if (isAdminChannelProviderType(providerType)) {
    return formatAdminChannelProviderLabel(providerType);
  }
  if (providerType === "youtube") {
    return "YouTube";
  }
  return providerType || "Unknown";
}
function defaultPollIntervalSeconds(providerType: string): number {
  return providerType === "website" ? 900 : 300;
}

const requestedPage = Number.parseInt(Astro.url.searchParams.get("page") ?? String(DEFAULT_PAGE), 10);
const page = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : DEFAULT_PAGE;
const channels = await sdk.listChannelsPage<R>({
  page,
  pageSize: DEFAULT_PAGE_SIZE,
});

const currentListPath = `${Astro.url.pathname}${Astro.url.search}`;
const sourceChannels = channels.items.map((c) => {
  const cfg = asRecord(c.config_json);
  const rawProviderType = resolveListedProviderType(c.provider_type);
  const editableProviderType = isAdminChannelProviderType(rawProviderType)
    ? rawProviderType
    : null;
  const storedItemCount = asInt(c.stored_item_count, 0);
  const pollDefault = defaultPollIntervalSeconds(rawProviderType);
  const rssConfig = rawProviderType === "rss" ? parseRssChannelConfig(cfg) : null;
  const websiteConfig = rawProviderType === "website" ? parseWebsiteChannelConfig(cfg) : null;
  const apiConfig = rawProviderType === "api" ? parseApiChannelConfig(cfg) : null;
  const emailImapConfig = rawProviderType === "email_imap" ? parseEmailImapChannelConfig(cfg) : null;
  const websiteModes = rawProviderType === "website"
    ? [
        websiteConfig?.sitemapDiscoveryEnabled ? "sitemap" : null,
        websiteConfig?.feedDiscoveryEnabled ? "feed" : null,
        websiteConfig?.collectionDiscoveryEnabled ? "collection" : null,
        websiteConfig?.downloadDiscoveryEnabled ? "download" : null,
        websiteConfig?.browserFallbackEnabled ? "browser" : null,
      ].filter((value): value is string => Boolean(value))
    : [];

  return {
    channelId: String(c.channel_id ?? ""),
    rawProviderType,
    editableProviderType,
    providerLabel: formatListedProviderLabel(rawProviderType),
    name: String(c.name ?? ""),
    fetchUrl: String(c.fetch_url ?? ""),
    language: String(c.language ?? "en"),
    isActive: c.is_active === true,
    pollIntervalSeconds: asInt(c.poll_interval_seconds, pollDefault),
    adaptiveEnabled: c.adaptive_enabled !== false,
    effectivePollIntervalSeconds: asInt(
      c.effective_poll_interval_seconds,
      asInt(c.poll_interval_seconds, pollDefault)
    ),
    maxPollIntervalSeconds: asInt(
      c.max_poll_interval_seconds,
      asInt(c.poll_interval_seconds, pollDefault) * 16
    ),
    nextDueAt: String(c.next_due_at ?? ""),
    lastResultKind: String(c.last_result_kind ?? "never"),
    overdueSeconds: asInt(c.overdue_seconds, 0),
    needsAttention: c.needs_attention === true,
    recentFailureCount24h: asInt(c.recent_failure_count_24h, 0),
    requestTimeoutMs: rawProviderType === "website"
      ? websiteConfig?.requestTimeoutMs ?? 10000
      : rawProviderType === "api"
        ? apiConfig?.requestTimeoutMs ?? 10000
        : rssConfig?.requestTimeoutMs ?? 10000,
    userAgent: rawProviderType === "website"
      ? websiteConfig?.userAgent ?? "NewsPortalFetchers/0.1"
      : rawProviderType === "api"
        ? apiConfig?.userAgent ?? "NewsPortalFetchers/0.1"
        : rssConfig?.userAgent ?? "NewsPortalFetchers/0.1",
    lastFetchAt: String(c.last_fetch_at ?? ""),
    lastSuccessAt: String(c.last_success_at ?? ""),
    storedItemCount,
    rss:
      rawProviderType === "rss"
        ? {
            maxItemsPerPoll: rssConfig?.maxItemsPerPoll ?? 20,
            preferContentEncoded: rssConfig?.preferContentEncoded ?? true,
            adapterStrategy: rssConfig?.adapterStrategy ?? null,
            maxEntryAgeHours: rssConfig?.maxEntryAgeHours ?? null,
            resolvedAdapterStrategy: resolveRssChannelAdapterStrategy(
              String(c.fetch_url ?? ""),
              rssConfig ?? parseRssChannelConfig({})
            ),
            resolvedMaxEntryAgeHours: resolveRssChannelMaxEntryAgeHours(
              String(c.fetch_url ?? ""),
              rssConfig ?? parseRssChannelConfig({})
            ),
            enrichmentEnabled: c.enrichment_enabled !== false,
            enrichmentMinBodyLength: asInt(c.enrichment_min_body_length, 500),
          }
        : null,
    website:
      rawProviderType === "website"
        ? {
            maxResourcesPerPoll: websiteConfig?.maxResourcesPerPoll ?? 50,
            totalPollTimeoutMs: websiteConfig?.totalPollTimeoutMs ?? 30000,
            crawlDelayMs: websiteConfig?.crawlDelayMs ?? 1000,
            sitemapDiscoveryEnabled: websiteConfig?.sitemapDiscoveryEnabled ?? true,
            feedDiscoveryEnabled: websiteConfig?.feedDiscoveryEnabled ?? true,
            collectionDiscoveryEnabled: websiteConfig?.collectionDiscoveryEnabled ?? true,
            downloadDiscoveryEnabled: websiteConfig?.downloadDiscoveryEnabled ?? true,
            browserFallbackEnabled: websiteConfig?.browserFallbackEnabled ?? false,
            collectionSeedUrls: websiteConfig?.collectionSeedUrls ?? [],
            allowedUrlPatterns: websiteConfig?.allowedUrlPatterns ?? [],
            blockedUrlPatterns: websiteConfig?.blockedUrlPatterns ?? [],
            modesSummary: websiteModes.length > 0 ? websiteModes.join(", ") : "manual",
          }
        : null,
    api:
      rawProviderType === "api"
        ? {
            maxItemsPerPoll: apiConfig?.maxItemsPerPoll ?? 20,
            requestTimeoutMs: apiConfig?.requestTimeoutMs ?? 10000,
            userAgent: apiConfig?.userAgent ?? "NewsPortalFetchers/0.1",
            itemsPath: apiConfig?.itemsPath ?? "items",
            titleField: apiConfig?.titleField ?? "title",
            leadField: apiConfig?.leadField ?? "lead",
            bodyField: apiConfig?.bodyField ?? "body",
            urlField: apiConfig?.urlField ?? "url",
            publishedAtField: apiConfig?.publishedAtField ?? "publishedAt",
            externalIdField: apiConfig?.externalIdField ?? "id",
            languageField: apiConfig?.languageField ?? "language",
            enrichmentEnabled: c.enrichment_enabled !== false,
            enrichmentMinBodyLength: asInt(c.enrichment_min_body_length, 500),
          }
        : null,
    emailImap:
      rawProviderType === "email_imap"
        ? {
            host: emailImapConfig?.host ?? "",
            port: emailImapConfig?.port ?? 993,
            secure: emailImapConfig?.secure ?? true,
            username: emailImapConfig?.username ?? "",
            mailbox: emailImapConfig?.mailbox ?? "INBOX",
            searchFrom: emailImapConfig?.searchFrom ?? "",
            maxItemsPerPoll: emailImapConfig?.maxItemsPerPoll ?? 20,
            enrichmentEnabled: c.enrichment_enabled !== false,
            enrichmentMinBodyLength: asInt(c.enrichment_min_body_length, 500),
            hasPassword: Boolean(String(emailImapConfig?.password ?? "").trim()),
          }
        : null,
  };
});

function fmt(v: unknown) {
  if (!v) return "—";
  const d = new Date(String(v));
  return isNaN(d.getTime()) ? String(v) : d.toLocaleString("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" });
}

function resolvePageHref(nextPage: number): string {
  const target = new URL(Astro.url);
  if (nextPage <= DEFAULT_PAGE) {
    target.searchParams.delete("page");
  } else {
    target.searchParams.set("page", String(nextPage));
  }
  return `${target.pathname}${target.search}`;
}

const attentionCount = sourceChannels.filter((channel) => channel.needsAttention).length;
const pausedCount = sourceChannels.filter((channel) => !channel.isActive).length;
const rssCount = sourceChannels.filter((channel) => channel.rawProviderType === "rss").length;
const websiteCount = sourceChannels.filter((channel) => channel.rawProviderType === "website").length;
const apiCount = sourceChannels.filter((channel) => channel.rawProviderType === "api").length;
const emailImapCount = sourceChannels.filter((channel) => channel.rawProviderType === "email_imap").length;
const currentView = String(Astro.url.searchParams.get("view") ?? "all").trim() || "all";

const viewOptions = [
  { key: "all", label: "All", count: sourceChannels.length },
  { key: "attention", label: "Needs attention", count: attentionCount },
  { key: "paused", label: "Paused", count: pausedCount },
  { key: "rss", label: "RSS", count: rssCount },
  { key: "website", label: "Website", count: websiteCount },
  { key: "api", label: "API", count: apiCount },
  { key: "email_imap", label: "Email IMAP", count: emailImapCount },
] as const;

function resolveViewHref(view: string): string {
  const target = new URL(Astro.url);
  if (view === "all") {
    target.searchParams.delete("view");
  } else {
    target.searchParams.set("view", view);
  }
  return `${target.pathname}${target.search}`;
}

const visibleChannels = sourceChannels.filter((channel) => {
  if (currentView === "attention") {
    return channel.needsAttention;
  }
  if (currentView === "paused") {
    return !channel.isActive;
  }
  if (currentView === "rss" || currentView === "website" || currentView === "api" || currentView === "email_imap") {
    return channel.rawProviderType === currentView;
  }
  return true;
});
---

<AdminShell title="Channels — Admin" session={session} flash={flash} activeNav="channels">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={pagePaths.dashboard} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">Channels</span>
    </nav>
  </Fragment>

  <Fragment slot="header-actions">
    <div class="flex flex-wrap items-center justify-end gap-2">
      <a href={pagePaths.importChannels} class="inline-flex h-9 items-center justify-center rounded-md border border-input px-3 text-sm font-medium transition-colors hover:bg-accent">
        Bulk import
      </a>
      <a href={pagePaths.newSource} class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
        Add source
      </a>
    </div>
  </Fragment>

  <div class="space-y-6">
    <div class="flex flex-col gap-4 rounded-[1.75rem] border border-border bg-card p-6 shadow-sm lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Source operations</p>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">Source channels</h1>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              Use this page as the source operations index: filter by health or provider, pause/resume safely, then move into dedicated create or edit workspaces for deep provider-specific setup.
            </p>
      </div>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-6">
        <div class="flex min-h-[8.75rem] flex-col rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Total</p>
          <p class="mt-auto pt-4 text-4xl font-semibold leading-none">{channels.total}</p>
        </div>
        <div class="flex min-h-[8.75rem] flex-col rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">RSS</p>
          <p class="mt-auto pt-4 text-4xl font-semibold leading-none">{rssCount}</p>
        </div>
        <div class="flex min-h-[8.75rem] flex-col rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Website</p>
          <p class="mt-auto pt-4 text-4xl font-semibold leading-none">{websiteCount}</p>
        </div>
        <div class="flex min-h-[8.75rem] flex-col rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">API</p>
          <p class="mt-auto pt-4 text-4xl font-semibold leading-none">{apiCount}</p>
        </div>
        <div class="flex min-h-[8.75rem] flex-col rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Email IMAP</p>
          <p class="mt-auto pt-4 text-4xl font-semibold leading-none">{emailImapCount}</p>
        </div>
        <div class="flex min-h-[8.75rem] flex-col rounded-2xl border border-border bg-background px-4 py-3">
          <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Attention / Paused</p>
          <p class="mt-auto inline-flex items-baseline whitespace-nowrap pt-4 text-[clamp(2.25rem,3vw,3.25rem)] font-semibold leading-none tracking-tight">
            <span class="text-amber-500">{attentionCount}</span>
            <span class="mx-2 text-muted-foreground">/</span>
            <span class="text-slate-500">{pausedCount}</span>
          </p>
        </div>
      </div>
    </div>

    <div class="grid gap-4 xl:grid-cols-[1.4fr_0.8fr]">
      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold">Operational overview</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Keep the list dense and actionable here. Full provider settings, auth, and advanced fetch behavior live on separate edit screens.
            </p>
          </div>
          <a href={pagePaths.help} class="text-sm font-medium text-primary hover:underline">Read setup guide</a>
        </div>
        <div class="mt-4 grid gap-3 md:grid-cols-3">
          <div class="rounded-2xl border border-border bg-background p-4">
            <p class="text-sm font-medium">One primary create path</p>
            <p class="mt-2 text-sm text-muted-foreground">Start with a single “Add source” entry point, then choose the provider and continue in a dedicated wizard-like screen.</p>
          </div>
          <div class="rounded-2xl border border-border bg-background p-4">
            <p class="text-sm font-medium">Keep provider truth explicit</p>
            <p class="mt-2 text-sm text-muted-foreground">Website channels stay websites, APIs stay APIs, and mailbox ingest stays mailbox-based instead of being silently coerced into another provider shape.</p>
          </div>
          <div class="rounded-2xl border border-border bg-background p-4">
            <p class="text-sm font-medium">Delete safely</p>
            <p class="mt-2 text-sm text-muted-foreground">Channels with stored history are archived instead of hard-deleted, so previously ingested items stay recoverable.</p>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <div>
          <h2 class="text-base font-semibold">Bulk RSS schedule</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            Apply one polling preset across the current RSS fleet when you need fast operational tuning. Website, API, and mailbox channels keep their own provider-specific budgets and settings.
          </p>
        </div>
        <form method="post" action={bffPaths.channelsSchedule} class="mt-4 grid gap-3">
          <input type="hidden" name="redirectTo" value={currentListPath} />
          <input type="hidden" name="providerType" value="rss" />
          <label class="grid gap-1.5">
            <span class="text-xs font-medium">Base interval (seconds)</span>
            <input name="pollIntervalSeconds" type="number" min="30" value="900" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
          </label>
          <label class="grid gap-1.5">
            <span class="text-xs font-medium">Adaptive scheduling</span>
            <select name="adaptiveEnabled" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">
              <option value="true">Enabled</option>
              <option value="false">Disabled</option>
            </select>
          </label>
          <label class="grid gap-1.5">
            <span class="text-xs font-medium">Maximum interval (seconds)</span>
            <input name="maxPollIntervalSeconds" type="number" min="30" value="86400" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
          </label>
          <AdminConfirmSubmitButton
            title="Apply bulk schedule"
            description="Update the polling schedule for all RSS channels. Use this for fleet-wide tuning, not one-off channel edits."
            triggerLabel="Apply schedule"
            confirmLabel="Apply to RSS channels"
            triggerClassName="mt-2 bg-secondary text-secondary-foreground hover:bg-secondary/80"
            confirmClassName="bg-secondary text-secondary-foreground hover:bg-secondary/80"
            client:load
          />
        </form>
        <div class="mt-4 flex flex-wrap gap-1.5">
          {Object.entries(CHANNEL_SCHEDULE_PRESETS).map(([label, seconds]) => (
            <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 text-[11px] font-medium text-muted-foreground">
              {label}: {String(seconds)}s
            </span>
          ))}
        </div>
      </section>
    </div>

    <section class="overflow-hidden rounded-2xl border border-border bg-card shadow-sm">
      <div class="flex flex-col gap-2 border-b border-border px-5 py-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-base font-semibold">Source index</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            {visibleChannels.length} visible on this page
            {channels.total > 0 && ` · ${channels.total} total channel${channels.total !== 1 ? "s" : ""} · page ${channels.page} of ${Math.max(channels.totalPages, 1)}`}
          </p>
        </div>
      </div>

      <div class="border-b border-border px-5 py-3">
        <div class="flex flex-wrap gap-2">
          {viewOptions.map((view) => (
            <a
              href={resolveViewHref(view.key)}
              class:list={[
                "inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium transition-colors",
                currentView === view.key
                  ? "bg-primary text-primary-foreground"
                  : "bg-muted text-muted-foreground hover:bg-accent hover:text-foreground",
              ]}
            >
              {view.label}
              <span class:list={[
                "ml-2 inline-flex min-w-5 items-center justify-center rounded-full px-1.5 text-[11px]",
                currentView === view.key ? "bg-primary-foreground/15 text-primary-foreground" : "bg-background text-muted-foreground",
              ]}>
                {view.count}
              </span>
            </a>
          ))}
        </div>
      </div>

      {channels.total === 0 ? (
        <div class="px-6 py-14 text-center">
          <p class="text-base font-medium">No source channels yet</p>
          <p class="mt-2 text-sm text-muted-foreground">Add a source to start polling feeds, sites, APIs, or mailboxes.</p>
          <div class="mt-5 flex flex-wrap justify-center gap-3">
            <a href={pagePaths.newSource} class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
              Add source
            </a>
          </div>
        </div>
      ) : visibleChannels.length === 0 ? (
        <div class="px-6 py-14 text-center">
          <p class="text-base font-medium">No channels match this saved view</p>
          <p class="mt-2 text-sm text-muted-foreground">
            Switch views or clear the filter to see more sources.
          </p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="admin-table w-full min-w-[1080px] text-sm">
            <thead>
              <tr class="border-b border-border bg-muted/30">
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Channel</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Health</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Schedule</th>
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">History</th>
                <th class="admin-table-actions-col px-5 py-3 text-left text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Actions</th>
              </tr>
            </thead>
            <tbody>
              {visibleChannels.length === 0 ? (
                <tr>
                  <td colspan="5" class="px-5 py-10 text-center text-sm text-muted-foreground">No channels on this page</td>
                </tr>
              ) : visibleChannels.map((channel) => {
                const editHref = appPath(`/channels/${channel.channelId}/edit`);
                const resourcesHref = appPath(`/resources?channelId=${encodeURIComponent(channel.channelId)}`);
                const destructiveLabel = channel.storedItemCount > 0 ? "Archive" : "Delete";
                const destructiveDescription = channel.storedItemCount > 0
                  ? `This source already has ${channel.storedItemCount} stored item${channel.storedItemCount === 1 ? "" : "s"}. It will be archived, not deleted.`
                  : "This source has no stored history yet, so deleting it removes it permanently.";

                return (
                  <tr class="border-b border-border last:border-b-0">
                    <td class="px-5 py-4 align-top">
                      <div class="admin-table-cell-stack">
                        <div class="flex items-start justify-between gap-3">
                          <div class="admin-table-meta">
                            <p class="text-sm font-semibold leading-5">{channel.name}</p>
                            <p class="text-xs text-muted-foreground">{channel.providerLabel}</p>
                          </div>
                          <span class:list={[
                            "inline-flex items-center rounded-full px-2.5 py-1 text-[11px] font-medium",
                            channel.isActive
                              ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300"
                              : "bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-200",
                          ]}>
                            {channel.isActive ? "Active" : "Paused"}
                          </span>
                        </div>
                        <p class="max-w-xl truncate text-sm text-muted-foreground">{channel.fetchUrl || "Provider-managed connection"}</p>
                        <div class="flex flex-wrap gap-2 text-[11px] text-muted-foreground">
                        <span>{channel.language || "No language"}</span>
                        <span>•</span>
                        <span>{channel.storedItemCount} stored item{channel.storedItemCount === 1 ? "" : "s"}</span>
                        <span>•</span>
                        {channel.rawProviderType === "rss" ? (
                          <span>
                            {channel.rss?.enrichmentEnabled
                              ? `enrichment ≥ ${channel.rss.enrichmentMinBodyLength}`
                              : "enrichment off"}
                          </span>
                        ) : channel.rawProviderType === "website" ? (
                          <span>
                            {channel.website?.maxResourcesPerPoll} resources/poll
                            {channel.website?.modesSummary ? ` • ${channel.website.modesSummary}` : ""}
                          </span>
                        ) : channel.rawProviderType === "api" ? (
                          <span>
                            {channel.api?.maxItemsPerPoll} items/poll • path {channel.api?.itemsPath}
                          </span>
                        ) : channel.rawProviderType === "email_imap" ? (
                          <span>
                            {channel.emailImap?.mailbox}
                            {channel.emailImap?.searchFrom ? ` • from ${channel.emailImap.searchFrom}` : ""}
                          </span>
                        ) : (
                          <span>Provider-specific editing unavailable</span>
                        )}
                        </div>
                      </div>
                      {channel.rawProviderType === "rss" && channel.rss && (
                        <div class="mt-2 flex flex-wrap gap-2 text-[11px] text-muted-foreground">
                          <span>adapter: {channel.rss.resolvedAdapterStrategy}</span>
                          <span>•</span>
                          <span>
                            age gate: {channel.rss.resolvedMaxEntryAgeHours != null ? `${channel.rss.resolvedMaxEntryAgeHours}h` : "none"}
                          </span>
                        </div>
                      )}
                      {channel.rawProviderType === "api" && channel.api && (
                        <div class="mt-2 flex flex-wrap gap-2 text-[11px] text-muted-foreground">
                          <span>title/url: {channel.api.titleField} / {channel.api.urlField}</span>
                          <span>•</span>
                          <span>
                            {channel.api.enrichmentEnabled
                              ? `enrichment ≥ ${channel.api.enrichmentMinBodyLength}`
                              : "enrichment off"}
                          </span>
                        </div>
                      )}
                      {channel.rawProviderType === "email_imap" && channel.emailImap && (
                        <div class="mt-2 flex flex-wrap gap-2 text-[11px] text-muted-foreground">
                          <span>user: {channel.emailImap.username || "—"}</span>
                          <span>•</span>
                          <span>transport: {channel.emailImap.secure ? "imaps" : "imap"}</span>
                          <span>•</span>
                          <span>{channel.emailImap.hasPassword ? "password stored" : "password missing"}</span>
                        </div>
                      )}
                    </td>
                    <td class="px-5 py-4 align-top">
                      <div class="admin-table-cell-stack">
                        <div class="admin-table-chip-wrap">
                          {channel.needsAttention && (
                            <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-1 text-[11px] font-medium text-amber-800 dark:bg-amber-900/30 dark:text-amber-300">
                              Needs attention
                            </span>
                          )}
                          {channel.recentFailureCount24h > 0 && (
                            <span class="inline-flex items-center rounded-full bg-rose-100 px-2.5 py-1 text-[11px] font-medium text-rose-800 dark:bg-rose-900/30 dark:text-rose-300">
                              {channel.recentFailureCount24h} failure{channel.recentFailureCount24h === 1 ? "" : "s"} / 24h
                            </span>
                          )}
                          {!channel.needsAttention && channel.recentFailureCount24h === 0 && (
                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-medium text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300">
                              Healthy
                            </span>
                          )}
                        </div>
                        <div class="admin-table-meta text-sm text-muted-foreground">
                          <p>Last result: <span class="font-medium text-foreground">{channel.lastResultKind}</span></p>
                          <p>Next due: {fmt(channel.nextDueAt)}</p>
                        </div>
                      </div>
                    </td>
                    <td class="px-5 py-4 align-top text-sm text-muted-foreground">
                      <div class="admin-table-meta">
                        <p>{channel.pollIntervalSeconds}s base</p>
                        <p>{channel.effectivePollIntervalSeconds}s effective</p>
                        <p>{channel.maxPollIntervalSeconds}s max</p>
                      </div>
                    </td>
                    <td class="px-5 py-4 align-top text-sm text-muted-foreground">
                      <div class="admin-table-meta">
                        <p>Last fetch: {fmt(channel.lastFetchAt)}</p>
                        <p>Last success: {fmt(channel.lastSuccessAt)}</p>
                      </div>
                    </td>
                    <td class="px-5 py-4 align-top">
                      <div class="admin-table-actions">
                        {channel.editableProviderType && (
                          <a href={editHref} class="inline-flex h-8 min-w-[7.5rem] items-center justify-center rounded-md border border-input px-3 text-xs font-medium transition-colors hover:bg-accent">
                            Edit
                          </a>
                        )}
                        {channel.rawProviderType === "website" && (
                          <a href={resourcesHref} class="inline-flex h-8 min-w-[7.5rem] items-center justify-center rounded-md border border-input px-3 text-xs font-medium transition-colors hover:bg-accent">
                            Resources
                          </a>
                        )}
                        {channel.editableProviderType && (
                          <form method="post" action={bffPaths.channels}>
                            <input type="hidden" name="intent" value="save" />
                            <input type="hidden" name="redirectTo" value={currentListPath} />
                            <input type="hidden" name="channelId" value={channel.channelId} />
                            <input type="hidden" name="providerType" value={channel.editableProviderType} />
                            <input type="hidden" name="name" value={channel.name} />
                            <input type="hidden" name="language" value={channel.language} />
                            <input type="hidden" name="pollIntervalSeconds" value={String(channel.pollIntervalSeconds)} />
                            <input type="hidden" name="adaptiveEnabled" value={asBoolString(channel.adaptiveEnabled)} />
                            <input type="hidden" name="maxPollIntervalSeconds" value={String(channel.maxPollIntervalSeconds)} />
                            {channel.editableProviderType === "rss" ? (
                              <>
                                <input type="hidden" name="fetchUrl" value={channel.fetchUrl} />
                                <input type="hidden" name="maxItemsPerPoll" value={String(channel.rss?.maxItemsPerPoll ?? 20)} />
                                <input type="hidden" name="requestTimeoutMs" value={String(channel.requestTimeoutMs)} />
                                <input type="hidden" name="userAgent" value={channel.userAgent} />
                                <input type="hidden" name="preferContentEncoded" value={asBoolString(channel.rss?.preferContentEncoded ?? true)} />
                                <input type="hidden" name="adapterStrategy" value={channel.rss?.adapterStrategy ?? "auto"} />
                                <input type="hidden" name="maxEntryAgeHours" value={channel.rss?.maxEntryAgeHours != null ? String(channel.rss.maxEntryAgeHours) : ""} />
                                <input type="hidden" name="enrichmentEnabled" value={asBoolString(channel.rss?.enrichmentEnabled ?? true)} />
                                <input type="hidden" name="enrichmentMinBodyLength" value={String(channel.rss?.enrichmentMinBodyLength ?? 500)} />
                              </>
                            ) : channel.editableProviderType === "website" ? (
                              <>
                                <input type="hidden" name="fetchUrl" value={channel.fetchUrl} />
                                <input type="hidden" name="requestTimeoutMs" value={String(channel.requestTimeoutMs)} />
                                <input type="hidden" name="userAgent" value={channel.userAgent} />
                                <input type="hidden" name="maxResourcesPerPoll" value={String(channel.website?.maxResourcesPerPoll ?? 50)} />
                                <input type="hidden" name="totalPollTimeoutMs" value={String(channel.website?.totalPollTimeoutMs ?? 30000)} />
                                <input type="hidden" name="crawlDelayMs" value={String(channel.website?.crawlDelayMs ?? 1000)} />
                                <input type="hidden" name="sitemapDiscoveryEnabled" value={asBoolString(channel.website?.sitemapDiscoveryEnabled ?? true)} />
                                <input type="hidden" name="feedDiscoveryEnabled" value={asBoolString(channel.website?.feedDiscoveryEnabled ?? true)} />
                                <input type="hidden" name="collectionDiscoveryEnabled" value={asBoolString(channel.website?.collectionDiscoveryEnabled ?? true)} />
                                <input type="hidden" name="downloadDiscoveryEnabled" value={asBoolString(channel.website?.downloadDiscoveryEnabled ?? true)} />
                                <input type="hidden" name="browserFallbackEnabled" value={asBoolString(channel.website?.browserFallbackEnabled ?? false)} />
                                <input type="hidden" name="collectionSeedUrls" value={(channel.website?.collectionSeedUrls ?? []).join("\n")} />
                                <input type="hidden" name="allowedUrlPatterns" value={(channel.website?.allowedUrlPatterns ?? []).join("\n")} />
                                <input type="hidden" name="blockedUrlPatterns" value={(channel.website?.blockedUrlPatterns ?? []).join("\n")} />
                              </>
                            ) : channel.editableProviderType === "api" ? (
                              <>
                                <input type="hidden" name="fetchUrl" value={channel.fetchUrl} />
                                <input type="hidden" name="maxItemsPerPoll" value={String(channel.api?.maxItemsPerPoll ?? 20)} />
                                <input type="hidden" name="requestTimeoutMs" value={String(channel.api?.requestTimeoutMs ?? 10000)} />
                                <input type="hidden" name="userAgent" value={channel.api?.userAgent ?? "NewsPortalFetchers/0.1"} />
                                <input type="hidden" name="itemsPath" value={channel.api?.itemsPath ?? "items"} />
                                <input type="hidden" name="titleField" value={channel.api?.titleField ?? "title"} />
                                <input type="hidden" name="leadField" value={channel.api?.leadField ?? "lead"} />
                                <input type="hidden" name="bodyField" value={channel.api?.bodyField ?? "body"} />
                                <input type="hidden" name="urlField" value={channel.api?.urlField ?? "url"} />
                                <input type="hidden" name="publishedAtField" value={channel.api?.publishedAtField ?? "publishedAt"} />
                                <input type="hidden" name="externalIdField" value={channel.api?.externalIdField ?? "id"} />
                                <input type="hidden" name="languageField" value={channel.api?.languageField ?? "language"} />
                                <input type="hidden" name="enrichmentEnabled" value={asBoolString(channel.api?.enrichmentEnabled ?? true)} />
                                <input type="hidden" name="enrichmentMinBodyLength" value={String(channel.api?.enrichmentMinBodyLength ?? 500)} />
                              </>
                            ) : (
                              <>
                                <input type="hidden" name="host" value={channel.emailImap?.host ?? ""} />
                                <input type="hidden" name="port" value={String(channel.emailImap?.port ?? 993)} />
                                <input type="hidden" name="secure" value={asBoolString(channel.emailImap?.secure ?? true)} />
                                <input type="hidden" name="username" value={channel.emailImap?.username ?? ""} />
                                <input type="hidden" name="mailbox" value={channel.emailImap?.mailbox ?? "INBOX"} />
                                <input type="hidden" name="searchFrom" value={channel.emailImap?.searchFrom ?? ""} />
                                <input type="hidden" name="maxItemsPerPoll" value={String(channel.emailImap?.maxItemsPerPoll ?? 20)} />
                                <input type="hidden" name="enrichmentEnabled" value={asBoolString(channel.emailImap?.enrichmentEnabled ?? true)} />
                                <input type="hidden" name="enrichmentMinBodyLength" value={String(channel.emailImap?.enrichmentMinBodyLength ?? 500)} />
                              </>
                            )}
                            <input type="hidden" name="isActive" value={asBoolString(!channel.isActive)} />
                            <button type="submit" class="inline-flex h-8 min-w-[7.5rem] items-center justify-center rounded-md border border-input px-3 text-xs font-medium transition-colors hover:bg-accent">
                              {channel.isActive ? "Pause" : "Resume"}
                            </button>
                          </form>
                        )}
                        <AdminConfirmAction
                          action={bffPaths.channels}
                          title={`${destructiveLabel} channel`}
                          description={destructiveDescription}
                          triggerLabel={destructiveLabel}
                          confirmLabel={destructiveLabel}
                          fields={[
                            { name: "intent", value: "delete" },
                            { name: "channelId", value: channel.channelId },
                            { name: "redirectTo", value: currentListPath },
                          ]}
                          triggerClassName={channel.storedItemCount > 0 ? "min-w-[7.5rem] justify-center border-amber-200 text-amber-700 hover:bg-amber-50 dark:border-amber-900/30 dark:text-amber-300 dark:hover:bg-amber-950/20" : "min-w-[7.5rem] justify-center border-rose-200 text-rose-700 hover:bg-rose-50 dark:border-rose-900/30 dark:text-rose-300 dark:hover:bg-rose-950/20"}
                          confirmClassName={channel.storedItemCount > 0 ? "bg-amber-600 text-white hover:bg-amber-600/90" : ""}
                          client:load
                        />
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </section>

    {(channels.hasPrev || channels.hasNext) && (
      <PaginationNav
        page={channels.page}
        totalPages={channels.totalPages}
        hasPrev={channels.hasPrev}
        hasNext={channels.hasNext}
        prevHref={resolvePageHref(channels.page - 1)}
        nextHref={resolvePageHref(channels.page + 1)}
      />
    )}
  </div>
</AdminShell>
