---
import { CHANNEL_SCHEDULE_PRESETS } from "@newsportal/contracts";
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import { readFlash } from "../lib/server/browser-flow";

export const prerender = false;
const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
if (!session) return Astro.redirect("/");

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });

const forwardedPrefix = (() => {
  const v = String(Astro.request.headers.get("x-forwarded-prefix") ?? "").trim();
  return (!v || v === "/") ? "" : `/${v.replace(/^\/+|\/+$/g, "")}`;
})();
const pageBasePath = forwardedPrefix ? `${forwardedPrefix}/` : (Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`);
function rpa(t: string) {
  return new URL(String(t).replace(/^\/+/, ""), `http://app${pageBasePath}`).pathname;
}

const bffPaths = {
  channels: rpa("bff/admin/channels"),
  channelsBulk: rpa("bff/admin/channels/bulk"),
  channelsSchedule: rpa("bff/admin/channels/schedule"),
};

type R = Record<string, unknown>;
function asRecord(v: unknown): R { return v != null && typeof v === "object" && !Array.isArray(v) ? (v as R) : {}; }
function asInt(v: unknown, f: number) { const p = typeof v === "number" && Number.isInteger(v) ? v : parseInt(String(v ?? ""), 10); return Number.isInteger(p) && p > 0 ? p : f; }
function asBool(v: boolean) { return v ? "true" : "false"; }

const channels = await sdk.listChannels<R[]>();

const rssChannels = (channels as R[]).filter(c => String(c.provider_type) === "rss").map(c => {
  const cfg = asRecord(c.config_json);
  return {
    channelId: String(c.channel_id ?? ""),
    name: String(c.name ?? ""),
    fetchUrl: String(c.fetch_url ?? ""),
    language: String(c.language ?? "en"),
    isActive: c.is_active === true,
    pollIntervalSeconds: asInt(c.poll_interval_seconds, 300),
    adaptiveEnabled: c.adaptive_enabled !== false,
    effectivePollIntervalSeconds: asInt(c.effective_poll_interval_seconds, asInt(c.poll_interval_seconds, 300)),
    maxPollIntervalSeconds: asInt(c.max_poll_interval_seconds, asInt(c.poll_interval_seconds, 300) * 16),
    nextDueAt: String(c.next_due_at ?? ""),
    lastResultKind: String(c.last_result_kind ?? "never"),
    overdueSeconds: asInt(c.overdue_seconds, 0),
    needsAttention: c.needs_attention === true,
    recentFailureCount24h: asInt(c.recent_failure_count_24h, 0),
    maxItemsPerPoll: asInt(cfg.maxItemsPerPoll, 20),
    requestTimeoutMs: asInt(cfg.requestTimeoutMs, 10000),
    userAgent: String(cfg.userAgent ?? "NewsPortalFetchers/0.1"),
    preferContentEncoded: cfg.preferContentEncoded !== false,
    lastFetchAt: String(c.last_fetch_at ?? ""),
    lastSuccessAt: String(c.last_success_at ?? ""),
    lastErrorAt: String(c.last_error_at ?? ""),
    lastErrorMessage: String(c.last_error_message ?? ""),
  };
});

function fmt(v: unknown) {
  if (!v) return "—";
  const d = new Date(String(v));
  return isNaN(d.getTime()) ? String(v) : d.toLocaleString("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" });
}

const bulkPlaceholder = JSON.stringify([{
  name: "Reuters World RSS", fetchUrl: "https://example.com/world.xml", language: "en",
  pollIntervalSeconds: 300, adaptiveEnabled: true, maxPollIntervalSeconds: 3600,
  maxItemsPerPoll: 25, requestTimeoutMs: 4000, isActive: true
}], null, 2);
---

<AdminShell title="Channels — Admin" session={session} flash={flash} activeNav="channels">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">Channels</span>
    </nav>
  </Fragment>

  <div class="space-y-6">
    <!-- Page header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold">Source Channels</h1>
        <p class="text-sm text-muted-foreground mt-0.5">{rssChannels.length} RSS channel{rssChannels.length !== 1 ? "s" : ""}</p>
      </div>
    </div>

    <!-- Create + Bulk + Schedule forms in a grid -->
    <div class="grid gap-4 lg:grid-cols-3">
      <!-- Create single -->
      <div class="rounded-xl border border-border bg-card p-4">
        <h2 class="font-semibold text-sm mb-3">Add RSS Channel</h2>
        <form method="post" action={bffPaths.channels} class="grid gap-2">
          <input type="hidden" name="providerType" value="rss" />
          {[
            { name: "name", placeholder: "Reuters World RSS", label: "Name" },
            { name: "fetchUrl", placeholder: "https://example.com/feed.xml", label: "Feed URL" },
            { name: "language", defaultValue: "en", label: "Language" },
          ].map(({ name, placeholder, label, defaultValue }) => (
            <div class="grid gap-1">
              <label class="text-xs font-medium">{label}</label>
              <input name={name} placeholder={placeholder} value={defaultValue}
                class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </div>
          ))}
          <div class="grid grid-cols-2 gap-2">
            <div class="grid gap-1">
              <label class="text-xs font-medium">Poll interval (s)</label>
              <input name="pollIntervalSeconds" value="300"
                class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </div>
            <div class="grid gap-1">
              <label class="text-xs font-medium">Adaptive</label>
              <select name="adaptiveEnabled" class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
                <option value="true">Yes</option>
                <option value="false">No</option>
              </select>
            </div>
          </div>
          <div class="grid gap-1">
            <label class="text-xs font-medium">Active</label>
            <select name="isActive" class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
              <option value="true">Active</option>
              <option value="false">Paused</option>
            </select>
          </div>
          <button type="submit" class="mt-1 h-8 rounded-md bg-primary text-primary-foreground text-xs font-medium hover:bg-primary/90 transition-colors">
            Create Channel
          </button>
        </form>
      </div>

      <!-- Bulk import -->
      <div class="rounded-xl border border-border bg-card p-4">
        <h2 class="font-semibold text-sm mb-3">Bulk Import</h2>
        <form method="post" action={bffPaths.channelsBulk} class="grid gap-2 h-[calc(100%-2rem)]">
          <textarea name="channelsJson" rows={12} placeholder={bulkPlaceholder}
            class="flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-xs shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring font-mono flex-1" />
          <button type="submit" class="h-8 rounded-md bg-secondary text-secondary-foreground text-xs font-medium hover:bg-secondary/80 transition-colors">
            Import JSON
          </button>
        </form>
      </div>

      <!-- Bulk schedule -->
      <div class="rounded-xl border border-border bg-card p-4">
        <h2 class="font-semibold text-sm mb-3">Bulk Schedule</h2>
        <form method="post" action={bffPaths.channelsSchedule} class="grid gap-2">
          <div class="grid gap-1">
            <label class="text-xs font-medium">Provider</label>
            <select name="providerType" class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
              <option value="rss">RSS</option>
              <option value="website">Website</option>
              <option value="api">API</option>
              <option value="email_imap">Email IMAP</option>
            </select>
          </div>
          <div class="grid gap-1">
            <label class="text-xs font-medium">Base interval (s)</label>
            <input name="pollIntervalSeconds" value="900"
              class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
          </div>
          <div class="grid gap-1">
            <label class="text-xs font-medium">Adaptive</label>
            <select name="adaptiveEnabled" class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
              <option value="true">Yes</option>
              <option value="false">No</option>
            </select>
          </div>
          <div class="grid gap-1">
            <label class="text-xs font-medium">Max interval (s)</label>
            <input name="maxPollIntervalSeconds" value="86400"
              class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
          </div>
          <button type="submit" class="mt-1 h-8 rounded-md bg-secondary text-secondary-foreground text-xs font-medium hover:bg-secondary/80 transition-colors">
            Apply Schedule
          </button>
        </form>
        <div class="mt-3 flex flex-wrap gap-1">
          {Object.entries(CHANNEL_SCHEDULE_PRESETS).map(([label, seconds]) => (
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium bg-muted text-muted-foreground">
              {label}: {String(seconds)}s
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Channels table -->
    <div class="rounded-xl border border-border bg-card overflow-hidden">
      <div class="px-4 py-3 border-b border-border">
        <h2 class="font-semibold text-sm">RSS Channels</h2>
      </div>
      {rssChannels.length === 0 ? (
        <p class="px-4 py-8 text-sm text-muted-foreground text-center">No RSS channels yet. Add one above.</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border">
                <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Name</th>
                <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground hidden md:table-cell">Schedule</th>
                <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Status</th>
                <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground hidden lg:table-cell">Last Success</th>
                <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Actions</th>
              </tr>
            </thead>
            <tbody>
              {rssChannels.map((ch) => (
                <tr class="border-b border-border last:border-0 hover:bg-muted/30 transition-colors">
                  <td class="px-4 py-3">
                    <div class="font-medium text-xs">{ch.name}</div>
                    <div class="text-[10px] text-muted-foreground truncate max-w-[200px]">{ch.fetchUrl}</div>
                    <div class="text-[10px] text-muted-foreground">{ch.language}</div>
                  </td>
                  <td class="px-4 py-3 hidden md:table-cell text-xs text-muted-foreground">
                    <div>{ch.pollIntervalSeconds}s base / {ch.effectivePollIntervalSeconds}s eff.</div>
                    <div>next: {fmt(ch.nextDueAt)}</div>
                  </td>
                  <td class="px-4 py-3">
                    <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ${
                      ch.isActive ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300" : "bg-muted text-muted-foreground"
                    }`}>
                      {ch.isActive ? "active" : "paused"}
                    </span>
                    {ch.needsAttention && <span class="ml-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300">attention</span>}
                    {ch.recentFailureCount24h > 0 && (
                      <div class="text-[10px] text-red-500 mt-0.5">{ch.recentFailureCount24h} failures 24h</div>
                    )}
                  </td>
                  <td class="px-4 py-3 hidden lg:table-cell text-xs text-muted-foreground">{fmt(ch.lastSuccessAt)}</td>
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-1">
                      <form method="post" action={bffPaths.channels}>
                        <input type="hidden" name="channelId" value={ch.channelId} />
                        <input type="hidden" name="providerType" value="rss" />
                        <input type="hidden" name="name" value={ch.name} />
                        <input type="hidden" name="fetchUrl" value={ch.fetchUrl} />
                        <input type="hidden" name="language" value={ch.language} />
                        <input type="hidden" name="pollIntervalSeconds" value={String(ch.pollIntervalSeconds)} />
                        <input type="hidden" name="adaptiveEnabled" value={asBool(ch.adaptiveEnabled)} />
                        <input type="hidden" name="maxPollIntervalSeconds" value={String(ch.maxPollIntervalSeconds)} />
                        <input type="hidden" name="maxItemsPerPoll" value={String(ch.maxItemsPerPoll)} />
                        <input type="hidden" name="requestTimeoutMs" value={String(ch.requestTimeoutMs)} />
                        <input type="hidden" name="userAgent" value={ch.userAgent} />
                        <input type="hidden" name="preferContentEncoded" value={asBool(ch.preferContentEncoded)} />
                        <input type="hidden" name="isActive" value={asBool(!ch.isActive)} />
                        <button type="submit" class="h-7 px-2.5 rounded-md border border-input text-xs hover:bg-accent transition-colors">
                          {ch.isActive ? "Pause" : "Resume"}
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</AdminShell>

