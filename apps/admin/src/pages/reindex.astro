---
import { DEFAULT_PAGE, DEFAULT_PAGE_SIZE } from "@newsportal/contracts";
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { AdminConfirmSubmitButton } from "../components/AdminConfirmSubmitButton";
import { LiveReindexJobsSection } from "../components/LiveReindexJobsSection";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../lib/server/browser-flow";

export const prerender = false;
const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });
const reindexBffPath = appPath("/bff/admin/reindex");
const pagePaths = { dashboard: appPath("/") };
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;

type ReindexRow = Record<string, unknown>;
const requestedPage = Number.parseInt(Astro.url.searchParams.get("page") ?? String(DEFAULT_PAGE), 10);
const page = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : DEFAULT_PAGE;
const reindexJobs = await sdk.listReindexJobsPage<ReindexRow>({ page, pageSize: DEFAULT_PAGE_SIZE });
const liveUpdatesEndpoint = `${appPath("/bff/admin/live-updates")}?surface=reindex&page=${page}&pageSize=${DEFAULT_PAGE_SIZE}`;

function readProgressLabel(job: ReindexRow): string | null {
  const optionsJson = job.options_json;
  if (!optionsJson || typeof optionsJson !== "object") {
    return null;
  }
  const progress = (optionsJson as Record<string, unknown>).progress;
  if (!progress || typeof progress !== "object") {
    return null;
  }
  const progressRecord = progress as Record<string, unknown>;
  const processed = Number(
    progressRecord.processedArticles ?? progressRecord.processedContentItems ?? NaN
  );
  const total = Number(
    progressRecord.totalArticles ?? progressRecord.totalContentItems ?? NaN
  );
  if (!Number.isFinite(processed) || !Number.isFinite(total) || total <= 0) {
    return null;
  }
  return `${processed}/${total} content items`;
}

function readSelectionProfileSummary(job: ReindexRow): string | null {
  const summary = String(job.selection_profile_summary ?? "").trim();
  return summary || null;
}

function readSelectionProfileSnapshot(
  job: ReindexRow
): {
  activeProfiles: number;
  totalProfiles: number;
  compatibilityProfiles: number;
  templatesWithProfiles: number;
  maxVersion: number;
} | null {
  const snapshot =
    job.selection_profile_snapshot &&
    typeof job.selection_profile_snapshot === "object"
      ? (job.selection_profile_snapshot as Record<string, unknown>)
      : null;
  if (!snapshot) {
    return null;
  }

  const readInt = (value: unknown): number => {
    const parsed = Number(value ?? NaN);
    return Number.isFinite(parsed) ? parsed : 0;
  };

  const payload = {
    activeProfiles: readInt(snapshot.activeProfiles),
    totalProfiles: readInt(snapshot.totalProfiles),
    compatibilityProfiles: readInt(snapshot.compatibilityProfiles),
    templatesWithProfiles: readInt(snapshot.templatesWithProfiles),
    maxVersion: readInt(snapshot.maxVersion),
  };

  return Object.values(payload).some((value) => value > 0) ? payload : null;
}

const initialJobs = {
  total: reindexJobs.total,
  page: reindexJobs.page,
  totalPages: reindexJobs.totalPages,
  hasPrev: reindexJobs.hasPrev,
  hasNext: reindexJobs.hasNext,
  queuedCount: reindexJobs.items.filter((job) => String(job.status) === "queued").length,
  runningCount: reindexJobs.items.filter((job) => String(job.status) === "running").length,
  revision: JSON.stringify(
    reindexJobs.items.map((job) => [
      job.reindex_job_id,
      job.status,
      readProgressLabel(job),
      readSelectionProfileSnapshot(job),
      readSelectionProfileSummary(job),
      job.created_at,
    ])
  ),
  items: reindexJobs.items.map((job) => {
    const optionsJson = job.options_json;
    const progress = optionsJson && typeof optionsJson === "object"
      ? ((optionsJson as Record<string, unknown>).progress as Record<string, unknown> | undefined)
      : undefined;
    const processedArticles = progress
      ? Number(progress.processedArticles ?? progress.processedContentItems ?? NaN)
      : NaN;
    const totalArticles = progress
      ? Number(progress.totalArticles ?? progress.totalContentItems ?? NaN)
      : NaN;
    return {
      reindexJobId: String(job.reindex_job_id ?? ""),
      indexName: String(job.index_name ?? "—"),
      jobKind: String(job.job_kind ?? "rebuild"),
      status: String(job.status ?? "pending"),
      createdAt: job.created_at ? String(job.created_at) : null,
      createdAtLabel: job.created_at ? String(job.created_at) : null,
      processedArticles:
        Number.isFinite(processedArticles) ? processedArticles : null,
      totalArticles: Number.isFinite(totalArticles) ? totalArticles : null,
      progressLabel: readProgressLabel(job),
      selectionProfileSnapshot: readSelectionProfileSnapshot(job),
      selectionProfileSummary: readSelectionProfileSummary(job),
      revision: JSON.stringify([
        job.reindex_job_id,
        job.status,
        readProgressLabel(job),
        readSelectionProfileSnapshot(job),
        readSelectionProfileSummary(job),
        job.created_at,
      ]),
    };
  }),
};
---

<AdminShell
  title="Reindex — Admin"
  session={session}
  flash={flash}
  activeNav="reindex"
  liveUpdatesEndpoint={liveUpdatesEndpoint}
  liveUpdatesSurface="reindex"
>
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={pagePaths.dashboard} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">Reindex</span>
    </nav>
  </Fragment>

  <div class="space-y-6 max-w-6xl">
    <section class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">System</p>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight">Reindex</h1>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">
        Use this page when matching quality looks stale, a restore changed the data baseline,
        or you need to replay historical content against the current rule set. Reindexing is
        safe for stored content: it recalculates derived state and optional historical matches,
        but it does not delete rows or resend retro notifications.
      </p>
    </section>

    <section class="grid gap-4 xl:grid-cols-3">
      <article class="rounded-2xl border border-border bg-card p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Mode 1</p>
        <h2 class="mt-2 text-base font-semibold">Rebuild index only</h2>
        <p class="mt-2 text-sm text-muted-foreground">
          Refresh derived lookup structures such as interest centroids when relevance feels stale.
        </p>
        <p class="mt-3 text-xs text-muted-foreground">Use when the rules changed, but historical rows themselves do not need repair.</p>
      </article>
      <article class="rounded-2xl border border-amber-200 bg-amber-50/60 p-4 dark:border-amber-900/40 dark:bg-amber-950/20">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-700 dark:text-amber-300">Mode 2</p>
        <h2 class="mt-2 text-base font-semibold">Rebuild + repair existing content</h2>
        <p class="mt-2 text-sm text-muted-foreground">
          Rematch historical rows against the current system-interest set and the active
          compatibility selection-profile snapshot.
        </p>
        <p class="mt-3 text-xs text-muted-foreground">Use when already persisted content should reflect current matching policy.</p>
      </article>
      <article class="rounded-2xl border border-border bg-card p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Optional</p>
        <h2 class="mt-2 text-base font-semibold">Prepend enrichment replay</h2>
        <p class="mt-2 text-sm text-muted-foreground">
          Run editorial articles back through fetchers-owned enrichment before the repair path.
        </p>
        <p class="mt-3 text-xs text-muted-foreground">Keep force rerun off unless you intentionally want to revisit already enriched rows.</p>
      </article>
    </section>

    <section class="grid gap-6 xl:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)]">
      <div class="rounded-xl border border-border bg-card p-5">
        <div class="mb-4">
          <h2 class="font-semibold text-sm">Queue Reindex Job</h2>
          <p class="mt-1 text-xs text-muted-foreground">
            One primary action lives here: choose the safest mode for the job you actually need.
          </p>
        </div>
        <form method="post" action={reindexBffPath} class="grid gap-3">
          <input type="hidden" name="redirectTo" value={currentPath} />
          <div class="grid gap-1.5">
            <label class="text-sm font-medium" for="indexName">Index name</label>
            <select id="indexName" name="indexName"
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
              <option value="interest_centroids">interest_centroids</option>
            </select>
          </div>
          <div class="grid gap-1.5">
            <label class="text-sm font-medium" for="jobKind">Mode</label>
            <select id="jobKind" name="jobKind"
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
              <option value="rebuild">Rebuild index only</option>
              <option value="backfill">Rebuild + repair existing content</option>
            </select>
          </div>
          <p class="text-xs text-muted-foreground">
            Historical repair runs asynchronously, records the active compatibility profile
            snapshot used for replay, and intentionally skips retro notification delivery.
          </p>
          <label class="flex items-start gap-2 rounded-md border border-border/60 p-3">
            <input id="includeEnrichment" name="includeEnrichment" type="checkbox" value="true" class="mt-0.5 h-4 w-4 rounded border-input" />
            <span class="space-y-1">
              <span class="block text-sm font-medium">Also rerun fetchers-owned article enrichment</span>
              <span class="block text-xs text-muted-foreground">
                Only affects <strong>Rebuild + repair existing content</strong>. The repair replays editorial articles through enrichment before normalize/dedup/embed/match steps and still skips retro notifications.
              </span>
            </span>
          </label>
          <label class="flex items-start gap-2 rounded-md border border-border/60 p-3">
            <input id="forceEnrichment" name="forceEnrichment" type="checkbox" value="true" class="mt-0.5 h-4 w-4 rounded border-input" />
            <span class="space-y-1">
              <span class="block text-sm font-medium">Force rerun even already enriched articles</span>
              <span class="block text-xs text-muted-foreground">
                Leave this off for the normal repair path. Use it only when you intentionally want to rerun enrichment on rows that already have `enriched` state.
              </span>
            </span>
          </label>
          <AdminConfirmSubmitButton
            title="Queue maintenance job"
            description="Start an asynchronous rebuild job. Use rebuild-only for index refreshes, or backfill to repair historical matches. Enrichment replay still skips retro notifications."
            triggerLabel="Queue maintenance job"
            confirmLabel="Start job"
            client:load
          />
        </form>
      </div>

      <aside class="space-y-4">
        <div class="rounded-xl border border-amber-200 bg-amber-50/60 p-4 dark:border-amber-900/40 dark:bg-amber-950/20">
          <p class="text-sm font-medium">When should you reindex?</p>
          <ul class="mt-3 space-y-2 text-xs text-muted-foreground">
            <li>After meaningful changes to system interests or user interests.</li>
            <li>After a restore or repair that changed the effective data baseline.</li>
            <li>When matching quality looks stale but raw ingest still looks healthy.</li>
          </ul>
        </div>
        <div class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">What this job does not do</p>
          <ul class="mt-3 space-y-2 text-xs text-muted-foreground">
            <li>It does not delete historical content.</li>
            <li>It does not resend retro notifications.</li>
            <li>It does not change fetch cadence or source health configuration.</li>
          </ul>
        </div>
        <div class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">Next check after you queue it</p>
          <p class="mt-2 text-xs text-muted-foreground">
            Watch the live jobs section below for status, progress, and the exact selection-profile
            snapshot applied to the replay.
          </p>
        </div>
      </aside>
    </section>

    <LiveReindexJobsSection
      initialJobs={initialJobs}
      currentPage={page}
      currentPath={currentPath}
      client:load
    />
  </div>
</AdminShell>
