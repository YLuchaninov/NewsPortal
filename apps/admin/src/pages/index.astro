---
import { DEFAULT_BRAND_CONFIG, readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { AdminLiveCollectionNotice } from "../components/AdminLiveCollectionNotice";
import { LiveDashboardKpiGrid } from "../components/LiveDashboardKpiGrid";
import AdminShell from "../layouts/AdminShell.astro";
import { buildAdminLiveRevision } from "../lib/live-updates";
import { resolveAdminSession } from "../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../lib/server/browser-flow";

export const prerender = false;
const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const pagePaths = {
  channels: appPath("/channels"),
  channelNew: appPath("/channels/new"),
  articles: appPath("/articles"),
  clusters: appPath("/clusters"),
  llmTemplates: appPath("/templates/llm"),
  interestTemplates: appPath("/templates/interests"),
  userInterests: appPath("/user-interests"),
  observability: appPath("/observability"),
  reindex: appPath("/reindex"),
  help: appPath("/help"),
  discovery: appPath("/discovery"),
  resources: appPath("/resources"),
};

type R = Record<string, unknown>;
function asInt(v: unknown, fallback = 0): number {
  const parsed =
    typeof v === "number" && Number.isFinite(v)
      ? v
      : Number.parseInt(String(v ?? ""), 10);
  return Number.isFinite(parsed) ? parsed : fallback;
}

const [summary, fetchRuns] = session
  ? await Promise.all([
      sdk.getDashboardSummary<R>(),
      sdk.listFetchRunsPage<R>({ page: 1, pageSize: 8 }),
    ])
  : [null, null];

function formatTimestamp(v: unknown): string {
  if (!v) return "never";
  const d = new Date(String(v));
  return isNaN(d.getTime()) ? String(v) : d.toLocaleString("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" });
}
function asRecord(v: unknown): R { return v != null && typeof v === "object" && !Array.isArray(v) ? v as R : {}; }
function formatFetchRunDelta(run: R): string {
  const metrics = asRecord(run.provider_metrics_json);
  if (String(run.provider_type ?? "") === "website" && Object.keys(metrics).length > 0) {
    const staticAccepted = asInt(metrics.staticAcceptedCount, 0);
    const browserOnly = asInt(metrics.browserOnlyAcceptedCount, 0);
    const finalAccepted = asInt(metrics.finalAcceptedCount, 0);
    return `${staticAccepted} static / +${browserOnly} browser / ${finalAccepted} final`;
  }
  return `+${String(run.new_article_count ?? 0)} new`;
}

const kpiCards = !summary ? [] : [
  { label: "System-selected content", value: String(summary.active_news ?? 0), color: "text-emerald-500" },
  { label: "Processed 24h", value: String(summary.processed_today ?? 0), color: "text-blue-500" },
  { label: "Total Users", value: String(summary.total_users ?? 0), color: "text-violet-500" },
  { label: "Overdue Channels", value: String(summary.overdue_channels ?? 0), color: (summary.overdue_channels as number) > 0 ? "text-amber-500" : "text-muted-foreground" },
  { label: "Fetch Failures 24h", value: String(summary.fetch_failures_24h ?? 0), color: (summary.fetch_failures_24h as number) > 0 ? "text-red-500" : "text-muted-foreground" },
  { label: "LLM Reviews 24h", value: String(summary.llm_review_count_24h ?? 0), color: "text-primary" },
  {
    label:
      summary.llm_review_enabled === true && summary.llm_monthly_quota_reached === true
        ? `LLM Budget · ${summary.llm_accept_gray_zone_on_budget_exhaustion === true ? "Accept" : "Reject"}`
        : "LLM Budget",
    value:
      summary.llm_review_enabled !== true
        ? "Disabled"
        : Number(summary.llm_monthly_budget_cents ?? 0) <= 0
        ? "Cap off"
        : summary.llm_monthly_quota_reached === true
        ? "Exhausted"
        : `${String(summary.llm_remaining_monthly_budget_cents ?? 0)}¢ left`,
    color:
      summary.llm_review_enabled !== true
        ? "text-muted-foreground"
        : summary.llm_monthly_quota_reached === true
        ? "text-amber-500"
        : "text-emerald-500",
  },
  { label: "New Content 24h", value: String(summary.fetch_new_content_24h ?? 0), color: "text-cyan-500" },
  { label: "Needs Attention", value: String(summary.attention_channels ?? 0), color: (summary.attention_channels as number) > 0 ? "text-amber-500" : "text-muted-foreground" },
];
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;
const liveUpdatesEndpoint = `${appPath("/bff/admin/live-updates")}?surface=dashboard`;
const initialDashboardSummary = !summary
  ? null
  : {
      activeNews: asInt(summary.active_news, 0),
      processedToday: asInt(summary.processed_today, 0),
      totalUsers: asInt(summary.total_users, 0),
      overdueChannels: asInt(summary.overdue_channels, 0),
      fetchFailures24h: asInt(summary.fetch_failures_24h, 0),
      llmReviewCount24h: asInt(summary.llm_review_count_24h, 0),
      newContent24h: asInt(summary.fetch_new_content_24h, 0),
      attentionChannels: asInt(summary.attention_channels, 0),
      queuedReindexJobs: asInt(summary.queued_reindex_jobs, 0),
      runningReindexJobs: 0,
      llmBudgetEnabled: summary.llm_review_enabled === true,
      llmMonthlyBudgetCents: asInt(summary.llm_monthly_budget_cents, 0),
      llmMonthToDateCostCents: asInt(summary.llm_month_to_date_cost_cents, 0),
      llmRemainingMonthlyBudgetCents:
        summary.llm_remaining_monthly_budget_cents == null
          ? null
          : asInt(summary.llm_remaining_monthly_budget_cents, 0),
      llmMonthlyQuotaReached: summary.llm_monthly_quota_reached === true,
      llmAcceptGrayZoneOnBudgetExhaustion:
        summary.llm_accept_gray_zone_on_budget_exhaustion === true,
      revision: buildAdminLiveRevision([
        summary.active_news,
        summary.processed_today,
        summary.total_users,
        summary.overdue_channels,
        summary.fetch_failures_24h,
        summary.llm_review_count_24h,
        summary.fetch_new_content_24h,
        summary.attention_channels,
        summary.queued_reindex_jobs,
        summary.llm_review_enabled,
        summary.llm_monthly_budget_cents,
        summary.llm_month_to_date_cost_cents,
        summary.llm_remaining_monthly_budget_cents,
        summary.llm_monthly_quota_reached,
        summary.llm_accept_gray_zone_on_budget_exhaustion,
      ]),
    };
const fetchRunsRevision = buildAdminLiveRevision([
  fetchRuns?.total ?? 0,
  fetchRuns?.items[0]?.channel_id ?? "",
  fetchRuns?.items[0]?.started_at ?? "",
  fetchRuns?.items[0]?.outcome_kind ?? "",
  fetchRuns?.items[0]?.new_article_count ?? "",
]);
---

<AdminShell
  title={`Dashboard — ${DEFAULT_BRAND_CONFIG.productName} Admin`}
  session={session}
  flash={flash}
  activeNav="dashboard"
  liveUpdatesEndpoint={liveUpdatesEndpoint}
  liveUpdatesSurface="dashboard"
>
  <Fragment slot="header-title">
    <h1 class="text-sm font-semibold text-foreground">Dashboard</h1>
  </Fragment>

  <div class="space-y-6">
      <!-- KPI grid -->
      {initialDashboardSummary ? (
        <LiveDashboardKpiGrid initialSummary={initialDashboardSummary} client:load />
      ) : (
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {kpiCards.map(({ label, value, color }) => (
            <div class="rounded-xl border border-border bg-card p-4">
              <p class="text-xs text-muted-foreground mb-1">{label}</p>
              <p class={`text-2xl font-bold ${color}`}>{value}</p>
            </div>
          ))}
        </div>
      )}

      <!-- Quick navigation -->
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5 xl:grid-cols-10">
        {[
          { href: pagePaths.channels, label: "Channels", desc: "Monitor source health" },
          { href: pagePaths.resources, label: "Resources", desc: "Inspect website resource rows" },
          { href: pagePaths.channelNew, label: "Add Channel", desc: "Create a new source channel" },
          { href: pagePaths.discovery, label: "Discovery", desc: "Approve AI-found sources" },
          { href: pagePaths.articles, label: "Articles", desc: "Moderate content" },
          { href: pagePaths.clusters, label: "Clusters", desc: "Event clusters" },
          { href: pagePaths.llmTemplates, label: "LLM Templates", desc: "Gray-zone prompts" },
          { href: pagePaths.interestTemplates, label: "System Interests", desc: "Global selection rules" },
          { href: pagePaths.userInterests, label: "User Interests", desc: "Per-user matching" },
          { href: pagePaths.observability, label: "Observability", desc: "Fetch & LLM logs" },
          { href: pagePaths.reindex, label: "Reindex", desc: "Rebuild indices" },
          { href: pagePaths.help, label: "Help", desc: "Setup guide" },
        ].map(({ href, label, desc }) => (
          <a href={href} class="rounded-xl border border-border bg-card p-4 hover:bg-accent hover:border-primary/20 transition-all group">
            <p class="font-medium text-sm group-hover:text-primary transition-colors">{label}</p>
            <p class="text-xs text-muted-foreground mt-0.5">{desc}</p>
          </a>
        ))}
      </div>

      <!-- Recent Fetch Runs -->
      <div class="rounded-xl border border-border bg-card overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-border">
          <div>
            <h2 class="font-semibold text-sm">Recent Fetch Runs</h2>
            {fetchRuns && fetchRuns.total > 0 && (
              <AdminLiveCollectionNotice
                surface="dashboard"
                collection="fetchRuns"
                initialTotal={fetchRuns.total}
                initialRevision={fetchRunsRevision}
                visibleCount={fetchRuns.items.length}
                refreshHref={currentPath}
                updateMessage="New fetch runs are available"
                client:load
              />
            )}
          </div>
          <a href={pagePaths.observability} class="text-xs text-primary hover:underline">View all →</a>
        </div>
        {!fetchRuns || fetchRuns.total === 0 ? (
          <p class="px-4 py-6 text-sm text-muted-foreground text-center">No fetch runs yet</p>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-border">
                  <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Channel</th>
                  <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Outcome</th>
                  <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground hidden sm:table-cell">Counts</th>
                  <th class="px-4 py-2.5 text-left text-xs font-medium text-muted-foreground">Time</th>
                </tr>
              </thead>
              <tbody>
                {fetchRuns.items.map((run) => (
                  <tr class="border-b border-border last:border-0 hover:bg-muted/30 transition-colors">
                    <td class="px-4 py-2.5">
                      <div class="font-medium text-xs truncate max-w-[120px]">{String(run.channel_name ?? run.channel_id ?? "—")}</div>
                      <div class="text-[10px] text-muted-foreground">{String(run.provider_type ?? "—")}</div>
                    </td>
                    <td class="px-4 py-2.5">
                      <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ${
                        String(run.outcome_kind) === "new_content"
                          ? "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300"
                          : String(run.outcome_kind) === "error"
                          ? "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300"
                          : "bg-muted text-muted-foreground"
                      }`}>
                        {String(run.outcome_kind ?? "—")}
                      </span>
                    </td>
                    <td class="px-4 py-2.5 hidden sm:table-cell text-xs text-muted-foreground">{formatFetchRunDelta(run)}</td>
                    <td class="px-4 py-2.5 text-xs text-muted-foreground">
                      {formatTimestamp(run.started_at)}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
  </div>
</AdminShell>
