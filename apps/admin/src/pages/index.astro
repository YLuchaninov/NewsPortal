---
import { DEFAULT_BRAND_CONFIG, readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { APP_SHELL_STYLES } from "@newsportal/ui";

import { resolveAdminSession } from "../lib/server/auth";

export const prerender = false;
const runtimeConfig = readRuntimeConfig(import.meta.env);
const session = await resolveAdminSession(Astro.request);
const sdk = createNewsPortalSdk({
  baseUrl: runtimeConfig.apiBaseUrl,
  fetchImpl: fetch
});

const [summary, channels, clusters, articles, reindexJobs, llmTemplates, interestTemplates] =
  session
    ? await Promise.all([
        sdk.getDashboardSummary<Record<string, unknown>>(),
        sdk.listChannels<Array<Record<string, unknown>>>(),
        sdk.listClusters<Array<Record<string, unknown>>>(),
        sdk.listArticles<Array<Record<string, unknown>>>(),
        sdk.listReindexJobs<Array<Record<string, unknown>>>(),
        sdk.listLlmTemplates<Array<Record<string, unknown>>>(),
        sdk.listInterestTemplates<Array<Record<string, unknown>>>()
      ])
    : [null, [], [], [], [], [], []];
const adminReindexJobs = reindexJobs as Array<Record<string, unknown>>;

function asRecord(value: unknown): Record<string, unknown> {
  return value != null && typeof value === "object" && !Array.isArray(value)
    ? (value as Record<string, unknown>)
    : {};
}

function asPositiveInteger(value: unknown, fallback: number): number {
  const parsed =
    typeof value === "number" && Number.isInteger(value) ? value : Number.parseInt(String(value ?? ""), 10);
  return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;
}

function asBooleanString(value: boolean): string {
  return value ? "true" : "false";
}

function formatTimestamp(value: unknown): string {
  if (!value) {
    return "never";
  }

  const parsed = new Date(String(value));
  return Number.isNaN(parsed.getTime()) ? String(value) : parsed.toLocaleString("en-US");
}

const rssChannels = (channels as Array<Record<string, unknown>>)
  .filter((channel) => String(channel.provider_type ?? "") === "rss")
  .map((channel) => {
    const config = asRecord(channel.config_json);

    return {
      channelId: String(channel.channel_id ?? ""),
      name: String(channel.name ?? ""),
      fetchUrl: String(channel.fetch_url ?? ""),
      language: String(channel.language ?? "en"),
      isActive: channel.is_active === true,
      pollIntervalSeconds: asPositiveInteger(channel.poll_interval_seconds, 300),
      maxItemsPerPoll: asPositiveInteger(config.maxItemsPerPoll, 20),
      requestTimeoutMs: asPositiveInteger(config.requestTimeoutMs, 10000),
      userAgent: String(config.userAgent ?? "NewsPortalFetchers/0.1 (+https://newsportal.local)"),
      preferContentEncoded: config.preferContentEncoded !== false,
      lastFetchAt: formatTimestamp(channel.last_fetch_at),
      lastSuccessAt: formatTimestamp(channel.last_success_at),
      lastErrorAt: formatTimestamp(channel.last_error_at),
      lastErrorMessage: String(channel.last_error_message ?? "")
    };
  });

const bulkRssPlaceholder = JSON.stringify(
  [
    {
      name: "Reuters World RSS",
      fetchUrl: "https://example.com/world.xml",
      language: "en",
      pollIntervalSeconds: 300,
      maxItemsPerPoll: 25,
      requestTimeoutMs: 4000,
      userAgent: "NewsPortalFetchers/admin-import",
      preferContentEncoded: true,
      isActive: true
    },
    {
      name: "EU Policy RSS",
      fetchUrl: "https://example.com/eu.xml",
      language: "en",
      pollIntervalSeconds: 600,
      maxItemsPerPoll: 15,
      requestTimeoutMs: 3000,
      userAgent: "NewsPortalFetchers/admin-import",
      preferContentEncoded: false,
      isActive: true
    }
  ],
  null,
  2
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{DEFAULT_BRAND_CONFIG.productName} Admin MVP</title>
    <style is:global set:html={APP_SHELL_STYLES}></style>
  </head>
  <body>
    <main>
      <div class="np-shell">
        <section class="np-card" style={`background:${DEFAULT_BRAND_CONFIG.backgroundGradient};`}>
          <p class="np-subtle">Operational console</p>
          <h1 class="np-heading">{DEFAULT_BRAND_CONFIG.productName} Admin</h1>
          {
            session ? (
              <div>
                <span class="np-pill">admin userId: {session.userId}</span>
                <span class="np-pill">roles: {session.roles.join(", ") || "none"}</span>
                <form method="post" action="/api/auth/logout" style="margin-top: 16px;">
                  <button type="submit" class="np-button secondary">Sign Out</button>
                </form>
              </div>
            ) : (
              <form method="post" action="/api/auth/sign-in" class="np-card">
                <label>
                  Admin email
                  <input name="email" type="email" placeholder="admin@example.com" />
                </label>
                <label>
                  Password
                  <input name="password" type="password" />
                </label>
                <input type="submit" value="Sign In with Firebase" />
                <p class="np-subtle">
                  Allowlisted emails from `ADMIN_ALLOWLIST_EMAILS` receive the local `admin` role on
                  first successful Firebase sign-in; PostgreSQL remains the authorization source of truth.
                </p>
              </form>
            )
          }
        </section>

        {
          session ? (
            <>
              <section class="np-grid two">
                <article class="np-card">
                  <h2>KPI</h2>
                  <div class="np-grid two">
                    <div><strong>{String(summary?.active_news ?? 0)}</strong><br />Active news</div>
                    <div><strong>{String(summary?.processed_total ?? 0)}</strong><br />Processed total</div>
                    <div><strong>{String(summary?.processed_today ?? 0)}</strong><br />Processed today</div>
                    <div><strong>{String(summary?.total_users ?? 0)}</strong><br />Total users</div>
                  </div>
                </article>

                <article class="np-card">
                  <h2>Reindex</h2>
                  <form method="post" action="/api/admin/reindex">
                    <label>
                      Index name
                      <select name="indexName">
                        <option value="interest_centroids">interest_centroids</option>
                      </select>
                    </label>
                    <input type="submit" value="Queue Reindex" />
                  </form>
                  <div style="margin-top: 16px;">
                    {adminReindexJobs.map((job) => (
                      <div class="np-pill">
                        {String(job.index_name)}: {String(job.status)}
                      </div>
                    ))}
                  </div>
                </article>
              </section>

              <section class="np-grid two">
                <article class="np-card">
                  <h2>Channels</h2>
                  <form method="post" action="/api/admin/channels">
                    <input type="hidden" name="providerType" value="rss" />
                    <label>
                      RSS channel name
                      <input name="name" placeholder="Reuters World RSS" />
                    </label>
                    <label>
                      RSS feed URL
                      <input name="fetchUrl" placeholder="https://example.com/feed.xml" />
                    </label>
                    <label>
                      Language
                      <input name="language" value="en" />
                    </label>
                    <label>
                      Poll interval (seconds)
                      <input name="pollIntervalSeconds" value="300" inputmode="numeric" />
                    </label>
                    <label>
                      Max items per poll
                      <input name="maxItemsPerPoll" value="20" inputmode="numeric" />
                    </label>
                    <label>
                      Request timeout (ms)
                      <input name="requestTimeoutMs" value="10000" inputmode="numeric" />
                    </label>
                    <label>
                      User agent
                      <input name="userAgent" value="NewsPortalFetchers/admin" />
                    </label>
                    <label>
                      Prefer `content:encoded`
                      <select name="preferContentEncoded">
                        <option value="true">true</option>
                        <option value="false">false</option>
                      </select>
                    </label>
                    <label>
                      Active
                      <select name="isActive">
                        <option value="true">active</option>
                        <option value="false">paused</option>
                      </select>
                    </label>
                    <input type="submit" value="Create RSS Channel" />
                  </form>
                  <form method="post" action="/api/admin/channels/bulk" style="margin-top: 18px;">
                    <label>
                      Bulk RSS import JSON
                      <textarea
                        name="channelsJson"
                        rows="14"
                        placeholder={bulkRssPlaceholder}
                      ></textarea>
                    </label>
                    <input type="submit" value="Import RSS Channels" />
                  </form>
                  <p class="np-subtle" style="margin-top: 12px;">
                    Internal MVP acceptance uses an RSS-first ingest surface. Website/API/IMAP channel
                    onboarding stays outside this admin flow until it has dedicated proof.
                  </p>
                  <p class="np-subtle">
                    Visible RSS channels: {rssChannels.length}. Bulk payload accepts the same RSS
                    fields as the single-channel form and rejects partially invalid rows.
                  </p>
                  <table class="np-table" style="margin-top: 18px;">
                    <thead>
                      <tr>
                        <th>Name</th>
                        <th>Fetch</th>
                        <th>Schedule</th>
                        <th>Status</th>
                        <th>Last Success</th>
                        <th>Last Error</th>
                        <th>Controls</th>
                      </tr>
                    </thead>
                    <tbody>
                      {rssChannels.map((channel) => (
                        <tr>
                          <td>
                            <div>{channel.name}</div>
                            <div class="np-subtle">rss / {channel.language || "-"}</div>
                          </td>
                          <td>
                            <div>{channel.fetchUrl}</div>
                            <div class="np-subtle">last fetch: {channel.lastFetchAt}</div>
                          </td>
                          <td>
                            <div>{channel.pollIntervalSeconds}s / {channel.maxItemsPerPoll} items</div>
                            <div class="np-subtle">
                              timeout: {channel.requestTimeoutMs}ms | content:encoded: {String(channel.preferContentEncoded)}
                            </div>
                          </td>
                          <td>{channel.isActive ? "active" : "paused"}</td>
                          <td>{channel.lastSuccessAt}</td>
                          <td>
                            <div>{channel.lastErrorAt}</div>
                            <div class="np-subtle">{channel.lastErrorMessage || "none"}</div>
                          </td>
                          <td>
                            <form method="post" action="/api/admin/channels" style="margin-bottom: 12px;">
                              <input type="hidden" name="channelId" value={channel.channelId} />
                              <input type="hidden" name="providerType" value="rss" />
                              <input type="hidden" name="name" value={channel.name} />
                              <input type="hidden" name="fetchUrl" value={channel.fetchUrl} />
                              <input type="hidden" name="language" value={channel.language} />
                              <input type="hidden" name="pollIntervalSeconds" value={String(channel.pollIntervalSeconds)} />
                              <input type="hidden" name="maxItemsPerPoll" value={String(channel.maxItemsPerPoll)} />
                              <input type="hidden" name="requestTimeoutMs" value={String(channel.requestTimeoutMs)} />
                              <input type="hidden" name="userAgent" value={channel.userAgent} />
                              <input
                                type="hidden"
                                name="preferContentEncoded"
                                value={asBooleanString(channel.preferContentEncoded)}
                              />
                              <input
                                type="hidden"
                                name="isActive"
                                value={asBooleanString(!channel.isActive)}
                              />
                              <button type="submit" class="np-button secondary">
                                {channel.isActive ? "Pause" : "Resume"}
                              </button>
                            </form>
                            <details>
                              <summary>Edit</summary>
                              <form method="post" action="/api/admin/channels" style="margin-top: 12px;">
                                <input type="hidden" name="channelId" value={channel.channelId} />
                                <input type="hidden" name="providerType" value="rss" />
                                <label>
                                  Name
                                  <input name="name" value={channel.name} />
                                </label>
                                <label>
                                  Feed URL
                                  <input name="fetchUrl" value={channel.fetchUrl} />
                                </label>
                                <label>
                                  Language
                                  <input name="language" value={channel.language} />
                                </label>
                                <label>
                                  Poll interval (seconds)
                                  <input
                                    name="pollIntervalSeconds"
                                    value={String(channel.pollIntervalSeconds)}
                                    inputmode="numeric"
                                  />
                                </label>
                                <label>
                                  Max items per poll
                                  <input
                                    name="maxItemsPerPoll"
                                    value={String(channel.maxItemsPerPoll)}
                                    inputmode="numeric"
                                  />
                                </label>
                                <label>
                                  Request timeout (ms)
                                  <input
                                    name="requestTimeoutMs"
                                    value={String(channel.requestTimeoutMs)}
                                    inputmode="numeric"
                                  />
                                </label>
                                <label>
                                  User agent
                                  <input name="userAgent" value={channel.userAgent} />
                                </label>
                                <label>
                                  Prefer `content:encoded`
                                  <select name="preferContentEncoded">
                                    <option value="true" selected={channel.preferContentEncoded}>true</option>
                                    <option value="false" selected={!channel.preferContentEncoded}>false</option>
                                  </select>
                                </label>
                                <label>
                                  Active
                                  <select name="isActive">
                                    <option value="true" selected={channel.isActive}>active</option>
                                    <option value="false" selected={!channel.isActive}>paused</option>
                                  </select>
                                </label>
                                <button type="submit" class="np-button secondary">Save RSS Settings</button>
                              </form>
                            </details>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </article>

                <article class="np-card">
                  <h2>Prompt & Interest Templates</h2>
                  <form method="post" action="/api/admin/templates">
                    <input type="hidden" name="kind" value="llm" />
                    <label>
                      Template name
                      <input name="name" placeholder="Gray zone review" />
                    </label>
                    <label>
                      Scope
                      <select name="scope">
                        <option value="interests">interests</option>
                        <option value="criteria">criteria</option>
                        <option value="global">global</option>
                      </select>
                    </label>
                    <label>
                      Template text
                      <textarea
                        name="templateText"
                        rows="6"
                        placeholder='Return JSON {"decision":"approve|reject|uncertain","score":0.0,"reason":"..."}'
                      ></textarea>
                    </label>
                    <input type="submit" value="Save LLM Template" />
                  </form>
                  <form method="post" action="/api/admin/templates" style="margin-top: 18px;">
                    <input type="hidden" name="kind" value="interest" />
                    <label>
                      Interest template name
                      <input name="name" placeholder="AI policy" />
                    </label>
                    <label>
                      Description
                      <textarea name="description" rows="3"></textarea>
                    </label>
                    <label>
                      Positive prototypes
                      <textarea name="positive_texts" rows="3"></textarea>
                    </label>
                    <label>
                      Negative prototypes
                      <textarea name="negative_texts" rows="3"></textarea>
                    </label>
                    <input type="submit" value="Save Interest Template" />
                  </form>
                  <p class="np-subtle" style="margin-top: 16px;">
                    Active LLM templates: {llmTemplates.length} | active interest templates: {interestTemplates.length}
                  </p>
                </article>
              </section>

              <section class="np-grid two">
                <article class="np-card">
                  <h2>Recent Articles</h2>
                  <table class="np-table">
                    <thead>
                      <tr>
                        <th>Title</th>
                        <th>State</th>
                        <th>Moderation</th>
                      </tr>
                    </thead>
                    <tbody>
                      {articles.slice(0, 10).map((article) => (
                        <tr>
                          <td>
                            <div>{String(article.title)}</div>
                            <div class="np-subtle">{String(article.lead ?? "")}</div>
                          </td>
                          <td>{String(article.processing_state)}</td>
                          <td>
                            <div class="np-grid two">
                              <form method="post" action="/api/admin/moderation">
                                <input type="hidden" name="docId" value={String(article.doc_id)} />
                                <input type="hidden" name="actionType" value="block" />
                                <button type="submit" class="np-button secondary">Block</button>
                              </form>
                              <form method="post" action="/api/admin/moderation">
                                <input type="hidden" name="docId" value={String(article.doc_id)} />
                                <input type="hidden" name="actionType" value="unblock" />
                                <button type="submit" class="np-button secondary">Unblock</button>
                              </form>
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </article>

                <article class="np-card">
                  <h2>Clusters</h2>
                  <table class="np-table">
                    <thead>
                      <tr>
                        <th>Cluster</th>
                        <th>Articles</th>
                        <th>Places</th>
                      </tr>
                    </thead>
                    <tbody>
                      {clusters.map((cluster) => (
                        <tr>
                          <td>{String(cluster.primary_title ?? cluster.cluster_id)}</td>
                          <td>{String(cluster.article_count ?? 0)}</td>
                          <td>{Array.isArray(cluster.top_places) ? cluster.top_places.join(", ") : ""}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </article>
              </section>
            </>
          ) : null
        }
      </div>
    </main>
  </body>
</html>
