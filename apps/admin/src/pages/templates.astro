---
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import { readFlash } from "../lib/server/browser-flow";

export const prerender = false;
const runtimeConfig = readRuntimeConfig(process.env, { defaultAppBaseUrl: "http://127.0.0.1:4322/" });
const session = await resolveAdminSession(Astro.request);
if (!session) return Astro.redirect("/");

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });

const fp = (() => {
  const v = String(Astro.request.headers.get("x-forwarded-prefix") ?? "").trim();
  return (!v || v === "/") ? "" : `/${v.replace(/^\/+|\/+$/g, "")}`;
})();
const pb = fp ? `${fp}/` : (Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`);
const rpa = (t: string) => new URL(String(t).replace(/^\/+/, ""), `http://app${pb}`).pathname;
const bffPaths = { templates: rpa("bff/admin/templates") };

type R = Record<string, unknown>;
const [llmTemplates, interestTemplates] = await Promise.all([
  sdk.listLlmTemplates<R[]>(),
  sdk.listInterestTemplates<R[]>(),
]);
---

<AdminShell title="Templates — Admin" session={session} flash={flash} activeNav="templates">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">Templates</span>
    </nav>
  </Fragment>

  <div class="space-y-6">
    <div>
      <h1 class="text-xl font-bold">Templates</h1>
      <p class="text-sm text-muted-foreground mt-0.5">LLM prompts and interest templates</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <!-- LLM Templates -->
      <div class="space-y-4">
        <div class="rounded-xl border border-border bg-card p-4">
          <h2 class="font-semibold text-sm mb-3">Create LLM Template</h2>
          <form method="post" action={bffPaths.templates} class="grid gap-2">
            <input type="hidden" name="kind" value="llm" />
            <div class="grid gap-1">
              <label class="text-xs font-medium">Template name</label>
              <input name="name" placeholder="Gray zone review"
                class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </div>
            <div class="grid gap-1">
              <label class="text-xs font-medium">Scope</label>
              <select name="scope" class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring">
                <option value="interests">interests</option>
                <option value="criteria">criteria</option>
                <option value="global">global</option>
              </select>
            </div>
            <div class="grid gap-1">
              <label class="text-xs font-medium">Template text</label>
              <textarea name="templateText" rows={6}
                placeholder={`Return JSON {"decision":"approve|reject|uncertain","score":0.0,"reason":"..."}`}
                class="flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-xs shadow-sm font-mono placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </div>
            <button type="submit" class="h-8 rounded-md bg-primary text-primary-foreground text-xs font-medium hover:bg-primary/90 transition-colors">
              Save LLM Template
            </button>
          </form>
        </div>

        <div class="rounded-xl border border-border bg-card overflow-hidden">
          <div class="px-4 py-3 border-b border-border">
            <p class="text-sm font-semibold">LLM Templates ({(llmTemplates as R[]).length})</p>
          </div>
          {(llmTemplates as R[]).length === 0 ? (
            <p class="px-4 py-4 text-xs text-muted-foreground text-center">No LLM templates yet</p>
          ) : (
            <div class="divide-y divide-border">
              {(llmTemplates as R[]).map((t) => (
                <div class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <p class="text-xs font-medium">{String(t.name ?? "Unnamed")}</p>
                    <span class="inline-flex items-center rounded-full px-1.5 py-0.5 text-[10px] font-medium bg-muted text-muted-foreground">{String(t.scope ?? "—")}</span>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- Interest Templates -->
      <div class="space-y-4">
        <div class="rounded-xl border border-border bg-card p-4">
          <h2 class="font-semibold text-sm mb-3">Create Interest Template</h2>
          <form method="post" action={bffPaths.templates} class="grid gap-2">
            <input type="hidden" name="kind" value="interest" />
            <div class="grid gap-1">
              <label class="text-xs font-medium">Template name</label>
              <input name="name" placeholder="AI policy"
                class="flex h-8 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </div>
            <div class="grid gap-1">
              <label class="text-xs font-medium">Description</label>
              <textarea name="description" rows={2}
                class="flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </div>
            <div class="grid gap-1">
              <label class="text-xs font-medium">Positive prototypes</label>
              <textarea name="positive_texts" rows={3}
                class="flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </div>
            <div class="grid gap-1">
              <label class="text-xs font-medium">Negative prototypes</label>
              <textarea name="negative_texts" rows={2}
                class="flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-xs shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </div>
            <button type="submit" class="h-8 rounded-md bg-primary text-primary-foreground text-xs font-medium hover:bg-primary/90 transition-colors">
              Save Interest Template
            </button>
          </form>
        </div>

        <div class="rounded-xl border border-border bg-card overflow-hidden">
          <div class="px-4 py-3 border-b border-border">
            <p class="text-sm font-semibold">Interest Templates ({(interestTemplates as R[]).length})</p>
          </div>
          {(interestTemplates as R[]).length === 0 ? (
            <p class="px-4 py-4 text-xs text-muted-foreground text-center">No interest templates yet</p>
          ) : (
            <div class="divide-y divide-border">
              {(interestTemplates as R[]).map((t) => (
                <div class="px-4 py-3">
                  <p class="text-xs font-medium">{String(t.name ?? "Unnamed")}</p>
                  {t.description && <p class="text-[10px] text-muted-foreground mt-0.5 line-clamp-1">{String(t.description)}</p>}
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</AdminShell>

