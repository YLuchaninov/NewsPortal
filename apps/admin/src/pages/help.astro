---
import { DEFAULT_BRAND_CONFIG } from "@newsportal/config";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../lib/server/browser-flow";

export const prerender = false;
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const pagePaths = {
  dashboard: appPath("/"),
  discovery: appPath("/discovery"),
  channels: appPath("/channels"),
  llmTemplates: appPath("/templates/llm"),
  interestTemplates: appPath("/templates/interests"),
  articles: appPath("/articles"),
  clusters: appPath("/clusters"),
  reindex: appPath("/reindex"),
  observability: appPath("/observability"),
};
---

<AdminShell title={`Help — ${DEFAULT_BRAND_CONFIG.productName} Admin`} session={session} flash={flash} activeNav="help">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={pagePaths.dashboard} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">Help</span>
    </nav>
  </Fragment>

  <div class="max-w-6xl space-y-8">
    <section class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Help</p>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight">Admin Guide</h1>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-muted-foreground">
        Use this page as an operator playbook. Start from the job you need to finish, then jump
        into the right surface instead of reading the entire product manual front to back.
      </p>
      <div class="mt-5 grid gap-3 md:grid-cols-3">
        <a href={pagePaths.channels} class="rounded-2xl border border-border bg-background/70 p-4 transition hover:border-primary/40 hover:bg-muted/40">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Sources</p>
          <p class="mt-2 text-base font-semibold">Find and fix a source issue</p>
          <p class="mt-2 text-sm text-muted-foreground">Start in Channels or Observability when fetches fail, cadence looks stale, or onboarding needs a safe path.</p>
        </a>
        <a href={pagePaths.articles} class="rounded-2xl border border-border bg-background/70 p-4 transition hover:border-primary/40 hover:bg-muted/40">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Operations</p>
          <p class="mt-2 text-base font-semibold">Triage content and decisions</p>
          <p class="mt-2 text-sm text-muted-foreground">Use Articles and Clusters when an operator needs to inspect canonical state, moderation, or verification context.</p>
        </a>
        <a href={pagePaths.reindex} class="rounded-2xl border border-border bg-background/70 p-4 transition hover:border-primary/40 hover:bg-muted/40">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Maintenance</p>
          <p class="mt-2 text-base font-semibold">Replay or repair system state</p>
          <p class="mt-2 text-sm text-muted-foreground">Use Reindex or Automation when the data baseline changed and you need controlled maintenance with visible consequences.</p>
        </a>
      </div>
    </section>

    <nav class="rounded-xl border border-border bg-card p-4">
      <p class="text-sm font-semibold mb-2">Jump to</p>
      <ul class="grid gap-1 sm:grid-cols-3 text-sm">
        <li><a href="#overview" class="text-primary hover:underline">System Overview</a></li>
        <li><a href="#discovery" class="text-primary hover:underline">Discovery Control Plane</a></li>
        <li><a href="#operations" class="text-primary hover:underline">Operational Playbooks</a></li>
        <li><a href="#rules" class="text-primary hover:underline">Rules &amp; AI Review</a></li>
        <li><a href="#reindex" class="text-primary hover:underline">Reindex &amp; Maintenance</a></li>
        <li><a href="#observability" class="text-primary hover:underline">Observability &amp; Costs</a></li>
      </ul>
    </nav>

    <section id="overview" class="space-y-3">
      <h2 class="text-lg font-bold border-b border-border pb-2">System Overview</h2>
      <p class="text-sm text-muted-foreground">
        {DEFAULT_BRAND_CONFIG.productName} remains a zero-shot acquisition, filtering, and notification system. The operator model is `acquire -&gt; normalize -&gt; canonicalize -&gt; cluster/verify -&gt; interest filter -&gt; final select`, and the UI is now split so each surface owns one clearer job in that path.
      </p>
      <div class="grid gap-3 md:grid-cols-3">
        <article class="rounded-xl border border-border bg-card p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Acquire</p>
          <p class="mt-2 text-sm font-medium">Channels, Resources, Discovery</p>
          <p class="mt-2 text-xs text-muted-foreground">Bring sources in, inspect source quality, and separate mission fit from generic recall quality before content enters the editorial pipeline.</p>
        </article>
        <article class="rounded-xl border border-border bg-card p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Decide</p>
          <p class="mt-2 text-sm font-medium">Articles, Clusters, Rules</p>
          <p class="mt-2 text-xs text-muted-foreground">Inspect canonical evidence, verification strength, moderation state, and the rules that shape system or user matching.</p>
        </article>
        <article class="rounded-xl border border-border bg-card p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Maintain</p>
          <p class="mt-2 text-sm font-medium">Observability, Reindex, Automation</p>
          <p class="mt-2 text-xs text-muted-foreground">Monitor fetch health and budgets, queue bounded repair work, and tune recurring maintenance workflows without mixing those jobs into content triage.</p>
        </article>
      </div>
    </section>

    <section id="discovery" class="space-y-3">
      <h2 class="text-lg font-bold border-b border-border pb-2">Discovery Control Plane</h2>
      <p class="text-sm text-muted-foreground">
        <a href={pagePaths.discovery} class="text-primary hover:underline">Discovery</a> is a dual-path operator surface. Graph-first missions own mission planning, hypotheses, and portfolio fit, while recall owns neutral acquisition backlog, source-quality snapshots, and bounded promotion into normal channels.
      </p>
      <div class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_minmax(280px,0.9fr)]">
        <div class="rounded-xl border border-border bg-card p-4">
          <p class="text-xs font-semibold">Debug order</p>
          <ol class="mt-3 list-decimal list-inside space-y-2 text-xs text-muted-foreground">
            <li>Check mission fit or recall quality before changing downstream rules.</li>
            <li>Read generic source quality separately from system-selected outcomes.</li>
            <li>Only promote a discovery result once the source quality looks durable enough for normal channel operations.</li>
          </ol>
        </div>
        <div class="rounded-xl border border-border bg-card p-4">
          <p class="text-xs font-semibold">What not to conflate</p>
          <ul class="mt-3 space-y-2 text-xs text-muted-foreground">
            <li><strong>Mission fit</strong> is not the same thing as final zero-shot filtering.</li>
            <li><strong>Generic source quality</strong> should be debugged before tightening interests.</li>
            <li><strong>Recall promotion</strong> should not be used as a shortcut for normal source onboarding.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="operations" class="space-y-3">
      <h2 class="text-lg font-bold border-b border-border pb-2">Operational Playbooks</h2>
      <div class="grid gap-3 md:grid-cols-2">
        <article id="channels" class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">Channels &amp; Source Onboarding</p>
          <p class="mt-2 text-xs text-muted-foreground">
            Use <a href={pagePaths.channels} class="text-primary hover:underline">Channels</a> for normal source operations. RSS stays the fastest editorial path; website channels keep generic discovery semantics for collections, entities, documents, and hidden feeds.
          </p>
          <ul class="mt-3 space-y-2 text-xs text-muted-foreground">
            <li>Add RSS when you already trust the feed URL.</li>
            <li>Add Website when you need the system to discover feeds, collections, or extractable resources.</li>
            <li>Use Observability to confirm whether the problem is fetch health before editing source rules.</li>
          </ul>
        </article>
        <article id="articles" class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">Content &amp; Moderation</p>
          <p class="mt-2 text-xs text-muted-foreground">
            <a href={pagePaths.articles} class="text-primary hover:underline">Articles</a> is the main triage surface for editorial observations, canonical document ownership, verification, and final-selection read model state.
          </p>
          <ul class="mt-3 space-y-2 text-xs text-muted-foreground">
            <li>Use block/unblock when the collection decision is wrong.</li>
            <li>Use the preview workspace before jumping to full detail.</li>
            <li>Read raw processing state only after the summary area points to a pipeline problem.</li>
          </ul>
        </article>
        <article id="clusters" class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">Event Clusters</p>
          <p class="mt-2 text-xs text-muted-foreground">
            <a href={pagePaths.clusters} class="text-primary hover:underline">Clusters</a> groups canonical documents that describe the same event. Use it when you need corroboration context, duplicate pressure, or verification strength instead of one row’s local metadata.
          </p>
        </article>
        <article class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">User-specific tuning</p>
          <p class="mt-2 text-xs text-muted-foreground">
            <a href={appPath("/user-interests")} class="text-primary hover:underline">User Interests</a> now opens as a focused workspace after lookup. Keep the left queue for prioritization and use the main pane for the one interest you are actively editing or compiling.
          </p>
        </article>
      </div>
    </section>

    <section id="rules" class="space-y-3">
      <h2 class="text-lg font-bold border-b border-border pb-2">Rules &amp; AI Review</h2>
      <div class="grid gap-3 md:grid-cols-2">
        <article id="templates" class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">LLM &amp; System Interests</p>
          <p class="mt-2 text-xs text-muted-foreground">
            <a href={pagePaths.llmTemplates} class="text-primary hover:underline">LLM Templates</a> define review prompts, while <a href={pagePaths.interestTemplates} class="text-primary hover:underline">System Interests</a> define reusable prototypes, hard constraints, time windows, and content-kind gates for system selection.
          </p>
          <p class="mt-3 text-xs text-muted-foreground">
            Matching constraints sync into live criteria for fresh ingest and historical reindex, while <code class="rounded bg-muted px-1 py-0.5">allowed_content_kinds</code> remains the gate for what can appear in the system-selected collection.
          </p>
        </article>
        <article id="gray-zone" class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">Gray Zone &amp; AI Review</p>
          <p class="mt-2 text-xs text-muted-foreground">
            The baseline LLM lane currently applies only to system-interest gray-zone decisions. User-interest gray-zone review stays suppressed in the baseline tier.
          </p>
          <div class="mt-3 grid gap-2 sm:grid-cols-3">
            <div class="rounded-md border border-emerald-200 bg-emerald-50 p-3 text-center dark:border-emerald-900/40 dark:bg-emerald-950/20">
              <p class="text-lg font-bold text-emerald-600 dark:text-emerald-400">≥ 0.72</p>
              <p class="text-[11px] font-medium text-emerald-800 dark:text-emerald-300">Relevant</p>
            </div>
            <div class="rounded-md border border-amber-200 bg-amber-50 p-3 text-center dark:border-amber-900/40 dark:bg-amber-950/20">
              <p class="text-lg font-bold text-amber-600 dark:text-amber-400">0.45 – 0.72</p>
              <p class="text-[11px] font-medium text-amber-800 dark:text-amber-300">Gray Zone</p>
            </div>
            <div class="rounded-md border border-border bg-muted p-3 text-center">
              <p class="text-lg font-bold text-muted-foreground">≤ 0.45</p>
              <p class="text-[11px] font-medium">Irrelevant</p>
            </div>
          </div>
          <p class="mt-3 text-xs text-muted-foreground">
            Monitor budget and cap behavior on <a href={pagePaths.observability} class="text-primary hover:underline">Observability</a>, not on the rule-editing pages themselves.
          </p>
        </article>
      </div>
    </section>

    <section id="reindex" class="space-y-3">
      <h2 class="text-lg font-bold border-b border-border pb-2">Reindex &amp; Maintenance</h2>
      <div class="grid gap-3 md:grid-cols-2">
        <article class="rounded-xl border border-amber-200 bg-amber-50/60 p-4 dark:border-amber-900/40 dark:bg-amber-950/20">
          <p class="text-sm font-medium">When to reindex</p>
          <ul class="mt-3 space-y-2 text-xs text-muted-foreground">
            <li>After major system-interest or user-interest changes.</li>
            <li>After a restore or repair that changed the effective baseline.</li>
            <li>When matching quality looks stale but ingest health still looks normal.</li>
          </ul>
        </article>
        <article class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">What maintenance does not do</p>
          <ul class="mt-3 space-y-2 text-xs text-muted-foreground">
            <li>It does not delete stored content.</li>
            <li>It does not resend retro notifications.</li>
            <li>It does not replace source debugging when the real issue is fetch failure.</li>
          </ul>
        </article>
      </div>
      <p class="text-sm text-muted-foreground">
        Start on <a href={pagePaths.reindex} class="text-primary hover:underline">Reindex</a> for one-off repairs, and use <a href={pagePaths.reindex} class="text-primary hover:underline">Reindex</a> plus <a href={appPath("/automation")} class="text-primary hover:underline">Automation</a> together when the same maintenance job needs a repeatable operator-owned workflow.
      </p>
    </section>

    <section id="observability" class="space-y-3">
      <h2 class="text-lg font-bold border-b border-border pb-2">Observability &amp; Costs</h2>
      <p class="text-sm text-muted-foreground">
        The <a href={pagePaths.observability} class="text-primary hover:underline">Observability</a> page is split into fetch health and AI review &amp; budget so source instability and review-cost pressure are debugged separately.
      </p>
      <div class="grid gap-3 md:grid-cols-3">
        <article class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">Fetch Runs</p>
          <p class="mt-2 text-xs text-muted-foreground">Each row is one poll of a channel. High error counts mean inspect the source first, not the matching rules.</p>
        </article>
        <article class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">LLM Reviews</p>
          <p class="mt-2 text-xs text-muted-foreground">Each row is one gray-zone review with decision, tokens, cost, and latency. Use it to watch review pressure rather than article correctness.</p>
        </article>
        <article class="rounded-xl border border-border bg-card p-4">
          <p class="text-sm font-medium">Budget state</p>
          <p class="mt-2 text-xs text-muted-foreground">Track remaining monthly budget, hard-stop state, and post-cap policy here before changing prompts or thresholds elsewhere.</p>
        </article>
      </div>
    </section>
  </div>
</AdminShell>
