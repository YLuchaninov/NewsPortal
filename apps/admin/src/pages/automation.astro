---
import { DEFAULT_PAGE } from "@newsportal/contracts";

import { AutomationOverviewBoard } from "../components/AutomationOverviewBoard";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../lib/server/browser-flow";
import { loadAutomationOverviewData } from "../lib/server/automation-workspace";

export const prerender = false;

const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);

if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const requestedPage = Number.parseInt(
  Astro.url.searchParams.get("sequencePage") ?? String(DEFAULT_PAGE),
  10
);
const sequencePage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : DEFAULT_PAGE;
const data = await loadAutomationOverviewData({
  page: sequencePage,
  pageSize: 12,
});
const liveUpdatesEndpoint = `${appPath("/bff/admin/live-updates")}?surface=automation&page=${sequencePage}&pageSize=12`;
---

<AdminShell
  title="Automation — Admin"
  session={session}
  flash={flash}
  activeNav="automation"
  liveUpdatesEndpoint={liveUpdatesEndpoint}
  liveUpdatesSurface="automation"
>
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={appPath("/")} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="font-medium text-foreground">Automation</span>
    </nav>
  </Fragment>

  <AutomationOverviewBoard
    sequences={data.sequences}
    recentRuns={data.recentRuns}
    outboxEvents={data.outboxEvents}
    summary={data.summary}
    automationBffPath={appPath("/bff/admin/automation")}
    automationRootPath={appPath("/automation")}
    templatesHref={appPath("/automation/templates")}
    mcpTokensHref={appPath("/automation/mcp")}
    currentUserId={session.userId}
    client:load
  />
</AdminShell>
