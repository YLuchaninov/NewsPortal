---
import { DEFAULT_PAGE, DEFAULT_PAGE_SIZE } from "@newsportal/contracts";
import { readRuntimeConfig } from "@newsportal/config";
import { createNewsPortalSdk } from "@newsportal/sdk";
import { PaginationNav } from "@newsportal/ui";
import AdminShell from "../layouts/AdminShell.astro";
import { resolveAdminSession } from "../lib/server/auth";
import {
  buildAdminSignInPath,
  readFlash,
  resolveAdminAppPath,
  resolveAdminCurrentPath,
} from "../lib/server/browser-flow";
import {
  isSequenceRunCancellable,
  listRecentSequenceRuns,
  listSequenceTaskRuns,
  resolveSequenceOperatorSummary,
} from "../lib/server/automation";

export const prerender = false;

const runtimeConfig = readRuntimeConfig(process.env, {
  defaultAppBaseUrl: "http://127.0.0.1:4322/",
});
const session = await resolveAdminSession(Astro.request);
const appPath = (target = "/") => resolveAdminAppPath(Astro.request, target);
if (!session) {
  return Astro.redirect(
    buildAdminSignInPath(Astro.request, resolveAdminCurrentPath(Astro.request))
  );
}

const flash = readFlash(Astro.url);
const sdk = createNewsPortalSdk({ baseUrl: runtimeConfig.apiBaseUrl, fetchImpl: fetch });
const automationBffPath = appPath("/bff/admin/automation");
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;

type R = Record<string, unknown>;
function asArray(value: unknown): R[] {
  return Array.isArray(value) ? value.map((entry) => (entry && typeof entry === "object" ? (entry as R) : {})) : [];
}

function asInt(value: unknown, fallback = 0): number {
  const parsed =
    typeof value === "number" && Number.isFinite(value)
      ? value
      : Number.parseInt(String(value ?? ""), 10);
  return Number.isFinite(parsed) ? parsed : fallback;
}

function readString(value: unknown, fallback = "—"): string {
  const normalized = String(value ?? "").trim();
  return normalized ? normalized : fallback;
}

function formatTimestamp(value: unknown): string {
  if (!value) {
    return "—";
  }
  const date = new Date(String(value));
  if (Number.isNaN(date.getTime())) {
    return String(value);
  }
  return date.toLocaleString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit",
  });
}

function formatJson(value: unknown, fallback = "{}"): string {
  if (value == null || value === "") {
    return fallback;
  }
  try {
    return JSON.stringify(value, null, 2);
  } catch {
    return fallback;
  }
}

function badgeClass(status: string): string {
  switch (status) {
    case "active":
    case "completed":
    case "published":
      return "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300";
    case "draft":
    case "pending":
      return "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300";
    case "failed":
      return "bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-300";
    case "archived":
    case "cancelled":
      return "bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-300";
    default:
      return "bg-muted text-muted-foreground";
  }
}

const requestedPage = Number.parseInt(
  Astro.url.searchParams.get("sequencePage") ?? String(DEFAULT_PAGE),
  10
);
const sequencePage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : DEFAULT_PAGE;
const requestedRunId = Astro.url.searchParams.get("runId")?.trim() ?? "";

const [sequences, pluginsRaw, outboxRaw, recentRuns] = await Promise.all([
  sdk.listSequencesPage<R>({
    page: sequencePage,
    pageSize: DEFAULT_PAGE_SIZE,
  }),
  sdk.listSequencePlugins<R[]>(),
  sdk.listOutboxEvents<R[]>(20),
  listRecentSequenceRuns(12),
]);

const plugins = asArray(pluginsRaw);
const outboxEvents = asArray(outboxRaw);
const sequenceItems = sequences.items.map((item) => item ?? {});
const selectedRunId =
  recentRuns.find((run) => String(run.run_id ?? "") === requestedRunId) != null
    ? requestedRunId
    : String(recentRuns[0]?.run_id ?? "");
const selectedRunTaskRuns = selectedRunId ? await listSequenceTaskRuns(selectedRunId) : [];
const operatorSummary = resolveSequenceOperatorSummary({
  sequences: sequenceItems,
  runs: recentRuns,
  outboxEvents,
});

function resolveSequencePageHref(nextPage: number): string {
  const target = new URL(Astro.url);
  if (nextPage <= DEFAULT_PAGE) {
    target.searchParams.delete("sequencePage");
  } else {
    target.searchParams.set("sequencePage", String(nextPage));
  }
  return `${target.pathname}${target.search}`;
}

function resolveRunHref(nextRunId: string | null): string {
  const target = new URL(Astro.url);
  if (nextRunId) {
    target.searchParams.set("runId", nextRunId);
  } else {
    target.searchParams.delete("runId");
  }
  return `${target.pathname}${target.search}`;
}

const createTaskGraphExample = JSON.stringify(
  [
    {
      key: "normalize",
      module: "article.normalize",
      options: {},
    },
  ],
  null,
  2
);

const pagePaths = {
  dashboard: appPath("/"),
};
---

<AdminShell title="Automation — Admin" session={session} flash={flash} activeNav="automation">
  <Fragment slot="header-title">
    <nav class="flex items-center gap-1 text-sm text-muted-foreground">
      <a href={pagePaths.dashboard} class="hover:text-foreground">Dashboard</a>
      <span>/</span>
      <span class="text-foreground font-medium">Automation</span>
    </nav>
  </Fragment>

  <div class="space-y-6">
    <section class="rounded-[1.75rem] border border-border bg-card p-6 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary/80">Sequence-first control plane</p>
          <h1 class="mt-2 text-2xl font-semibold tracking-tight">Automation and outbox</h1>
          <p class="mt-2 text-sm leading-6 text-muted-foreground">
            Operate the sequence engine from admin instead of dropping down to raw maintenance API calls. This surface keeps
            sequence definitions, recent run state, plugin visibility, and recent outbox traffic in one operator view.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-6">
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Sequences</p>
            <p class="mt-1 text-2xl font-semibold">{operatorSummary.totalSequences}</p>
          </div>
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Active</p>
            <p class="mt-1 text-2xl font-semibold">{operatorSummary.activeSequences}</p>
          </div>
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Draft</p>
            <p class="mt-1 text-2xl font-semibold">{operatorSummary.draftSequences}</p>
          </div>
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Recent runs</p>
            <p class="mt-1 text-2xl font-semibold">{operatorSummary.recentRuns}</p>
          </div>
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Pending runs</p>
            <p class="mt-1 text-2xl font-semibold">{operatorSummary.pendingRuns}</p>
          </div>
          <div class="rounded-2xl border border-border bg-background px-4 py-3">
            <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">Pending outbox</p>
            <p class="mt-1 text-2xl font-semibold">{operatorSummary.pendingOutboxEvents}</p>
          </div>
        </div>
      </div>
    </section>

    <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold">Create sequence</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Draft or activate a new sequence definition directly from admin.
            </p>
          </div>
          <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 text-[11px] font-medium text-muted-foreground">
            maintenance API write
          </span>
        </div>
        <form method="post" action={automationBffPath} class="mt-5 grid gap-4">
          <input type="hidden" name="intent" value="create_sequence" />
          <input type="hidden" name="redirectTo" value={currentPath} />
          <div class="grid gap-4 md:grid-cols-2">
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Title</span>
              <input name="title" required class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Status</span>
              <select name="status" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">
                <option value="draft">draft</option>
                <option value="active">active</option>
              </select>
            </label>
          </div>
          <label class="grid gap-1.5">
            <span class="text-xs font-medium">Description</span>
            <textarea name="description" rows="3" class="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring"></textarea>
          </label>
          <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Trigger event</span>
              <input name="triggerEvent" placeholder="optional" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Cron</span>
              <input name="cron" placeholder="*/15 * * * *" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Max runs</span>
              <input name="maxRuns" inputmode="numeric" placeholder="optional" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
            <label class="grid gap-1.5">
              <span class="text-xs font-medium">Tags</span>
              <input name="tags" placeholder="ops, manual" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
            </label>
          </div>
          <label class="grid gap-1.5">
            <span class="text-xs font-medium">Task graph JSON</span>
            <textarea name="taskGraph" rows="10" class="w-full rounded-md border border-input bg-transparent px-3 py-2 font-mono text-xs shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">{createTaskGraphExample}</textarea>
          </label>
          <button type="submit" class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
            Create sequence
          </button>
        </form>
      </section>

      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold">Plugin catalog</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Live task registry exposed by the sequence engine.
            </p>
          </div>
          <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 text-[11px] font-medium text-muted-foreground">
            {plugins.length} plugin{plugins.length === 1 ? "" : "s"}
          </span>
        </div>
        <div class="mt-4 max-h-[32rem] overflow-y-auto space-y-3 pr-1">
          {plugins.length === 0 ? (
            <p class="rounded-xl border border-dashed border-border px-4 py-6 text-sm text-muted-foreground">
              No plugins were returned by the maintenance API.
            </p>
          ) : plugins.map((plugin) => (
            <details class="rounded-xl border border-border bg-background p-4">
              <summary class="cursor-pointer list-none">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-sm font-semibold">{readString(plugin.module)}</p>
                  <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                    {readString(plugin.category)}
                  </span>
                </div>
                <p class="mt-1 text-sm text-muted-foreground">{readString(plugin.description)}</p>
              </summary>
              <div class="mt-4 grid gap-4 xl:grid-cols-2">
                <div>
                  <p class="text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Inputs</p>
                  <pre class="mt-2 overflow-x-auto rounded-xl border border-border bg-muted/50 p-3 text-[11px] leading-5">{formatJson(plugin.inputs)}</pre>
                </div>
                <div>
                  <p class="text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Outputs</p>
                  <pre class="mt-2 overflow-x-auto rounded-xl border border-border bg-muted/50 p-3 text-[11px] leading-5">{formatJson(plugin.outputs)}</pre>
                </div>
              </div>
            </details>
          ))}
        </div>
      </section>
    </div>

    <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="text-base font-semibold">Sequence definitions</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            Update task graphs, activate or draft definitions, request manual runs, or archive stale entries.
          </p>
        </div>
        <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 text-[11px] font-medium text-muted-foreground">
          page {sequences.page} of {sequences.totalPages || 1}
        </span>
      </div>

      <div class="mt-5 space-y-4">
        {sequenceItems.length === 0 ? (
          <p class="rounded-xl border border-dashed border-border px-4 py-8 text-sm text-muted-foreground">
            No sequence definitions exist yet.
          </p>
        ) : sequenceItems.map((sequence) => {
          const sequenceId = readString(sequence.sequence_id, "");
          const tags = Array.isArray(sequence.tags) ? sequence.tags.map((tag) => String(tag)) : [];
          return (
            <article class="rounded-2xl border border-border bg-background p-5">
              <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="text-base font-semibold">{readString(sequence.title)}</h3>
                    <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium ${badgeClass(readString(sequence.status, ""))}`}>
                      {readString(sequence.status)}
                    </span>
                  </div>
                  <p class="mt-1 text-sm text-muted-foreground">{readString(sequence.description, "No description")}</p>
                  <p class="mt-2 text-xs text-muted-foreground">
                    ID {sequenceId} · Trigger {readString(sequence.trigger_event)} · Cron {readString(sequence.cron)} · Runs {asInt(sequence.run_count, 0)} · Updated {formatTimestamp(sequence.updated_at)}
                  </p>
                </div>
                {tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {tags.map((tag) => (
                      <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>

              <div class="mt-4 grid gap-4 xl:grid-cols-[1.15fr_0.85fr]">
                <form method="post" action={automationBffPath} class="grid gap-4">
                  <input type="hidden" name="intent" value="update_sequence" />
                  <input type="hidden" name="redirectTo" value={currentPath} />
                  <input type="hidden" name="sequenceId" value={sequenceId} />
                  <div class="grid gap-4 md:grid-cols-2">
                    <label class="grid gap-1.5">
                      <span class="text-xs font-medium">Title</span>
                      <input name="title" value={readString(sequence.title, "")} class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
                    </label>
                    <label class="grid gap-1.5">
                      <span class="text-xs font-medium">Status</span>
                      <select name="status" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">
                        {["draft", "active", "archived"].map((status) => (
                          <option value={status} selected={status === readString(sequence.status, "draft")}>{status}</option>
                        ))}
                      </select>
                    </label>
                  </div>
                  <label class="grid gap-1.5">
                    <span class="text-xs font-medium">Description</span>
                    <textarea name="description" rows="3" class="w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">{readString(sequence.description, "")}</textarea>
                  </label>
                  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                    <label class="grid gap-1.5">
                      <span class="text-xs font-medium">Trigger event</span>
                      <input name="triggerEvent" value={readString(sequence.trigger_event, "")} class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
                    </label>
                    <label class="grid gap-1.5">
                      <span class="text-xs font-medium">Cron</span>
                      <input name="cron" value={readString(sequence.cron, "")} class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
                    </label>
                    <label class="grid gap-1.5">
                      <span class="text-xs font-medium">Max runs</span>
                      <input name="maxRuns" inputmode="numeric" value={String(sequence.max_runs ?? "")} class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
                    </label>
                    <label class="grid gap-1.5">
                      <span class="text-xs font-medium">Tags</span>
                      <input name="tags" value={tags.join(", ")} class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring" />
                    </label>
                  </div>
                  <textarea name="taskGraph" rows="10" class="w-full rounded-md border border-input bg-transparent px-3 py-2 font-mono text-xs shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">{formatJson(sequence.task_graph, "[]")}</textarea>
                  <button type="submit" class="inline-flex h-10 items-center justify-center rounded-md border border-input px-4 text-sm font-medium transition-colors hover:bg-accent">
                    Save sequence
                  </button>
                </form>

                <div class="grid gap-4">
                  <form method="post" action={automationBffPath} class="rounded-2xl border border-border p-4">
                    <input type="hidden" name="intent" value="run_sequence" />
                    <input type="hidden" name="redirectTo" value={currentPath} />
                    <input type="hidden" name="sequenceId" value={sequenceId} />
                    <div class="space-y-3">
                      <div>
                        <h4 class="text-sm font-semibold">Request manual run</h4>
                        <p class="mt-1 text-xs text-muted-foreground">The run is created through the same maintenance API used by runtime tooling.</p>
                      </div>
                      <label class="grid gap-1.5">
                        <span class="text-xs font-medium">Context JSON</span>
                        <textarea name="contextJson" rows="4" class="w-full rounded-md border border-input bg-transparent px-3 py-2 font-mono text-xs shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">{`{}`}</textarea>
                      </label>
                      <label class="grid gap-1.5">
                        <span class="text-xs font-medium">Trigger meta JSON</span>
                        <textarea name="triggerMeta" rows="3" class="w-full rounded-md border border-input bg-transparent px-3 py-2 font-mono text-xs shadow-sm outline-none focus-visible:ring-1 focus-visible:ring-ring">{`{}`}</textarea>
                      </label>
                      <button type="submit" class="inline-flex h-10 w-full items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
                        Run now
                      </button>
                    </div>
                  </form>

                  <form method="post" action={automationBffPath} class="rounded-2xl border border-border p-4">
                    <input type="hidden" name="intent" value="archive_sequence" />
                    <input type="hidden" name="redirectTo" value={currentPath} />
                    <input type="hidden" name="sequenceId" value={sequenceId} />
                    <div class="space-y-3">
                      <div>
                        <h4 class="text-sm font-semibold">Archive definition</h4>
                        <p class="mt-1 text-xs text-muted-foreground">Archiving keeps history but prevents future routing or manual runs.</p>
                      </div>
                      <button type="submit" class="inline-flex h-10 w-full items-center justify-center rounded-md border border-rose-300 px-4 text-sm font-medium text-rose-700 transition-colors hover:bg-rose-50 dark:border-rose-900/40 dark:text-rose-300 dark:hover:bg-rose-950/20">
                        Archive
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      {(sequences.hasPrev || sequences.hasNext) && (
        <div class="mt-5">
          <PaginationNav
            page={sequences.page}
            totalPages={sequences.totalPages}
            hasPrev={sequences.hasPrev}
            hasNext={sequences.hasNext}
            prevHref={resolveSequencePageHref(sequences.page - 1)}
            nextHref={resolveSequencePageHref(sequences.page + 1)}
          />
        </div>
      )}
    </section>

    <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold">Recent sequence runs</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Recent execution state from PostgreSQL-backed sequence history.
            </p>
          </div>
          {selectedRunId && (
            <a href={resolveRunHref(null)} class="text-sm text-primary hover:underline">Clear task-run focus</a>
          )}
        </div>
        <div class="mt-5 space-y-4">
          {recentRuns.length === 0 ? (
            <p class="rounded-xl border border-dashed border-border px-4 py-8 text-sm text-muted-foreground">
              No recent sequence runs yet.
            </p>
          ) : recentRuns.map((run) => {
            const runId = readString(run.run_id, "");
            const status = readString(run.status, "");
            return (
              <article class={`rounded-2xl border p-4 ${selectedRunId === runId ? "border-primary/50 bg-primary/5" : "border-border bg-background"}`}>
                <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                  <div>
                    <div class="flex flex-wrap items-center gap-2">
                      <h3 class="text-sm font-semibold">{readString(run.sequence_title)}</h3>
                      <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium ${badgeClass(status)}`}>
                        {status}
                      </span>
                    </div>
                    <p class="mt-1 text-xs text-muted-foreground">
                      Run {runId} · Sequence {readString(run.sequence_id)} · Trigger {readString(run.trigger_type)} · Created {formatTimestamp(run.created_at)}
                    </p>
                    <p class="mt-1 text-xs text-muted-foreground">
                      Tasks {asInt(run.completed_tasks, 0)}/{asInt(run.total_tasks, 0)} completed · Running {asInt(run.running_tasks, 0)} · Failed {asInt(run.failed_tasks, 0)} · Skipped {asInt(run.skipped_tasks, 0)}
                    </p>
                    {readString(run.error_text, "") && readString(run.error_text, "") !== "—" && (
                      <p class="mt-2 text-xs text-rose-600 dark:text-rose-300">{readString(run.error_text, "")}</p>
                    )}
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <a href={resolveRunHref(runId)} class="inline-flex h-8 items-center justify-center rounded-md border border-input px-3 text-xs font-medium transition-colors hover:bg-accent">
                      Inspect task runs
                    </a>
                    {isSequenceRunCancellable(status) && (
                      <form method="post" action={automationBffPath}>
                        <input type="hidden" name="intent" value="cancel_run" />
                        <input type="hidden" name="redirectTo" value={resolveRunHref(runId)} />
                        <input type="hidden" name="runId" value={runId} />
                        <input type="hidden" name="reason" value="Cancelled via admin automation surface." />
                        <button type="submit" class="inline-flex h-8 items-center justify-center rounded-md border border-rose-300 px-3 text-xs font-medium text-rose-700 transition-colors hover:bg-rose-50 dark:border-rose-900/40 dark:text-rose-300 dark:hover:bg-rose-950/20">
                          Cancel run
                        </button>
                      </form>
                    )}
                  </div>
                </div>
                <details class="mt-3">
                  <summary class="cursor-pointer text-xs font-medium text-muted-foreground">Context and trigger meta</summary>
                  <div class="mt-3 grid gap-3 xl:grid-cols-2">
                    <pre class="overflow-x-auto rounded-xl border border-border bg-muted/50 p-3 text-[11px] leading-5">{formatJson(run.context_json)}</pre>
                    <pre class="overflow-x-auto rounded-xl border border-border bg-muted/50 p-3 text-[11px] leading-5">{formatJson(run.trigger_meta)}</pre>
                  </div>
                </details>
              </article>
            );
          })}
        </div>
      </section>

      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold">Recent outbox events</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Read-only visibility into relay-facing durable events.
            </p>
          </div>
          <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 text-[11px] font-medium text-muted-foreground">
            {outboxEvents.length} shown
          </span>
        </div>
        <div class="mt-5 overflow-x-auto">
          <table class="min-w-full text-left text-sm">
            <thead class="border-b border-border text-xs uppercase tracking-[0.16em] text-muted-foreground">
              <tr>
                <th class="px-3 py-2 font-medium">Event</th>
                <th class="px-3 py-2 font-medium">Aggregate</th>
                <th class="px-3 py-2 font-medium">Status</th>
                <th class="px-3 py-2 font-medium">Attempts</th>
                <th class="px-3 py-2 font-medium">Created</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {outboxEvents.length === 0 ? (
                <tr>
                  <td colspan="5" class="px-3 py-6 text-sm text-muted-foreground">No outbox events returned.</td>
                </tr>
              ) : outboxEvents.map((event) => (
                <tr>
                  <td class="px-3 py-3 align-top">
                    <p class="font-medium text-foreground">{readString(event.event_type)}</p>
                    <p class="mt-1 text-xs text-muted-foreground">{readString(event.event_id)}</p>
                  </td>
                  <td class="px-3 py-3 align-top text-muted-foreground">
                    <p>{readString(event.aggregate_type)}</p>
                    <p class="mt-1 text-xs">{readString(event.aggregate_id)}</p>
                  </td>
                  <td class="px-3 py-3 align-top">
                    <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium ${badgeClass(readString(event.status, ""))}`}>
                      {readString(event.status)}
                    </span>
                    {readString(event.error_message, "") && readString(event.error_message, "") !== "—" && (
                      <p class="mt-2 max-w-xs text-xs text-rose-600 dark:text-rose-300">{readString(event.error_message, "")}</p>
                    )}
                  </td>
                  <td class="px-3 py-3 align-top text-muted-foreground">{String(event.attempt_count ?? 0)}</td>
                  <td class="px-3 py-3 align-top text-muted-foreground">{formatTimestamp(event.created_at)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </div>

    {selectedRunId && (
      <section class="rounded-2xl border border-border bg-card p-5 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold">Task runs for {selectedRunId}</h2>
            <p class="mt-1 text-sm text-muted-foreground">
              Per-task execution detail for the selected sequence run.
            </p>
          </div>
        </div>
        <div class="mt-5 space-y-4">
          {selectedRunTaskRuns.length === 0 ? (
            <p class="rounded-xl border border-dashed border-border px-4 py-8 text-sm text-muted-foreground">
              No task-run rows exist yet for this sequence run.
            </p>
          ) : selectedRunTaskRuns.map((taskRun) => (
            <article class="rounded-2xl border border-border bg-background p-4">
              <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="text-sm font-semibold">{String(taskRun.task_key ?? "task")}</h3>
                    <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium ${badgeClass(readString(taskRun.status, ""))}`}>
                      {readString(taskRun.status)}
                    </span>
                  </div>
                  <p class="mt-1 text-xs text-muted-foreground">
                    Module {readString(taskRun.module)} · Index {String(taskRun.task_index ?? 0)} · Started {formatTimestamp(taskRun.started_at)} · Finished {formatTimestamp(taskRun.finished_at)} · Duration {String(taskRun.duration_ms ?? "—")} ms
                  </p>
                  {readString(taskRun.error_text, "") && readString(taskRun.error_text, "") !== "—" && (
                    <p class="mt-2 text-xs text-rose-600 dark:text-rose-300">{readString(taskRun.error_text, "")}</p>
                  )}
                </div>
              </div>
              <details class="mt-3">
                <summary class="cursor-pointer text-xs font-medium text-muted-foreground">Options, input, and output</summary>
                <div class="mt-3 grid gap-3 xl:grid-cols-3">
                  <pre class="overflow-x-auto rounded-xl border border-border bg-muted/50 p-3 text-[11px] leading-5">{formatJson(taskRun.options_json)}</pre>
                  <pre class="overflow-x-auto rounded-xl border border-border bg-muted/50 p-3 text-[11px] leading-5">{formatJson(taskRun.input_json)}</pre>
                  <pre class="overflow-x-auto rounded-xl border border-border bg-muted/50 p-3 text-[11px] leading-5">{formatJson(taskRun.output_json)}</pre>
                </div>
              </details>
            </article>
          ))}
        </div>
      </section>
    )}
  </div>
</AdminShell>
