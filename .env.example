# Copy this file to .env.dev (or another runtime env file) and replace placeholder secrets.
# The committed baseline stays safe by default: local ports, discovery disabled, and manual review preferred.

# PostgreSQL database name used by local services and host-side scripts.
POSTGRES_DB=newsportal

# PostgreSQL username for the local baseline.
POSTGRES_USER=newsportal

# PostgreSQL password for the local baseline. Replace outside throwaway local setups.
POSTGRES_PASSWORD=change-me

# Host-side PostgreSQL address. Docker services override this with the internal compose DNS name.
POSTGRES_HOST=127.0.0.1

# Host-side PostgreSQL port exposed by the local compose stack.
POSTGRES_PORT=55432

# Host-side Redis address. Docker services override this with the internal compose DNS name.
REDIS_HOST=127.0.0.1

# Host-side Redis port exposed by the local compose stack.
REDIS_PORT=56379

# Host port mapped to the relay service.
RELAY_PORT=4000

# Host port mapped to the fetchers service.
FETCHERS_PORT=4100

# Host port mapped to the Python API service.
API_PORT=8000

# Host port mapped to the web app.
WEB_PORT=4321

# Host port mapped to the admin app.
ADMIN_PORT=4322

# Host port mapped to nginx, which fronts the local stack.
NGINX_PORT=8080

# How often relay polls PostgreSQL outbox rows, in milliseconds.
OUTBOX_POLL_INTERVAL_MS=1000

# Maximum number of outbox rows relay handles per poll batch.
OUTBOX_BATCH_SIZE=20

# Legacy embed fanout toggle for relay compatibility paths. Keep enabled only if your local flow expects it.
RELAY_ENABLE_EMBED_FANOUT=1

# How often fetchers scans for due channels, in milliseconds.
FETCHERS_POLL_INTERVAL_MS=5000

# Maximum number of channels fetchers loads per scheduling batch.
FETCHERS_BATCH_SIZE=100

# Parallel fetch worker count inside the fetchers service.
FETCHERS_CONCURRENCY=4

# Default HTTP timeout for RSS/website fetch requests, in milliseconds.
FETCHERS_REQUEST_TIMEOUT_MS=10000

# Default User-Agent header used by fetchers for outbound requests.
FETCHERS_USER_AGENT=NewsPortalFetchers/0.1 (+https://newsportal.local)

# Default embedding model used by ML/indexing flows.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Embedding backend selection. "auto" lets the runtime choose the available local implementation.
EMBEDDING_BACKEND=auto

# Fallback embedding/hash dimensionality expected by the derived index layer.
EMBEDDING_HASH_DIMENSIONS=384

# Directory for cached model artifacts inside the runtime environment.
MODEL_CACHE_DIR=/workspace/data/models

# Root directory for rebuilt HNSW indices.
HNSW_INDEX_ROOT=/workspace/data/indices

# Root directory for persisted HNSW snapshots.
HNSW_SNAPSHOT_ROOT=/workspace/data/snapshots

# Internal API base URL used by SSR/BFF code inside compose.
NEWSPORTAL_API_BASE_URL=http://api:8000

# Browser/host-facing API base URL used for links, redirects, and host-side checks.
NEWSPORTAL_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Browser/host-facing base URL for the web app. Keep the trailing slash.
NEWSPORTAL_WEB_APP_BASE_URL=http://127.0.0.1:4321/

# Browser/host-facing base URL for the admin app. Keep the trailing slash.
NEWSPORTAL_ADMIN_APP_BASE_URL=http://127.0.0.1:4322/

# Firebase project id for web/admin sign-in flows.
FIREBASE_PROJECT_ID=replace-me

# Firebase Web API key used by the browser-facing sign-in flow.
FIREBASE_WEB_API_KEY=replace-me

# Firebase client config JSON string for browser apps. Store this as minified JSON.
FIREBASE_CLIENT_CONFIG={}

# Firebase admin/service-account credentials JSON string for privileged server-side auth operations.
FIREBASE_ADMIN_CREDENTIALS={}

# Comma-separated allowlist of exact admin emails or whole domains prefixed with "@". Used for initial admin bootstrap.
ADMIN_ALLOWLIST_EMAILS=admin@example.com,@newsportal.local

# Gemini API key for the baseline system-interest gray-zone review runtime.
GEMINI_API_KEY=replace-me

# Default Gemini model for baseline LLM review and as a fallback for discovery when discovery-specific model is unset.
GEMINI_MODEL=gemini-2.0-flash

# Base URL for Gemini-compatible API calls.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Input-token cost used for baseline LLM cost accounting, in USD per 1M input tokens.
LLM_INPUT_COST_PER_MILLION_USD=0.10

# Output-token cost used for baseline LLM cost accounting, in USD per 1M output tokens.
LLM_OUTPUT_COST_PER_MILLION_USD=0.40

# Toggle for baseline system-interest gray-zone LLM review. Keep enabled unless you intentionally want that lane disabled.
LLM_REVIEW_ENABLED=1

# Hard monthly spending cap for baseline system-interest gray-zone LLM review, in cents, measured on the current UTC month. Set 0 to disable the cap.
LLM_REVIEW_MONTHLY_BUDGET_CENTS=0

# Post-cap policy for baseline system-interest gray-zone criteria: 1 auto-accepts them into the system gate, 0 auto-rejects them.
LLM_REVIEW_BUDGET_EXHAUST_ACCEPT_GRAY_ZONE=0

# Discovery kill switch. Keep 0 in committed/local-safe templates; set to 1 only when you intentionally enable discovery.
DISCOVERY_ENABLED=0

# Cron expression for scheduled discovery mission planning/runs.
DISCOVERY_CRON=0 */6 * * *

# Default per-mission discovery budget, in cents, applied when new missions are created.
DISCOVERY_BUDGET_CENTS_DEFAULT=500

# Maximum number of discovery hypotheses executed in one mission run.
DISCOVERY_MAX_HYPOTHESES_PER_RUN=20

# Default cap on how many sources one discovery mission should collect.
DISCOVERY_MAX_SOURCES_DEFAULT=20

# Optional legacy fallback threshold in the 0..1 range for profile-less discovery missions. Leave blank to require manual review unless a profile threshold applies.
DISCOVERY_AUTO_APPROVE_THRESHOLD=

# Active discovery search provider. Supported adapters are "stub", "ddgs", "brave", and "serper". The current safe baseline is "ddgs".
DISCOVERY_SEARCH_PROVIDER=ddgs

# DDGS backend mode. "auto" lets the library choose the best available backend.
DISCOVERY_DDGS_BACKEND=auto

# DDGS region hint used for search localization.
DISCOVERY_DDGS_REGION=us-en

# DDGS safesearch mode.
DISCOVERY_DDGS_SAFESEARCH=moderate

# Brave Search API key for DISCOVERY_SEARCH_PROVIDER=brave.
DISCOVERY_BRAVE_API_KEY=

# Serper API key for DISCOVERY_SEARCH_PROVIDER=serper.
DISCOVERY_SERPER_API_KEY=

# Optional discovery-specific Gemini key. If blank in real envs, discovery falls back to GEMINI_API_KEY.
DISCOVERY_GEMINI_API_KEY=replace-me

# Optional discovery-specific Gemini model. If blank in real envs, discovery falls back to GEMINI_MODEL.
DISCOVERY_GEMINI_MODEL=gemini-2.0-flash

# Optional discovery-specific Gemini base URL. If blank in real envs, discovery falls back to GEMINI_BASE_URL.
DISCOVERY_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Input-token discovery cost used for the discovery cost ledger, in USD per 1M input tokens.
DISCOVERY_LLM_INPUT_COST_PER_MILLION_USD=0.10

# Output-token discovery cost used for the discovery cost ledger, in USD per 1M output tokens.
DISCOVERY_LLM_OUTPUT_COST_PER_MILLION_USD=0.40

# Hard monthly discovery spending cap, in cents, measured on the current UTC month. Set 0 to disable the cap.
DISCOVERY_MONTHLY_BUDGET_CENTS=500

# Dormant placeholder for future Brave-backed discovery search. Unused by the current baseline.
DISCOVERY_BRAVE_API_KEY=

# Dormant placeholder for future Serper-backed discovery search. Unused by the current baseline.
DISCOVERY_SERPER_API_KEY=

# Telegram bot token for optional Telegram delivery.
TELEGRAM_BOT_TOKEN=replace-me

# SMTP URL for email digest delivery. The local MVP baseline expects the Mailpit sink.
EMAIL_DIGEST_SMTP_URL=smtp://mailpit:1025

# From-address used by email digests.
EMAIL_DIGEST_FROM=alerts@newsportal.local

# Toggle for the worker-side manual/scheduled digest polling loop.
WORKER_ENABLE_USER_DIGEST_SCHEDULER=1

# How often the worker polls queued manual digests and due scheduled digests, in seconds.
WORKER_USER_DIGEST_POLL_INTERVAL_SECONDS=5

# Local compose/dev baseline for concurrent sequence-run execution. The Python runtime fallback remains 1 when this env is unset.
WORKER_SEQUENCE_RUNNER_CONCURRENCY=4
WORKER_SEQUENCE_RUNNER_LOCK_DURATION_MS=300000
WORKER_SEQUENCE_RUNNER_STALLED_INTERVAL_MS=300000

# Public VAPID key exposed to browsers for web-push subscription setup.
WEB_PUSH_VAPID_PUBLIC_KEY=replace-me

# Private VAPID key used by the worker delivery runtime when sending web push notifications.
WEB_PUSH_VAPID_PRIVATE_KEY=replace-me

# Contact subject used in web-push VAPID metadata.
WEB_PUSH_VAPID_SUBJECT=mailto:alerts@newsportal.local

# Signing key for public API request/response security flows.
PUBLIC_API_SIGNING_KEY=replace-me

# Shared app secret used by Astro apps for session/cookie signing and related server-side secrets.
APP_SECRET=replace-me

# IMAP host for future email-imap source polling.
IMAP_HOST=imap.example.com

# IMAP port for email-imap polling. 993 is the common TLS default.
IMAP_PORT=993

# IMAP username for email-imap source polling.
IMAP_USERNAME=imap-user

# IMAP password for email-imap source polling.
IMAP_PASSWORD=replace-me
